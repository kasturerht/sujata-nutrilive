  <script is:inline>
    // All code is wrapped in an init function to handle Astro's ViewTransitions and page loads
    function initProductPage() {
      // Cinematic Reveal
      setTimeout(() => {
        const reveal = document.getElementById('cinematic-reveal');
        const text = document.getElementById('reveal-text');
        if (text) text.style.opacity = '0';
        if (reveal) {
          reveal.style.opacity = '0';
          setTimeout(() => reveal.remove(), 1000); 
        }
      }, 600);

      // Scroll Progress
      window.addEventListener('scroll', () => {
        const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
        const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const scrolled = (winScroll / height) * 100;
        const scrollBar = document.getElementById('scroll-progress');
        if(scrollBar) scrollBar.style.width = scrolled + '%';
      }, { passive: true });

      // Urgency Timer
      const timerElement = document.getElementById('countdown-timer');
      if(timerElement) {
        let time = 2 * 3600 + 14 * 60;
        setInterval(() => {
          time--;
          const h = Math.floor(time / 3600).toString().padStart(2, '0');
          const m = Math.floor((time % 3600) / 60).toString().padStart(2, '0');
          const s = (time % 60).toString().padStart(2, '0');
          timerElement.innerText = `${h}:${m}:${s}`;
        }, 1000);
      }

      // 3D Hover & Glare (Performance optimized with requestAnimationFrame throttling)
      const track = document.getElementById('premium-3d-track');
      const wrapper = document.getElementById('bottle-3d-wrapper');
      const glow = document.getElementById('ambient-glow');
      const glare = document.getElementById('bottle-glare');
      const customCursor = document.getElementById('custom-cursor');
      const mainImg = document.getElementById('main-pdp-image');
      const variantBtns = document.querySelectorAll('.variant-btn');
      const priceDisplay = document.getElementById('dynamic-price');

      let ticking3D = false;

      if (track && wrapper && glow && glare && customCursor) {
        track.addEventListener('mousemove', (e) => {
          if (!ticking3D) {
            const rect = track.getBoundingClientRect();
            const clientX = e.clientX;
            const clientY = e.clientY;

            window.requestAnimationFrame(() => {
              const x = clientX - rect.left;
              const y = clientY - rect.top;
              const xPct = (x / rect.width) - 0.5;
              const yPct = (y / rect.height) - 0.5;

              wrapper.style.transform = `rotateX(${yPct * -20}deg) rotateY(${xPct * 20}deg) scale(1.05)`;
              glow.style.transform = `translate(calc(-50% + ${xPct * 60}px), calc(-50% + ${yPct * 60}px))`;
              glare.style.opacity = '1';
              glare.style.transform = `translateX(${xPct * 200}%) translateY(${yPct * 200}%)`;

              customCursor.style.opacity = '1';
              customCursor.style.left = `${clientX}px`;
              customCursor.style.top = `${clientY}px`;
              ticking3D = false;
            });
            ticking3D = true;
          }
        });

        track.addEventListener('mouseleave', () => {
          window.requestAnimationFrame(() => {
            wrapper.style.transform = 'rotateX(0deg) rotateY(0deg) scale(1)';
            glow.style.transform = 'translate(-50%, -50%)';
            glare.style.opacity = '0';
            customCursor.style.opacity = '0';
          });
        });
      }

      // Magnetic Button (Performance optimized with requestAnimationFrame throttling)
      const btnWrapper = document.getElementById('magnetic-btn-wrapper');
      const atcBtn = document.getElementById('add-to-cart-btn');
      let btnTicking = false;

      if (btnWrapper && atcBtn) {
        btnWrapper.addEventListener('mousemove', (e) => {
          if (!btnTicking) {
            const rect = btnWrapper.getBoundingClientRect();
            const clientX = e.clientX;
            const clientY = e.clientY;

            window.requestAnimationFrame(() => {
              const x = clientX - rect.left;
              const y = clientY - rect.top;
              const pullX = (x - rect.width / 2) * 0.3;
              const pullY = (y - rect.height / 2) * 0.3;
              atcBtn.style.transform = `translate(${pullX}px, ${pullY}px)`;
              btnTicking = false;
            });
            btnTicking = true;
          }
        });

        btnWrapper.addEventListener('mouseleave', () => {
          window.requestAnimationFrame(() => {
            atcBtn.style.transform = 'translate(0px, 0px)';
          });
        });
      }

      // Thumbnails
      const thumbs = document.querySelectorAll('.thumb-btn');
      thumbs.forEach(b => {
        b.addEventListener('click', () => {
          const newSrc = b.getAttribute('data-src');
          if(mainImg && newSrc) {
            mainImg.style.opacity = '0';
            mainImg.style.transform = 'scale(0.95)';
            setTimeout(() => {
              mainImg.setAttribute('src', newSrc);
              mainImg.style.opacity = '1';
              mainImg.style.transform = 'scale(1)';
            }, 150);
            thumbs.forEach(t => {
              t.classList.remove('border-[#166534]', 'shadow-md', 'opacity-100');
              t.classList.add('border-transparent', 'opacity-50');
            });
            b.classList.add('border-[#166534]', 'shadow-md', 'opacity-100');
            b.classList.remove('border-transparent', 'opacity-50');
          }
        });
      });

      // Text Scramble
      const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&*";
      const scrambleElement = document.querySelector('.scramble-text');
      let scrambleInterval = null;
      if (scrambleElement) {
        const observerScramble = new IntersectionObserver((entries) => {
          if(entries[0].isIntersecting && !scrambleElement.classList.contains('scrambled')) {
            let iteration = 0;
            clearInterval(scrambleInterval);
            scrambleElement.classList.add('scrambled');
            scrambleInterval = setInterval(() => {
              scrambleElement.innerText = scrambleElement.innerText
                .split("")
                .map((letter, index) => {
                  if(index < iteration) return scrambleElement.dataset.value[index];
                  return letters[Math.floor(Math.random() * 42)];
                }).join("");
              if(iteration >= scrambleElement.dataset.value.length) clearInterval(scrambleInterval);
              iteration += 1 / 3;
            }, 30);
          }
        }, { threshold: 0.5 });
        observerScramble.observe(scrambleElement);
      }

      // Timeline Scroll
      const timelineLine = document.getElementById('timeline-progress');
      const steps = document.querySelectorAll('.timeline-step');
      
      if (timelineLine && steps.length > 0) {
        window.addEventListener('scroll', () => {
          steps.forEach((step, index) => {
            const rect = step.getBoundingClientRect();
            const dot = step.querySelector('.step-dot');
            const innerDot = step.querySelector('.step-inner-dot');
            
            if(rect.top < window.innerHeight * 0.7) {
              step.classList.remove('opacity-50');
              step.classList.add('opacity-100');
              dot.classList.replace('bg-emerald-900', 'bg-emerald-500');
              dot.classList.replace('border-[#022c22]', 'border-emerald-200');
              innerDot.classList.replace('bg-transparent', 'bg-white');
              const progress = ((index + 1) / steps.length) * 100;
              timelineLine.style.height = `${progress}%`;
            } else {
              step.classList.add('opacity-50');
              step.classList.remove('opacity-100');
              dot.classList.replace('bg-emerald-500', 'bg-emerald-900');
              dot.classList.replace('border-emerald-200', 'border-[#022c22]');
              innerDot.classList.replace('bg-white', 'bg-transparent');
            }
          });
        }, { passive: true });
      }

      // Lab Modal (100% FIXED & CRASH-PROOF)
      const labModal = document.getElementById('lab-modal');
      const openLabBtn = document.getElementById('open-lab-report');
      const closeLabBtn = document.getElementById('close-lab-modal');

      if(labModal && openLabBtn) {
        const closeModal = () => {
          labModal.classList.add('opacity-0', 'pointer-events-none');
          document.body.style.overflow = '';
        };
        openLabBtn.addEventListener('click', () => {
          labModal.classList.remove('opacity-0', 'pointer-events-none');
          document.body.style.overflow = 'hidden'; 
        });
        if (closeLabBtn) {
            closeLabBtn.addEventListener('click', closeModal);
        }
        labModal.addEventListener('click', (e) => {
          if(e.target === labModal) closeModal();
        });
      }

      // Odometer Score
      const odometerElements = document.querySelectorAll('.odometer-number');
      if (odometerElements.length > 0) {
        const observerOdometer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting && !entry.target.classList.contains('counted')) {
              entry.target.classList.add('counted');
              const target = +entry.target.getAttribute('data-target');
              const duration = 2000; 
              const step = target / (duration / 16); 
              let current = 0;
              const updateCounter = () => {
                current += step;
                if (current < target) {
                  entry.target.innerText = Math.ceil(current).toLocaleString('en-IN');
                  requestAnimationFrame(updateCounter);
                } else {
                  entry.target.innerText = target.toLocaleString('en-IN');
                }
              };
              updateCounter();
            }
          });
        }, { threshold: 0.5 });
        odometerElements.forEach(el => observerOdometer.observe(el));
      }

      // 1. Variant Switching Logic (Size switching)
      variantBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
          variantBtns.forEach(b => {
            b.classList.remove('border-[#111827]', 'text-[#111827]', 'bg-gray-50', 'selected-variant');
            b.classList.add('border-gray-200', 'text-gray-500');
          });

          const target = e.currentTarget;
          target.classList.remove('border-gray-200', 'text-gray-500');
          target.classList.add('border-[#111827]', 'text-[#111827]', 'bg-gray-50', 'selected-variant');

          // Sync data-variant-id attribute on the main ATC button
          const selectedVariantId = target.getAttribute('data-variant-id');
          if (atcBtn && selectedVariantId) {
            atcBtn.setAttribute('data-variant-id', selectedVariantId);
          }

          // Update Subscription Widget Labels dynamically when size changes
          const selectedPrice = parseFloat(target.getAttribute('data-price'));
          const selectedPriceFormatted = selectedPrice.toFixed(2);
          const discountedPriceFormatted = (selectedPrice * 0.9).toFixed(2);

          const labelOnetime = document.getElementById('onetime-price-label');
          const labelSubscribe = document.getElementById('subscribe-price-label');
          const labelOldSubscribe = document.getElementById('subscribe-old-price');

          if(labelOnetime) labelOnetime.innerText = `₹${selectedPriceFormatted}`;
          if(labelSubscribe) labelSubscribe.innerText = `₹${discountedPriceFormatted}`;
          if(labelOldSubscribe) labelOldSubscribe.innerText = `₹${selectedPriceFormatted}`;

          // Update main display price with fade animation
          if (priceDisplay) {
            priceDisplay.style.opacity = '0';
            priceDisplay.style.transform = 'translateY(-5px)';
            setTimeout(() => {
              updatePurchaseOptionUI();
              priceDisplay.style.opacity = '1';
              priceDisplay.style.transform = 'translateY(0)';
            }, 150);
          }
        });
      });

      // 1.5. Purchase Option (Subscription vs One-time) Selector Logic
      const radioOnetime = document.querySelector('input[value="onetime"]');
      const radioSubscribe = document.querySelector('input[value="subscribe"]');
      const optOnetime = document.getElementById('opt-one-time');
      const optSubscribe = document.getElementById('opt-subscribe');
      const btnTextElement = document.getElementById('btn-text');

      function updatePurchaseOptionUI() {
        const activeVariant = document.querySelector('.variant-btn.selected-variant');
        const basePrice = activeVariant ? parseFloat(activeVariant.getAttribute('data-price')) : 0;
        
        if (radioSubscribe && radioSubscribe.checked) {
          const discountPrice = (basePrice * 0.9).toFixed(2);
          if (priceDisplay) priceDisplay.innerText = `₹${discountPrice}`;
          if (btnTextElement) {
            btnTextElement.innerHTML = `Subscribe & Save <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`;
          }
          if (atcBtn) atcBtn.setAttribute('data-purchase-type', 'subscribe');
          optSubscribe?.classList.add('border-[#111827]', 'bg-gray-50/50');
          optSubscribe?.classList.remove('border-gray-200');
          optOnetime?.classList.add('border-gray-200');
          optOnetime?.classList.remove('border-[#111827]', 'bg-gray-50/50');
        } else {
          const basePriceFormatted = basePrice.toFixed(2);
          if (priceDisplay) priceDisplay.innerText = `₹${basePriceFormatted}`;
          if (btnTextElement) {
            btnTextElement.innerHTML = `Add to Routine <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`;
          }
          if (atcBtn) atcBtn.setAttribute('data-purchase-type', 'onetime');
          optOnetime?.classList.add('border-[#111827]', 'bg-gray-50/50');
          optOnetime?.classList.remove('border-gray-200');
          optSubscribe?.classList.add('border-gray-200');
          optSubscribe?.classList.remove('border-[#111827]', 'bg-gray-50/50');
        }
      }

      radioOnetime?.addEventListener('change', updatePurchaseOptionUI);
      radioSubscribe?.addEventListener('change', updatePurchaseOptionUI);
      
      optOnetime?.addEventListener('click', () => {
        const input = optOnetime.querySelector('input[type="radio"]');
        if (input && !input.checked) {
          input.checked = true;
          updatePurchaseOptionUI();
        }
      });
      
      optSubscribe?.addEventListener('click', () => {
        const input = optSubscribe.querySelector('input[type="radio"]');
        if (input && !input.checked) {
          input.checked = true;
          updatePurchaseOptionUI();
        }
      });

      // 2. WhatsApp Opt-in Checkbox State Logic (RTO Reduction)
      const waToggle = document.getElementById('whatsapp-toggle-container');
      const waCheckbox = document.getElementById('whatsapp-checkbox');
      
      if (waToggle && waCheckbox) {
        const checkboxIcon = waCheckbox.querySelector('svg');
        const isOptedIn = localStorage.getItem('sujata_whatsapp_optin') === 'true';
        
        const updateCheckboxState = (active) => {
          if (active) {
            waCheckbox.classList.remove('bg-white');
            waCheckbox.classList.add('bg-[#166534]');
            checkboxIcon?.classList.remove('scale-0');
            checkboxIcon?.classList.add('scale-100');
          } else {
            waCheckbox.classList.remove('bg-[#166534]');
            waCheckbox.classList.add('bg-white');
            checkboxIcon?.classList.remove('scale-100');
            checkboxIcon?.classList.add('scale-0');
          }
        };

        if (isOptedIn) updateCheckboxState(true);
        
        waToggle.addEventListener('click', () => {
          const active = waCheckbox.classList.contains('bg-[#166534]');
          if (active) {
            updateCheckboxState(false);
            localStorage.setItem('sujata_whatsapp_optin', 'false');
          } else {
            updateCheckboxState(true);
            localStorage.setItem('sujata_whatsapp_optin', 'true');
            
            // Trigger success feedback on global Live Toast
            const toast = document.getElementById('live-toast');
            const toastName = document.getElementById('toast-name');
            if (toast && toastName) {
              const oldName = toastName.innerText;
              const toastTitle = document.getElementById('toast-title');
              const toastAction = document.getElementById('toast-action');
              
              const oldTitleText = toastTitle ? toastTitle.innerText : 'Live Order';
              const oldActionText = toastAction ? toastAction.innerText : '';
              
              if (toastTitle) toastTitle.innerText = "WhatsApp Enabled";
              toastName.innerText = "Live tracking linked!";
              if (toastAction) toastAction.innerText = "Updates will be sent on checkout";
              
              toast.classList.remove('translate-y-[150%]', 'opacity-0');
              setTimeout(() => {
                toast.classList.add('translate-y-[150%]', 'opacity-0');
                setTimeout(() => {
                  if (toastTitle) toastTitle.innerText = oldTitleText;
                  toastName.innerText = oldName;
                  if (toastAction) toastAction.innerText = oldActionText;
                }, 800);
              }, 2500);
            }
          }
        });
      }
    } // End of initProductPage

    // Guarantee execution regardless of Astro's router state
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initProductPage);
    } else {
      initProductPage();
    }
    
    // Fallback for Astro ViewTransitions
    document.addEventListener('astro:page-load', initProductPage);
  </script>

</StoreLayout>