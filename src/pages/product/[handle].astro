      // Cinematic Reveal
      setTimeout(() => {
        const reveal = document.getElementById('cinematic-reveal');
        const text = document.getElementById('reveal-text');
        if (text) text.style.opacity = '0';
        if (reveal) {
          reveal.style.opacity = '0';
          setTimeout(() => reveal.remove(), 1000); 
        }
      }, 600);

      // Scroll Progress
      window.addEventListener('scroll', () => {
        const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
        const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const scrolled = (winScroll / height) * 100;
        const scrollBar = document.getElementById('scroll-progress');
        if(scrollBar) scrollBar.style.width = scrolled + '%';
      }, { passive: true });

      // Urgency Timer
      const timerElement = document.getElementById('countdown-timer');
      if(timerElement) {
        let time = 2 * 3600 + 14 * 60;
        setInterval(() => {
          time--;
          const h = Math.floor(time / 3600).toString().padStart(2, '0');
          const m = Math.floor((time % 3600) / 60).toString().padStart(2, '0');
          const s = (time % 60).toString().padStart(2, '0');
          timerElement.innerText = `${h}:${m}:${s}`;
        }, 1000);
      }

      // 3D Hover & Glare
      const track = document.getElementById('premium-3d-track');
      const wrapper = document.getElementById('bottle-3d-wrapper');
      const glow = document.getElementById('ambient-glow');
      const glare = document.getElementById('bottle-glare');
      const customCursor = document.getElementById('custom-cursor');
      const mainImg = document.getElementById('main-pdp-image');

      if (track && wrapper && glow && glare && customCursor) {
        track.addEventListener('mousemove', (e) => {
          const rect = track.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          const xPct = (x / rect.width) - 0.5;
          const yPct = (y / rect.height) - 0.5;

          wrapper.style.transform = `rotateX(${yPct * -20}deg) rotateY(${xPct * 20}deg) scale(1.05)`;
          glow.style.transform = `translate(calc(-50% + ${xPct * 60}px), calc(-50% + ${yPct * 60}px))`;
          glare.style.opacity = '1';
          glare.style.transform = `translateX(${xPct * 200}%) translateY(${yPct * 200}%)`;

          customCursor.style.opacity = '1';
          customCursor.style.left = `${e.clientX}px`;
          customCursor.style.top = `${e.clientY}px`;
        });
        track.addEventListener('mouseleave', () => {
          wrapper.style.transform = `rotateX(0deg) rotateY(0deg) scale(1)`;
          glow.style.transform = `translate(-50%, -50%)`;
          glare.style.opacity = '0';
          customCursor.style.opacity = '0';
        });
      }

      // Magnetic Button
      const btnWrapper = document.getElementById('magnetic-btn-wrapper');
      const atcBtn = document.getElementById('add-to-cart-btn');

      if (btnWrapper && atcBtn) {
        btnWrapper.addEventListener('mousemove', (e) => {
          const rect = btnWrapper.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          const pullX = (x - rect.width / 2) * 0.3;
          const pullY = (y - rect.height / 2) * 0.3;
          atcBtn.style.transform = `translate(${pullX}px, ${pullY}px)`;
        });
        btnWrapper.addEventListener('mouseleave', () => {
          atcBtn.style.transform = `translate(0px, 0px)`;
        });
      }

      // Thumbnails
      const thumbs = document.querySelectorAll('.thumb-btn');
      thumbs.forEach(b => {
        b.addEventListener('click', () => {
          const newSrc = b.getAttribute('data-src');
          if(mainImg && newSrc) {
            mainImg.style.opacity = '0';
            mainImg.style.transform = 'scale(0.95)';
            setTimeout(() => {
              mainImg.setAttribute('src', newSrc);
              mainImg.style.opacity = '1';
              mainImg.style.transform = 'scale(1)';
            }, 150);
            thumbs.forEach(t => {
              t.classList.remove('border-[#166534]', 'shadow-md', 'opacity-100');
              t.classList.add('border-transparent', 'opacity-50');
            });
            b.classList.add('border-[#166534]', 'shadow-md', 'opacity-100');
            b.classList.remove('border-transparent', 'opacity-50');
          }
        });
      });

      // Text Scramble
      const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&*";
      const scrambleElement = document.querySelector('.scramble-text');
      let scrambleInterval = null;
      if (scrambleElement) {
        const observerScramble = new IntersectionObserver((entries) => {
          if(entries[0].isIntersecting && !scrambleElement.classList.contains('scrambled')) {
            let iteration = 0;
            clearInterval(scrambleInterval);
            scrambleElement.classList.add('scrambled');
            scrambleInterval = setInterval(() => {
              scrambleElement.innerText = scrambleElement.innerText
                .split("")
                .map((letter, index) => {
                  if(index < iteration) return scrambleElement.dataset.value[index];
                  return letters[Math.floor(Math.random() * 42)];
                }).join("");
              if(iteration >= scrambleElement.dataset.value.length) clearInterval(scrambleInterval);
              iteration += 1 / 3;
            }, 30);
          }
        }, { threshold: 0.5 });
        observerScramble.observe(scrambleElement);
      }

      // Timeline Scroll
      const timelineLine = document.getElementById('timeline-progress');
      const steps = document.querySelectorAll('.timeline-step');
      
      if (timelineLine && steps.length > 0) {
        window.addEventListener('scroll', () => {
          steps.forEach((step, index) => {
            const rect = step.getBoundingClientRect();
            const dot = step.querySelector('.step-dot');
            const innerDot = step.querySelector('.step-inner-dot');
            
            if(rect.top < window.innerHeight * 0.7) {
              step.classList.remove('opacity-50');
              step.classList.add('opacity-100');
              dot.classList.replace('bg-emerald-900', 'bg-emerald-500');
              dot.classList.replace('border-[#022c22]', 'border-emerald-200');
              innerDot.classList.replace('bg-transparent', 'bg-white');
              const progress = ((index + 1) / steps.length) * 100;
              timelineLine.style.height = `${progress}%`;
            } else {
              step.classList.add('opacity-50');
              step.classList.remove('opacity-100');
              dot.classList.replace('bg-emerald-500', 'bg-emerald-900');
              dot.classList.replace('border-emerald-200', 'border-[#022c22]');
              innerDot.classList.replace('bg-white', 'bg-transparent');
            }
          });
        }, { passive: true });
      }

      // Lab Modal (100% FIXED & CRASH-PROOF)
      const labModal = document.getElementById('lab-modal');
      const openLabBtn = document.getElementById('open-lab-report');
      const closeLabBtn = document.getElementById('close-lab-modal');

      if(labModal && openLabBtn) {
        const closeModal = () => {
          labModal.classList.add('opacity-0', 'pointer-events-none');
          document.body.style.overflow = '';
        };
        openLabBtn.addEventListener('click', () => {
          labModal.classList.remove('opacity-0', 'pointer-events-none');
          document.body.style.overflow = 'hidden'; 
        });
        if (closeLabBtn) {
            closeLabBtn.addEventListener('click', closeModal);
        }
        labModal.addEventListener('click', (e) => {
          if(e.target === labModal) closeModal();
        });
      }

      // Odometer Score
      const odometerElements = document.querySelectorAll('.odometer-number');
      if (odometerElements.length > 0) {
        const observerOdometer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting && !entry.target.classList.contains('counted')) {
              entry.target.classList.add('counted');
              const target = +entry.target.getAttribute('data-target');
              const duration = 2000; 
              const step = target / (duration / 16); 
              let current = 0;
              const updateCounter = () => {
                current += step;
                if (current < target) {
                  entry.target.innerText = Math.ceil(current).toLocaleString('en-IN');
                  requestAnimationFrame(updateCounter);
                } else {
                  entry.target.innerText = target.toLocaleString('en-IN');
                }
              };
              updateCounter();
            }
          });
        }, { threshold: 0.5 });
        odometerElements.forEach(el => observerOdometer.observe(el));
      }

      // Live Toast
      const toast = document.getElementById('live-toast');
      const toastName = document.getElementById('toast-name');
      const buyers = ["Rahul from Mumbai", "Neha from Pune", "Karan from Delhi", "Anjali from Bangalore", "Vikram from Hyderabad"];

      if(toast && toastName) {
        setTimeout(() => {
          toastName.innerText = buyers[Math.floor(Math.random() * buyers.length)];
          toast.classList.remove('translate-y-[150%]', 'opacity-0');
          setTimeout(() => { toast.classList.add('translate-y-[150%]', 'opacity-0'); }, 4000);
        }, 5000);

        setInterval(() => {
          toastName.innerText = buyers[Math.floor(Math.random() * buyers.length)];
          toast.classList.remove('translate-y-[150%]', 'opacity-0');
          setTimeout(() => { toast.classList.add('translate-y-[150%]', 'opacity-0'); }, 4000);
        }, Math.floor(Math.random() * 10000) + 20000);
      }

      // ==========================================
      // PHASE 4: THE CONVERSION ENGINE (BULLETPROOF)
      // ==========================================
      const priceDisplay = document.getElementById('dynamic-price');
      const variantBtns = document.querySelectorAll('.variant-btn');

      // 1. Variant Switching Logic (जर २-३ साईझ असतील तर)
      variantBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
          variantBtns.forEach(b => {
            b.classList.remove('border-[#111827]', 'text-[#111827]', 'bg-gray-50', 'selected-variant');
            b.classList.add('border-gray-200', 'text-gray-500');
          });

          const target = e.currentTarget;
          target.classList.remove('border-gray-200', 'text-gray-500');
          target.classList.add('border-[#111827]', 'text-[#111827]', 'bg-gray-50', 'selected-variant');

          const newPrice = parseFloat(target.getAttribute('data-price')).toFixed(2);
          if(priceDisplay) {
            priceDisplay.style.opacity = '0';
            priceDisplay.style.transform = 'translateY(-5px)';
            setTimeout(() => {
              priceDisplay.innerText = `₹${newPrice}`;
              priceDisplay.style.opacity = '1';
              priceDisplay.style.transform = 'translateY(0)';
            }, 150);
          }
        });
      });

    //   // 2. Add To Cart -> Instant Checkout (१००% Safe Logic)
    //   if(atcBtn) {
    //     atcBtn.addEventListener('click', async function(e) {
    //       e.preventDefault(); 
    //       e.stopPropagation(); 
    //       console.log("--- SECURE CHECKOUT INITIATED ---");

    //       const domain = atcBtn.getAttribute('data-domain');
    //       const token = atcBtn.getAttribute('data-token');
    //       const defaultVariantId = atcBtn.getAttribute('data-default-variant');

    //       // बटण दाबल्याच्या अचूक क्षणी Variant ID शोधणे
