    //       const finalVariantId = activeVariantBtn ? activeVariantBtn.getAttribute('data-variant-id') : defaultVariantId;

    //       console.log("Final Variant ID:", finalVariantId);

    //       if(!finalVariantId || finalVariantId === 'undefined') {
    //         alert("⚠️ Error: Product Variant ID is missing! Cannot create cart.");
    //         return;
    //       }

    //       const btnText = document.getElementById('btn-text');
    //       const btnSpinner = document.getElementById('btn-spinner');

    //       // ॲनिमेशन चालू करणे
    //       atcBtn.disabled = true;
    //       if(btnText) btnText.style.opacity = '0';
    //       if(btnSpinner) btnSpinner.classList.remove('hidden');

    //       const query = `
    //         mutation cartCreate($input: CartInput!) {
    //           cartCreate(input: $input) {
    //             cart { checkoutUrl }
    //             userErrors { message }
    //           }
    //         }
    //       `;
          
    //       const variables = {
    //         input: { lines: [{ merchandiseId: finalVariantId, quantity: 1 }] }
    //       };

    //       try {
    //         const response = await fetch(`https://${domain}/api/2024-01/graphql.json`, {
    //           method: 'POST',
    //           headers: {
    //             'Content-Type': 'application/json',
    //             'X-Shopify-Storefront-Access-Token': token
    //           },
    //           body: JSON.stringify({ query, variables })
    //         });

    //         const data = await response.json();
    //         console.log("Shopify API Response:", data);

    //         const checkoutUrl = data.data?.cartCreate?.cart?.checkoutUrl;

    //         if(checkoutUrl) {
    //           console.log("✅ Cart Created! Redirecting...");
    //           window.location.href = checkoutUrl; 
    //         } else {
    //           const errorMsg = data.data?.cartCreate?.userErrors[0]?.message || "Unknown API Error";
    //           console.error("Cart Errors:", errorMsg);
    //           alert("❌ Checkout Error: " + errorMsg);
    //           resetButton();
    //         }
    //       } catch (error) {
    //         console.error("Network/API Error:", error);
    //         alert("❌ Network error. Please check your connection and try again.");
    //         resetButton();
    //       }

    //       function resetButton() {
    //         atcBtn.disabled = false;
    //         if(btnText) btnText.style.opacity = '1';
    //         if(btnSpinner) btnSpinner.classList.add('hidden');
    //       }
    //     });
    //   }
    // } // End of initProductPage

    // Guarantee execution regardless of Astro's router state
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initProductPage);
    } else {
      initProductPage();
    }
    
    // Fallback for Astro ViewTransitions
    document.addEventListener('astro:page-load', initProductPage);
  </script>

