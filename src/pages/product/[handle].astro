            </div>
          </div>

          <div class="product-details-container bg-white p-6 rounded-2xl shadow-[0_10px_30px_rgba(0,0,0,0.03)] border border-gray-100 mb-6">
            <div class="flex items-end justify-between mb-6">
              <div class="flex flex-col">
                <span class="text-[9px] font-bold tracking-[0.25em] uppercase text-gray-400 mb-1">Formulation Investment</span>
                <div class="flex items-baseline gap-1">
                  <span id="dynamic-price" class="text-3xl font-black text-[#111827] transition-all duration-300 inline-block">₹{price}</span>
                </div>
              </div>
              <div class="text-right flex flex-col items-end">
                <span class="text-[9px] font-bold uppercase tracking-widest text-[#166534] bg-[#f0fdf4] px-2 py-1 rounded mb-1">Free Delivery</span>
                <span class="text-[8px] uppercase tracking-widest text-gray-400">Taxes Included</span>
              </div>
            </div>

            {variants.length > 1 && (
              <div class="mb-6 border-t border-gray-50 pt-5">
                <span class="text-[9px] font-bold tracking-[0.25em] uppercase text-gray-400 mb-3 block">Select Size</span>
                <div class="flex flex-wrap gap-2" id="variant-selector">
                  {variants.map((v: any, i: number) => (
                    <button 
                      class={`variant-btn px-5 py-2.5 rounded-lg border-2 text-xs font-bold transition-all duration-300 ${i === 0 ? 'border-[#111827] text-[#111827] bg-gray-50 selected-variant' : 'border-gray-200 text-gray-500 hover:border-[#111827] hover:text-[#111827]'}`}
                      data-variant-id={v.id}
                      data-price={v.price.amount}
                    >
                      {v.title}
                    </button>
                  ))}
                </div>
              </div>
            )}

            {/* 🌟 Subscribe & Save 10% Option Widget */}
            <div class="mb-6 border-t border-gray-50 pt-5">
              <span class="text-[9px] font-bold tracking-[0.25em] uppercase text-gray-400 mb-3 block">Purchase Option</span>
              <div class="flex flex-col gap-3">
                {/* One-time Option */}
                <div class="purchase-option-label relative flex items-center justify-between p-4 rounded-xl border-2 border-[#111827] bg-gray-50/50 cursor-pointer transition-all duration-300 group" id="opt-one-time">
                  <div class="flex items-center gap-3">
                    <input type="radio" name="purchase_type" value="onetime" checked class="w-4 h-4 text-[#166534] focus:ring-[#166534] border-gray-300" />
                    <div class="flex flex-col">
                      <span class="text-xs font-bold text-[#111827] uppercase tracking-wider">One-time Purchase</span>
                      <span class="text-[9px] text-gray-400 uppercase tracking-widest mt-0.5">Standard single shipment</span>
                    </div>
                  </div>
                  <span class="text-sm font-black text-[#111827]" id="onetime-price-label">₹{price}</span>
                </div>
                
                {/* Subscription Option */}
                <div class="purchase-option-label relative flex items-center justify-between p-4 rounded-xl border-2 border-gray-200 cursor-pointer transition-all duration-300 hover:border-[#111827] group" id="opt-subscribe">
                  <div class="flex items-center gap-3">
                    <input type="radio" name="purchase_type" value="subscribe" class="w-4 h-4 text-[#166534] focus:ring-[#166534] border-gray-300" />
                    <div class="flex flex-col">
                      <div class="flex items-center gap-2">
                        <span class="text-xs font-bold text-[#111827] uppercase tracking-wider">Subscribe & Save</span>
                        <span class="text-[8px] bg-emerald-100 text-emerald-800 font-extrabold px-1.5 py-0.5 rounded-full uppercase tracking-wider">Save 10%</span>
                      </div>
                      <span class="text-[9px] text-gray-400 uppercase tracking-widest mt-0.5">Auto-delivers every 30 days</span>
                    </div>
                  </div>
                  <div class="flex flex-col items-end">
                    <span class="text-sm font-black text-emerald-700" id="subscribe-price-label">₹{(parseFloat(price) * 0.9).toFixed(2)}</span>
                    <span class="text-[8px] text-gray-400 line-through" id="subscribe-old-price">₹{price}</span>
                  </div>
                </div>
              </div>
            </div>

            <div class="relative w-full h-14" id="magnetic-btn-wrapper">
              <button 
                id="add-to-cart-btn" 
                type="button"
                data-domain={shopifyDomain} 
                data-token={storefrontToken}
                data-default-variant={variants[0]?.id}
                data-variant-id={variants[0]?.id}
                class="add-to-cart-btn absolute inset-0 w-full h-full bg-[#111827] text-white rounded-xl overflow-hidden group shadow-lg hover:shadow-[0_15px_30px_rgba(22,101,52,0.25)] transition-all duration-300 flex items-center justify-center gap-3 z-20 will-change-transform disabled:opacity-80 disabled:cursor-not-allowed"
              >
              
                <div class="absolute inset-0 bg-gradient-to-r from-[#166534] to-[#042f17] translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-[cubic-bezier(0.1,0,0,1)] z-0"></div>
                
                <span id="btn-text" class="relative z-10 text-xs font-bold tracking-[0.15em] uppercase flex items-center gap-2 transition-opacity duration-300">
                  Add to Routine
                  <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </span>

                <svg id="btn-spinner" class="absolute z-10 w-5 h-5 text-white animate-spin hidden" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
              </button>
            </div>
            {/* 🌟 2026 D2C Conversion Elements (Trust & Frictionless) */}
            <div class="mt-4 flex flex-col gap-4 animate-[fadeInUp_0.5s_ease-out]">
              
              <div class="flex flex-col items-center gap-2">
                <div class="flex items-center gap-1.5 opacity-65">
                  <svg class="w-3.5 h-3.5 text-emerald-800" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                  <span class="text-[9px] font-extrabold uppercase tracking-widest text-gray-600">100% Secure Checkout</span>
                </div>
                <div class="flex items-center justify-center gap-2 opacity-80 hover:opacity-100 transition-opacity duration-300">
                  {/* UPI */}
                  <div class="w-9 h-5 bg-white rounded-md flex items-center justify-center p-0.5 border border-gray-100 shadow-sm">
                     <img src="/payment/upi.svg" alt="UPI" class="w-full h-full object-contain" />
                  </div>
                  {/* GPay */}
                  <div class="w-9 h-5 bg-white rounded-md flex items-center justify-center p-0.5 border border-gray-100 shadow-sm">
                     <img src="/payment/gpay.svg" alt="Google Pay" class="w-full h-full object-contain" />
                  </div>
                  {/* PhonePe */}
                  <div class="w-9 h-5 bg-white rounded-md flex items-center justify-center p-0.5 border border-gray-100 shadow-sm">
                     <img src="/payment/phonepe.svg" alt="PhonePe" class="w-full h-full object-contain" />
                  </div>
                  {/* Paytm */}
                  <div class="w-9 h-5 bg-white rounded-md flex items-center justify-center p-0.5 border border-gray-100 shadow-sm">
                     <img src="/payment/paytm.svg" alt="Paytm" class="w-full h-full object-contain" />
                  </div>
                  {/* Visa */}
                  <div class="w-9 h-5 bg-white rounded-md flex items-center justify-center p-0.5 border border-gray-100 shadow-sm">
                     <img src="/payment/visa.svg" alt="Visa" class="w-full h-full object-contain" />
                  </div>
                  {/* Mastercard */}
                  <div class="w-9 h-5 bg-white rounded-md flex items-center justify-center p-0.5 border border-gray-100 shadow-sm">
                     <img src="/payment/mastercard.svg" alt="Mastercard" class="w-full h-full object-contain" />
                  </div>
                </div>
              </div>
              
              {/* WhatsApp Live Updates Opt-in Checkbox Layout */}
              <div class="flex items-center justify-between bg-[#25D366]/5 hover:bg-[#25D366]/10 px-4 py-3 rounded-xl border border-[#25D366]/10 hover:border-[#25D366]/30 transition-all duration-300 cursor-pointer group" id="whatsapp-toggle-container">
                <div class="flex items-center gap-2.5">
                  <svg class="w-5 h-5 text-[#25D366] transition-transform duration-300 group-hover:scale-110 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12.031 0C5.385 0 0 5.388 0 12.042c0 2.124.553 4.195 1.604 6.012L.452 24l6.104-1.601a11.964 11.964 0 005.475 1.328h.005c6.645 0 12.031-5.388 12.031-12.042C24 5.388 18.677 0 12.031 0zm5.351 17.181c-.223.633-1.282 1.206-1.768 1.246-.445.038-.971.21-3.085-.666-2.545-1.054-4.161-3.666-4.288-3.834-.127-.168-1.026-1.365-1.026-2.605 0-1.24.634-1.85 1.026-2.261.353-.372.889-.486 1.185-.486.297 0 .593.004.851.015.275.011.644-.105.992.738.356.862 1.218 2.966 1.326 3.181.107.215.178.468.03.743-.148.275-.222.446-.445.714-.222.268-.466.586-.667.828-.222.268-.458.558-.201.996.258.438 1.144 1.884 2.456 3.051 1.693 1.506 3.093 1.97 3.538 2.185.445.215.707.19 1.002-.148.297-.338 1.282-1.488 1.626-2.001.344-.513.687-.428 1.088-.275.402.153 2.541 1.196 2.977 1.41.436.215.727.322.831.5.105.178.105 1.037-.118 1.67z"></path></svg>
                  <div class="flex flex-col">
                    <span class="text-[9.5px] font-extrabold text-[#064E3B] uppercase tracking-wider">Get order updates on WhatsApp 📱</span>
                    <span class="text-[8px] text-[#064E3B]/70 uppercase tracking-widest font-bold mt-0.5">Receive order confirmation & delivery alerts</span>
                  </div>
                </div>
                <div class="w-5 h-5 rounded border-2 border-[#166534] flex items-center justify-center bg-white transition-all duration-300" id="whatsapp-checkbox">
                  <svg class="w-3.5 h-3.5 text-white scale-0 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="4"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                </div>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-3 gap-3">
            {[
              { icon: '🌿', title: '100% Vegan', sub: 'Plant-Based' },
              { icon: '🔬', title: 'Lab Tested', sub: 'Zero Toxins' },
              { icon: '⚡', title: 'Bio-Active', sub: 'High Absorption' }
            ].map(item => (
              <div class="text-center p-3 rounded-xl bg-white border border-gray-100 hover:border-[#166534]/20 transition-colors">
                <div class="text-xl mb-1.5">{item.icon}</div>
                <div class="text-[9px] font-bold text-[#111827] uppercase tracking-widest">{item.title}</div>
                <div class="text-[8px] text-gray-400 mt-0.5">{item.sub}</div>
              </div>
            ))}
          </div>

        </div>
      </div>
    </div>
  </main>

  {/* 🌟 The Sujata Purity Moat Comparative Table Section */}
  <section class="max-w-[85rem] mx-auto px-6 lg:px-12 py-16 border-t border-gray-100 z-20 relative bg-white">
    <div class="mb-10 text-center sm:text-left">
      <span class="text-emerald-800 text-[10px] font-black uppercase tracking-[0.2em] mb-2 block">The Sujata Purity Moat</span>
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-['Playfair_Display'] font-black text-[#111827] tracking-tight">
        Sujata Raw (Cold-Pressed) vs. Commercial (Heat-Processed)
      </h2>
    </div>
    
    <div class="overflow-x-auto rounded-2xl border border-gray-100 shadow-[0_10px_30px_rgba(0,0,0,0.015)]">
      <table class="w-full text-left border-collapse bg-white">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-100">
            <th class="p-5 text-xs font-bold text-gray-500 uppercase tracking-widest">Active Metric</th>
            <th class="p-5 text-xs font-black text-emerald-800 uppercase tracking-widest bg-emerald-50/50">Sujata (Raw & Cold-Pressed)</th>
            <th class="p-5 text-xs font-bold text-gray-500 uppercase tracking-widest">Commercial Brands (Heat-Processed)</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50 text-xs sm:text-sm">
          <tr class="transition-colors hover:bg-gray-50/50">
            <td class="p-5 font-bold text-gray-900">Extraction Temperature</td>
            <td class="p-5 font-bold text-emerald-700 bg-emerald-50/30">Zero Heat Cold-Pressing (&lt; 25°C)</td>
            <td class="p-5 text-gray-500">High-Heat Spray Drying (80°C - 120°C)</td>
          </tr>
          <tr class="transition-colors hover:bg-gray-50/50">
            <td class="p-5 font-bold text-gray-900">Phycocyanin Potency</td>
            <td class="p-5 font-bold text-emerald-700 bg-emerald-50/30">100% Active & Bio-Available</td>
            <td class="p-5 text-gray-500">Thermally Degraded (Loss of &gt;50%)</td>
