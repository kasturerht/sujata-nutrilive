---
import StoreLayout from '../../layouts/StoreLayout.astro';

const shopifyDomain = 'skadas-headless-demo.myshopify.com';
const storefrontToken = '32f678c5f8d1345e945ed48713d9cf2f';

const { handle } = Astro.params;

// 🌟 Updated Metafield Keys based on your Shopify Admin
const productQuery = `
  query ProductByHandle($handle: String!) {
    product(handle: $handle) {
      id title handle descriptionHtml availableForSale vendor tags
      priceRange { minVariantPrice { amount currencyCode } maxVariantPrice { amount currencyCode } }
      images(first: 10) { edges { node { url altText } } }
      variants(first: 20) { edges { node { id title availableForSale price { amount currencyCode } selectedOptions { name value } } } }
      
      ingredients: metafield(namespace: "custom", key: "active_compounds") { value }
      timeline: metafield(namespace: "custom", key: "efficacy_timeline") { value }
      labReport: metafield(namespace: "custom", key: "lab_report_pdf") { value }
    }
  }
`;

const res = await fetch(`https://${shopifyDomain}/api/2024-01/graphql.json`, {
  method: 'POST',
  headers: { 'Content-Type': 'application/json', 'X-Shopify-Storefront-Access-Token': storefrontToken },
  body: JSON.stringify({ query: productQuery, variables: { handle } }),
});

const data = await res.json();
const product = data.data?.product;

if (!product) return Astro.redirect('/store');

const images = product.images.edges.map((e: any) => e.node);
const variants = product.variants.edges.map((e: any) => e.node);
const primaryImage = images[0];

const price = parseFloat(product.priceRange.minVariantPrice.amount).toFixed(2);
const maxPrice = parseFloat(product.priceRange.maxVariantPrice.amount).toFixed(2);
const hasPriceRange = price !== maxPrice;

// JSON Parsing with Fallbacks
const ingredientsData = product.ingredients?.value ? JSON.parse(product.ingredients.value) : [];
const timelineData = product.timeline?.value ? JSON.parse(product.timeline.value) : [];
const labReportUrl = product.labReport?.value || null;
---

<StoreLayout title={`${product.title} | Sujata Premium`}>

  <div id="cinematic-reveal" class="fixed inset-0 bg-[#022c22] z-[9999] flex flex-col items-center justify-center transition-all duration-[1000ms] ease-[cubic-bezier(0.8,0,0.2,1)] pointer-events-none">
    <div class="w-12 h-[1px] bg-emerald-500/50 mb-4 animate-[pulse_1s_ease-in-out_infinite]"></div>
    <span class="text-white font-['Playfair_Display'] text-xs tracking-[0.5em] uppercase opacity-100 transition-opacity duration-500" id="reveal-text">Initializing Protocol</span>
  </div>

  <div id="scroll-progress" class="fixed top-0 left-0 h-[2px] bg-gradient-to-r from-[#166534] to-emerald-400 z-[1000] transition-all duration-75" style="width: 0%;"></div>

  <div id="custom-cursor" class="fixed w-6 h-6 rounded-full border border-[#166534] pointer-events-none z-[100] opacity-0 transition-opacity duration-300 flex items-center justify-center -translate-x-1/2 -translate-y-1/2 mix-blend-difference hidden md:flex">
    <div class="w-1 h-1 bg-[#166534] rounded-full"></div>
  </div>

  <div class="fixed top-0 left-0 right-0 z-50 bg-[#FAF9F6]/80 backdrop-blur-xl border-b border-black/[0.04]">
    <div class="max-w-[90rem] mx-auto px-6 lg:px-12 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 text-[#4B5563] hover:text-[#166534] transition-colors duration-300 group">
        <svg class="w-4 h-4 transition-transform duration-300 group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 12H5m7-7-7 7 7 7"/></svg>
        <span class="text-[10px] font-bold tracking-[0.2em] uppercase">Return to Store</span>
      </a>
      <span class="font-['Playfair_Display'] font-bold text-[#111827] text-sm hidden sm:block tracking-widest">SUJATA<span class="text-[#166534]">.</span></span>
      <div class="w-32 hidden sm:block"></div>
    </div>
  </div>

  <main class="bg-[#FAF9F6] min-h-screen pt-24 pb-12 selection:bg-[#166534] selection:text-white">
    <div class="max-w-[85rem] mx-auto px-6 lg:px-12 relative z-10">

      <nav class="flex items-center gap-3 mb-8">
        <a href="/" class="text-[9px] font-bold tracking-[0.25em] uppercase text-gray-400 hover:text-[#166534] transition-colors">Apothecary</a>
        <span class="w-8 h-[1px] bg-gray-300"></span>
        <span class="text-[9px] font-bold tracking-[0.25em] uppercase text-[#111827]">{product.title}</span>
      </nav>

      <div class="grid grid-cols-1 md:grid-cols-[1fr_400px] lg:grid-cols-[1fr_450px] gap-10 lg:gap-16 items-start">
        
        <div class="sticky top-24 space-y-4">
          <div id="premium-3d-track" class="relative w-full aspect-[4/5] md:aspect-square bg-white rounded-[2rem] overflow-hidden shadow-[0_20px_50px_rgba(0,0,0,0.03)] border border-black/[0.02] flex items-center justify-center cursor-none" style="perspective: 1500px;">
            <div id="ambient-glow" class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[75%] h-[75%] bg-emerald-500/40 rounded-full pointer-events-none transition-transform duration-150 ease-out will-change-transform blur-[90px]"></div>
            <div id="image-skeleton" class="absolute inset-0 bg-[#f8faf9] animate-pulse z-10 flex items-center justify-center transition-opacity duration-700">
              <div class="w-8 h-8 border-2 border-[#166534]/20 border-t-[#166534] rounded-full animate-spin"></div>
            </div>
            <div id="bottle-3d-wrapper" class="relative z-20 w-[70%] h-[70%] flex items-center justify-center transition-transform duration-300 ease-out will-change-transform">
                <img id="main-pdp-image" src={primaryImage?.url || '/spirulina-bottle.png'} alt={product.title} class="relative z-20 w-full h-full object-contain drop-shadow-[0_25px_40px_rgba(0,0,0,0.15)] transition-all duration-500 ease-out" onload="document.getElementById('image-skeleton').style.opacity='0'; document.getElementById('image-skeleton').style.pointerEvents='none';" />
                <div id="bottle-glare" class="absolute inset-0 bg-gradient-to-tr from-transparent via-white/50 to-transparent opacity-0 mix-blend-overlay pointer-events-none rounded-full transition-opacity duration-300 transform -translate-x-[100%]"></div>
            </div>
            <div class="absolute top-4 left-4 z-30 pointer-events-none">
              <span class="bg-white/90 backdrop-blur border border-gray-100 text-[#166534] text-[9px] font-black uppercase tracking-widest px-3 py-1.5 rounded-full shadow-sm flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-[#166534] animate-pulse"></span>Clinical Grade
              </span>
            </div>
          </div>

          {images.length > 1 && (
            <div class="flex gap-3 overflow-x-auto pb-2 scrollbar-hide">
              {images.map((img: any, i: number) => (
                <button class={`thumb-btn flex-shrink-0 w-16 h-16 rounded-xl overflow-hidden border transition-all duration-300 ${i === 0 ? 'border-[#166534] shadow-md opacity-100' : 'border-transparent opacity-50 hover:opacity-100 hover:border-[#166534]/30'}`} data-src={img.url}>
                  <img src={img.url} alt="thumbnail" class="w-full h-full object-contain bg-white p-2" />
                </button>
              ))}
            </div>
          )}
        </div>

        <div class="flex flex-col pt-2 lg:pt-4">
          <h1 class="text-3xl md:text-4xl lg:text-[2.75rem] font-['Playfair_Display'] font-black text-[#111827] leading-[1.1] tracking-tight mb-3">
            {product.title}
          </h1>
          <div class="text-gray-500 text-sm font-light leading-relaxed mb-6 prose-sm [&_strong]:text-[#111827] [&_strong]:font-bold line-clamp-3" set:html={product.descriptionHtml} />

          <div class="flex flex-col gap-2 mb-6 border border-emerald-900/10 bg-[#f0fdf4]/50 p-3 rounded-xl">
            <div class="flex items-center gap-2">
              <span class="relative flex h-2 w-2"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-500 opacity-75"></span><span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-600"></span></span>
              <span class="text-[9px] font-bold uppercase tracking-widest text-emerald-950">High Demand: <span class="text-[#166534]">Only 14 Batches Left</span></span>
            </div>
            <div class="flex items-center gap-2 text-[9px] uppercase tracking-widest text-gray-500 font-bold">
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              Order within <span class="text-gray-900 font-black" id="countdown-timer">02:14:00</span> for priority dispatch
            </div>
          </div>

          <div class="bg-white p-6 rounded-2xl shadow-[0_10px_30px_rgba(0,0,0,0.03)] border border-gray-100 mb-6">
            <div class="flex items-end justify-between mb-6">
              <div class="flex flex-col">
                <span class="text-[9px] font-bold tracking-[0.25em] uppercase text-gray-400 mb-1">Formulation Investment</span>
                <div class="flex items-baseline gap-1">
                  <span id="dynamic-price" class="text-3xl font-black text-[#111827] transition-all duration-300 inline-block">₹{price}</span>
                </div>
              </div>
              <div class="text-right flex flex-col items-end">
                <span class="text-[9px] font-bold uppercase tracking-widest text-[#166534] bg-[#f0fdf4] px-2 py-1 rounded mb-1">Free Delivery</span>
                <span class="text-[8px] uppercase tracking-widest text-gray-400">Taxes Included</span>
              </div>
            </div>

            {variants.length > 1 && (
              <div class="mb-6 border-t border-gray-50 pt-5">
                <span class="text-[9px] font-bold tracking-[0.25em] uppercase text-gray-400 mb-3 block">Select Size</span>
                <div class="flex flex-wrap gap-2" id="variant-selector">
                  {variants.map((v: any, i: number) => (
                    <button 
                      class={`variant-btn px-5 py-2.5 rounded-lg border-2 text-xs font-bold transition-all duration-300 ${i === 0 ? 'border-[#111827] text-[#111827] bg-gray-50 selected-variant' : 'border-gray-200 text-gray-500 hover:border-[#111827] hover:text-[#111827]'}`}
                      data-variant-id={v.id}
                      data-price={v.price.amount}
                    >
                      {v.title}
                    </button>
                  ))}
                </div>
              </div>
            )}

            <div class="relative w-full h-14" id="magnetic-btn-wrapper">
              <button 
                id="add-to-cart-btn" 
                type="button"
                data-domain={shopifyDomain} 
                data-token={storefrontToken}
                data-default-variant={variants[0]?.id}
                class="absolute inset-0 w-full h-full bg-[#111827] text-white rounded-xl overflow-hidden group shadow-lg hover:shadow-[0_15px_30px_rgba(22,101,52,0.25)] transition-all duration-300 flex items-center justify-center gap-3 z-20 will-change-transform disabled:opacity-80 disabled:cursor-not-allowed"
              >
              
                <div class="absolute inset-0 bg-gradient-to-r from-[#166534] to-[#042f17] translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-[cubic-bezier(0.1,0,0,1)] z-0"></div>
                
                <span id="btn-text" class="relative z-10 text-xs font-bold tracking-[0.15em] uppercase flex items-center gap-2 transition-opacity duration-300">
                  Secure Checkout
                  <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                </span>

                <svg id="btn-spinner" class="absolute z-10 w-5 h-5 text-white animate-spin hidden" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
              </button>
            </div>
            {/* 🌟 2026 D2C Conversion Elements (Trust & Frictionless) */}
            <div class="mt-4 flex flex-col gap-3 animate-[fadeInUp_0.5s_ease-out]">
              
              <div class="flex items-center justify-center gap-3 opacity-60 grayscale">
                <span class="text-[9px] font-bold uppercase tracking-widest text-gray-500">100% Secure 256-Bit Checkout</span>
                <span class="w-1 h-1 rounded-full bg-gray-400"></span>
                <span class="text-[9px] font-bold uppercase tracking-widest text-gray-500">UPI & Cards Accepted</span>
              </div>
              
              <div class="flex items-center justify-center gap-2 bg-[#25D366]/10 py-2 rounded-lg border border-[#25D366]/20">
                <svg class="w-4 h-4 text-[#25D366]" fill="currentColor" viewBox="0 0 24 24"><path d="M12.031 0C5.385 0 0 5.388 0 12.042c0 2.124.553 4.195 1.604 6.012L.452 24l6.104-1.601a11.964 11.964 0 005.475 1.328h.005c6.645 0 12.031-5.388 12.031-12.042C24 5.388 18.677 0 12.031 0zm5.351 17.181c-.223.633-1.282 1.206-1.768 1.246-.445.038-.971.21-3.085-.666-2.545-1.054-4.161-3.666-4.288-3.834-.127-.168-1.026-1.365-1.026-2.605 0-1.24.634-1.85 1.026-2.261.353-.372.889-.486 1.185-.486.297 0 .593.004.851.015.275.011.644-.105.992.738.356.862 1.218 2.966 1.326 3.181.107.215.178.468.03.743-.148.275-.222.446-.445.714-.222.268-.466.586-.667.828-.222.268-.458.558-.201.996.258.438 1.144 1.884 2.456 3.051 1.693 1.506 3.093 1.97 3.538 2.185.445.215.707.19 1.002-.148.297-.338 1.282-1.488 1.626-2.001.344-.513.687-.428 1.088-.275.402.153 2.541 1.196 2.977 1.41.436.215.727.322.831.5.105.178.105 1.037-.118 1.67z"></path></svg>
                <span class="text-[9px] font-bold text-[#111827] uppercase tracking-wider">Live Order Updates on WhatsApp</span>
              </div>
              
            </div>
          </div>

          <div class="grid grid-cols-3 gap-3">
            {[
              { icon: '🌿', title: '100% Vegan', sub: 'Plant-Based' },
              { icon: '🔬', title: 'Lab Tested', sub: 'Zero Toxins' },
              { icon: '⚡', title: 'Bio-Active', sub: 'High Absorption' }
            ].map(item => (
              <div class="text-center p-3 rounded-xl bg-white border border-gray-100 hover:border-[#166534]/20 transition-colors">
                <div class="text-xl mb-1.5">{item.icon}</div>
                <div class="text-[9px] font-bold text-[#111827] uppercase tracking-widest">{item.title}</div>
                <div class="text-[8px] text-gray-400 mt-0.5">{item.sub}</div>
              </div>
            ))}
          </div>

        </div>
      </div>
    </div>
  </main>

  <section id="science-dossier" class="relative bg-[#022c22] text-white py-20 md:py-24 overflow-hidden z-20 border-t border-emerald-900/30">
    <div class="absolute top-[-10%] right-[-10%] w-[50vw] h-[50vw] bg-[radial-gradient(circle_at_50%_50%,#064e3b_0%,transparent_70%)] opacity-60 mix-blend-screen pointer-events-none blur-[100px]"></div>
    <div class="absolute bottom-[-10%] left-[-10%] w-[40vw] h-[40vw] bg-[radial-gradient(circle_at_50%_50%,#047857_0%,transparent_70%)] opacity-30 mix-blend-screen pointer-events-none blur-[120px]"></div>

    <div class="max-w-[85rem] mx-auto px-6 lg:px-12 relative z-10">
      
      <div class="mb-16 max-w-3xl">
        <div class="inline-flex items-center gap-3 mb-4">
          <span class="w-8 h-[1px] bg-emerald-500/50"></span>
          <span class="text-emerald-400 font-mono text-[9px] tracking-[0.3em] uppercase">Architecture of Purity</span>
        </div>
        <h2 class="scramble-text text-3xl md:text-[3.5rem] font-['Playfair_Display'] font-black text-white leading-[1.05] tracking-tight" data-value="THE CLINICAL DOSSIER.">
          THE CLINICAL DOSSIER.
        </h2>
        <p class="mt-6 text-emerald-100/70 font-light text-sm leading-relaxed max-w-xl">
          We stripped away the marketing fluff. Here is the exact scientific breakdown of what happens at a cellular level when you consume our cold-pressed extraction.
        </p>
      </div>

      <div class="mb-20">
        <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-emerald-500 mb-6 flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
          Active Compounds
        </h3>
        
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4" id="ingredient-grid">
          {ingredientsData.map((item: any) => (
            <div class={`ingredient-box relative p-5 md:p-6 rounded-2xl border border-white/5 bg-white/[0.02] backdrop-blur-sm transition-all duration-500 hover:bg-white/[0.05] hover:${item.border} group cursor-crosshair overflow-hidden`}>
              <div class="absolute top-0 right-0 p-4 opacity-10 font-['Playfair_Display'] font-black text-5xl transition-opacity duration-500 group-hover:opacity-20">{item.symbol}</div>
              <div class={`text-xl md:text-2xl font-bold mb-1 ${item.color}`}>{item.symbol}</div>
              <div class="text-[9px] md:text-[10px] font-bold uppercase tracking-widest text-white mb-3">{item.name}</div>
              <div class="text-[10px] text-emerald-100/70 leading-relaxed font-light opacity-0 translate-y-2 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 ease-out">
                {item.desc}
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">
        <div class="relative pl-6 md:pl-10">
          <div class="absolute top-0 bottom-0 left-[11px] md:left-[19px] w-[1px] bg-emerald-900/50">
            <div id="timeline-progress" class="absolute top-0 left-0 w-full bg-emerald-400 shadow-[0_0_15px_#34d399] transition-all duration-1000 ease-out" style="height: 0%;"></div>
          </div>
          <div class="space-y-12 md:space-y-14">
            {timelineData.map((step: any, i: number) => (
              <div class="timeline-step relative opacity-50 transition-opacity duration-700">
                <div class="absolute -left-[35px] md:-left-[43px] top-1 w-3 h-3 md:w-4 md:h-4 rounded-full border-2 border-[#022c22] bg-emerald-900 flex items-center justify-center z-10 transition-colors duration-500 step-dot">
                  <div class="w-1 h-1 md:w-1.5 md:h-1.5 rounded-full bg-transparent transition-colors duration-500 step-inner-dot"></div>
                </div>
                <span class="text-emerald-500 font-mono text-[8px] md:text-[9px] tracking-[0.2em] uppercase block mb-1">{step.time}</span>
                <h4 class="text-xl md:text-2xl font-['Playfair_Display'] font-bold text-white mb-2">{step.title}</h4>
                <p class="text-emerald-100/70 text-xs md:text-sm font-light leading-relaxed max-w-sm">{step.desc}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="bg-white/[0.03] border border-white/5 p-8 rounded-2xl backdrop-blur-md">
          <h3 class="text-lg font-bold text-white mb-3">We prove our purity.</h3>
          <p class="text-emerald-100/70 text-xs font-light leading-relaxed mb-6">
            Every batch of Sujata Spirulina undergoes rigorous third-party testing for heavy metals and toxins.
          </p>
          <div class="space-y-3 mb-8">
            <div class="flex items-center justify-between border-b border-emerald-900/30 pb-2"><span class="text-[10px] text-gray-400">Lead (Pb)</span><span class="text-[10px] font-bold text-emerald-400">Undetected</span></div>
            <div class="flex items-center justify-between border-b border-emerald-900/30 pb-2"><span class="text-[10px] text-gray-400">Mercury (Hg)</span><span class="text-[10px] font-bold text-emerald-400">Undetected</span></div>
          </div>
          <button id="open-lab-report" class="w-full relative group overflow-hidden rounded-xl bg-emerald-950/30 border border-emerald-500/20 py-3.5 flex items-center justify-center gap-2 transition-all duration-500 hover:bg-emerald-900/50 hover:border-emerald-500/50 hover:shadow-[0_0_20px_rgba(16,185,129,0.15)]">
            <svg class="w-4 h-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-white">View Official Lab Report</span>
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/5 to-transparent -translate-x-full group-hover:animate-[shimmer_1.5s_infinite]"></div>
          </button>
        </div>
      </div>
    </div>
  </section>

  <section id="the-cult-section" class="relative bg-[#FAF9F6] py-24 md:py-32 overflow-hidden z-20 border-t border-black/[0.03]">
    <div class="absolute top-0 left-0 w-full h-[300px] bg-gradient-to-b from-[#f0fdf4] to-transparent opacity-50 pointer-events-none"></div>

    <div class="max-w-[85rem] mx-auto px-6 lg:px-12 relative z-10">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-8">
        <div class="max-w-2xl">
          <div class="inline-flex items-center gap-3 mb-4">
            <span class="w-8 h-[1px] bg-[#166534]/30"></span>
            <span class="text-[#166534] font-mono text-[9px] tracking-[0.3em] uppercase font-bold">Verified Efficacy</span>
          </div>
          <h2 class="text-3xl md:text-[3.5rem] font-['Playfair_Display'] font-black text-[#111827] leading-[1.05] tracking-tight">
            Join the top 1% <br/> <span class="italic text-gray-400 font-light">high performers.</span>
          </h2>
        </div>
        <div class="md:text-right flex flex-col md:items-end">
          <div class="flex items-center gap-2 mb-2">
