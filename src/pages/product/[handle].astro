---
import StoreLayout from '../../layouts/StoreLayout.astro';

const shopifyDomain = import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_DOMAIN || "skadas-headless-demo.myshopify.com";
const storefrontToken = import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_TOKEN || "32f678c5f8d1345e945ed48713d9cf2f";

const { handle } = Astro.params;

// 🌟 Updated Metafield Keys based on your Shopify Admin
const productQuery = `
  query ProductByHandle($handle: String!) {
    product(handle: $handle) {
      id title handle descriptionHtml availableForSale vendor tags
      priceRange { minVariantPrice { amount currencyCode } maxVariantPrice { amount currencyCode } }
      images(first: 10) { edges { node { url altText } } }
      variants(first: 20) { edges { node { id title availableForSale price { amount currencyCode } selectedOptions { name value } } } }
      
      ingredients: metafield(namespace: "custom", key: "active_compounds") { value }
      timeline: metafield(namespace: "custom", key: "efficacy_timeline") { value }
      labReport: metafield(namespace: "custom", key: "lab_report_pdf") { value }
    }
  }
`;

let product = null;
try {
  if (shopifyDomain && storefrontToken) {
    const res = await fetch(`https://${shopifyDomain}/api/2024-01/graphql.json`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Shopify-Storefront-Access-Token': storefrontToken },
      body: JSON.stringify({ query: productQuery, variables: { handle } }),
    });

    const data = await res.json();
    product = data.data?.product;
  } else {
    console.warn("⚠️ Shopify credentials missing! Please configure PUBLIC_SHOPIFY_STOREFRONT_DOMAIN and PUBLIC_SHOPIFY_STOREFRONT_TOKEN.");
  }
} catch (error) {
  console.error("❌ Failed to fetch product details from Shopify:", error);
}

if (!product) return Astro.redirect('/');

const images = product.images?.edges.map((e: any) => e.node) || [];
const variants = product.variants?.edges.map((e: any) => e.node) || [];
const primaryImage = images[0];

const price = product.priceRange ? parseFloat(product.priceRange.minVariantPrice.amount).toFixed(2) : "0.00";
const maxPrice = product.priceRange ? parseFloat(product.priceRange.maxVariantPrice.amount).toFixed(2) : "0.00";
const hasPriceRange = price !== maxPrice;

// JSON Parsing with Fallbacks
const ingredientsData = product.ingredients?.value ? JSON.parse(product.ingredients.value) : [];
const timelineData = product.timeline?.value ? JSON.parse(product.timeline.value) : [];
const labReportUrl = product.labReport?.value || null;
---

<StoreLayout title={`${product.title} | Sujata Premium`}>

  <div id="cinematic-reveal" class="fixed inset-0 bg-[#022c22] z-[9999] flex flex-col items-center justify-center transition-all duration-[1000ms] ease-[cubic-bezier(0.8,0,0.2,1)] pointer-events-none">
    <div class="w-12 h-[1px] bg-emerald-500/50 mb-4 animate-[pulse_1s_ease-in-out_infinite]"></div>
    <span class="text-white font-['Playfair_Display'] text-xs tracking-[0.5em] uppercase opacity-100 transition-opacity duration-500" id="reveal-text">Initializing Protocol</span>
  </div>

  <div id="scroll-progress" class="fixed top-0 left-0 h-[2px] bg-gradient-to-r from-[#166534] to-emerald-400 z-[1000] transition-all duration-75" style="width: 0%;"></div>

  <div id="custom-cursor" class="fixed w-6 h-6 rounded-full border border-[#166534] pointer-events-none z-[100] opacity-0 transition-opacity duration-300 flex items-center justify-center -translate-x-1/2 -translate-y-1/2 mix-blend-difference hidden md:flex">
    <div class="w-1 h-1 bg-[#166534] rounded-full"></div>
  </div>

  <div class="fixed top-0 left-0 right-0 z-50 bg-[#FAF9F6]/80 backdrop-blur-xl border-b border-black/[0.04]">
    <div class="max-w-[90rem] mx-auto px-6 lg:px-12 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 text-[#4B5563] hover:text-[#166534] transition-colors duration-300 group">
        <svg class="w-4 h-4 transition-transform duration-300 group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 12H5m7-7-7 7 7 7"/></svg>
        <span class="text-[10px] font-bold tracking-[0.2em] uppercase">Return to Store</span>
      </a>
      <span class="font-['Playfair_Display'] font-bold text-[#111827] text-sm hidden sm:block tracking-widest">SUJATA<span class="text-[#166534]">.</span></span>
      <div class="w-32 hidden sm:block"></div>
    </div>
  </div>

  <main class="bg-[#FAF9F6] min-h-screen pt-24 pb-12 selection:bg-[#166534] selection:text-white">
    <div class="max-w-[85rem] mx-auto px-6 lg:px-12 relative z-10">

      <nav class="flex items-center gap-3 mb-8">
        <a href="/" class="text-[9px] font-bold tracking-[0.25em] uppercase text-gray-400 hover:text-[#166534] transition-colors">Apothecary</a>
        <span class="w-8 h-[1px] bg-gray-300"></span>
        <span class="text-[9px] font-bold tracking-[0.25em] uppercase text-[#111827]">{product.title}</span>
      </nav>

      <div class="grid grid-cols-1 md:grid-cols-[1fr_400px] lg:grid-cols-[1fr_450px] gap-10 lg:gap-16 items-start">
        
        <div class="md:sticky md:top-24 space-y-4">
          <div id="premium-3d-track" class="relative w-full aspect-[4/5] md:aspect-square bg-white rounded-[2rem] overflow-hidden shadow-[0_20px_50px_rgba(0,0,0,0.03)] border border-black/[0.02] flex items-center justify-center cursor-none" style="perspective: 1500px;">
            <div id="ambient-glow" class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[75%] h-[75%] bg-emerald-500/40 rounded-full pointer-events-none transition-transform duration-150 ease-out will-change-transform blur-[90px]"></div>
            <div id="image-skeleton" class="absolute inset-0 bg-[#f8faf9] animate-pulse z-10 flex items-center justify-center transition-opacity duration-700">
              <div class="w-8 h-8 border-2 border-[#166534]/20 border-t-[#166534] rounded-full animate-spin"></div>
            </div>
            <div id="bottle-3d-wrapper" class="relative z-20 w-[70%] h-[70%] flex items-center justify-center transition-transform duration-300 ease-out will-change-transform">
                <img id="main-pdp-image" src={primaryImage?.url || '/spirulina-bottle.png'} alt={product.title} class="relative z-20 w-full h-full object-contain drop-shadow-[0_25px_40px_rgba(0,0,0,0.15)] transition-all duration-500 ease-out" onload="document.getElementById('image-skeleton').style.opacity='0'; document.getElementById('image-skeleton').style.pointerEvents='none';" />
