---
import StoreLayout from '../layouts/StoreLayout.astro';
import StoreHeader from '../components/StoreHeader.astro';
import StoreHero from '../components/StoreHero.astro';
import StoreProducts from '../components/StoreProducts.astro';
import CartDrawer from '../components/CartDrawer.astro';

// १. तुझे Shopify डिटेल्स
const shopifyDomain = 'skadas-headless-demo.myshopify.com'; 
const storefrontToken = '32f678c5f8d1345e945ed48713d9cf2f'; 

// २. संपूर्ण GraphQL Query
// index.astro madhla tuza query block asa update kar:
const query = `
  {
    products(first: 6) {
      edges {
        node {
          id
          handle
          title
          description
          availableForSale
          priceRange {
            minVariantPrice {
              amount
              currencyCode
            }
          }
          variants(first: 1) {
            edges {
              node {
                id
              }
            }
          }
          images(first: 2) {
            edges {
              node {
                url
                altText
              }
            }
          }
        }
      }
    }
  }
`;

// ३. Server-side Fetch
const response = await fetch(`https://${shopifyDomain}/api/2024-01/graphql.json`, {
  method: 'POST',
  headers: {
    'Content-Type': 'application/json',
    'X-Shopify-Storefront-Access-Token': storefrontToken,
  },
  body: JSON.stringify({ query }),
});

const json = await response.json();
const products = json.data?.products?.edges || [];
---

<StoreLayout title="Skadas | Organic Spirulina">
  
  <StoreHeader />
  
  <StoreHero />
  
  <StoreProducts products={products} />
  <main class="bg-[#FAF9F6] relative z-10 pb-24 md:pb-40 overflow-hidden" id="product-ecosystem">
    
    <div class="absolute inset-0 bg-[url('/noise.svg')] opacity-[0.02] pointer-events-none z-0"></div>
    <div class="absolute top-0 w-full h-[1px] bg-gradient-to-r from-transparent via-[#166534]/10 to-transparent"></div>

    <div class="max-w-[90rem] mx-auto px-6 lg:px-12 relative z-10">
      
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 md:mb-20 pt-16">
        <div class="max-w-2xl relative w-full">
          <div class="absolute -left-6 -top-6 w-24 h-24 bg-[#E8F3ED] rounded-full blur-2xl z-0"></div>
          
          <h2 class="text-[clamp(2.5rem,6vw,5rem)] leading-[1.05] font-['Playfair_Display'] font-black text-[#111827] mb-4 relative z-10 tracking-tight">
            Our <br class="hidden sm:block"/>
            <span class="text-[#166534] italic font-medium">Formulations.</span>
          </h2>
          <p class="text-[#4B5563] text-base md:text-lg font-light max-w-md leading-relaxed relative z-10">
            Crafted with obsessive attention to purity. Zero fillers, uncompromising quality.
          </p>
        </div>
        
        <div class="flex overflow-x-auto gap-6 sm:gap-8 mt-8 md:mt-0 border-b border-[#E5E7EB] pb-2 w-full md:w-auto scrollbar-hide">
          <button class="text-[10px] md:text-xs font-bold tracking-[0.2em] uppercase text-[#111827] relative whitespace-nowrap after:content-[''] after:absolute after:-bottom-[9px] after:left-0 after:w-full after:h-[2px] after:bg-[#166534]">Pure Powders</button>
          <button class="text-[10px] md:text-xs font-bold tracking-[0.2em] uppercase text-[#9CA3AF] hover:text-[#111827] transition-colors relative whitespace-nowrap">Capsules</button>
          <button class="text-[10px] md:text-xs font-bold tracking-[0.2em] uppercase text-[#9CA3AF] hover:text-[#111827] transition-colors relative whitespace-nowrap">Bundles</button>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-10 justify-items-center">
        
        {products.map(({ node }) => (
          <a href={`/product/${node.handle}`} class="magnetic-card-wrapper perspective-[2000px] h-full w-full max-w-[380px] block">
            <div class="magnetic-card group relative bg-white rounded-[2rem] p-4 md:p-5 shadow-[0_10px_30px_rgba(0,0,0,0.03)] hover:shadow-[0_40px_80px_rgba(22,101,52,0.08)] transition-all duration-700 ease-out flex flex-col h-full border border-white hover:border-[#F2F7F4] transform-style-3d">
              
              <div class="relative w-full aspect-square md:aspect-[4/5] max-h-[280px] bg-[#FAF9F6] rounded-3xl mb-5 flex items-center justify-center overflow-hidden p-6">
                
                <div class="absolute inset-0 bg-gradient-to-tr from-[#E8F3ED]/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

                {node.images.edges[0] ? (
                  <img 
                    src={node.images.edges[0].node.url} 
                    alt={node.title} 
                    class="w-full h-full object-contain drop-shadow-[0_15px_25px_rgba(0,0,0,0.08)] transform transition-transform duration-1000 ease-out lg:group-hover:scale-110 lg:group-hover:-translate-y-2 relative z-10" 
                  />
                ) : (
                  <div class="text-[#9CA3AF] font-mono text-xs tracking-widest uppercase">No Image</div>
                )}

                <div class="hidden lg:flex absolute inset-0 bg-white/50 backdrop-blur-md opacity-0 group-hover:opacity-100 transition-all duration-500 z-20 flex-col items-center justify-center p-4 translate-y-4 group-hover:translate-y-0">
                  <div class="bg-white/90 px-5 py-6 rounded-2xl shadow-xl border border-white/50 w-[85%] transform scale-95 group-hover:scale-100 transition-transform duration-500 delay-100">
                    <p class="text-[9px] font-bold tracking-[0.2em] text-[#166534] uppercase mb-3 text-center border-b border-[#166534]/10 pb-2">The Formula</p>
                    <ul class="space-y-2">
                      <li class="flex items-center gap-2 text-[11px] font-semibold text-[#111827]">
                        <svg class="w-3 h-3 text-[#166534]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                        100% Organic
                      </li>
                      <li class="flex items-center gap-2 text-[11px] font-semibold text-[#111827]">
                        <svg class="w-3 h-3 text-[#166534]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                        Vegan Protein
                      </li>
                      <li class="flex items-center gap-2 text-[11px] font-semibold text-[#111827]">
                        <svg class="w-3 h-3 text-[#166534]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                        Cold-pressed
                      </li>
                    </ul>
                  </div>
                </div>

                <div class="absolute top-4 left-4 z-30">
                  <span class={`text-[8px] font-bold tracking-[0.2em] uppercase px-2.5 py-1 rounded-full shadow-sm ${node.availableForSale ? 'bg-white text-[#166534]' : 'bg-red-50 text-red-600'}`}>
                    {node.availableForSale ? 'In Stock' : 'Sold Out'}
                  </span>
                </div>
              </div>
              
              <div class="px-1 md:px-2 pb-1 flex flex-col flex-grow relative z-30">
                
                <div class="flex items-center gap-1 mb-2.5">
                  {[...Array(5)].map((_) => (
                    <svg class="w-3 h-3 text-[#F59E0B] fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                  ))}
                  <span class="text-[9px] text-[#6B7280] ml-1 font-semibold uppercase tracking-wider">124 Reviews</span>
                </div>

                <h3 class="text-[clamp(1.25rem,2.5vw,1.5rem)] font-['Playfair_Display'] font-bold text-[#111827] mb-2 group-hover:text-[#166534] transition-colors leading-[1.2] line-clamp-2">
                  {node.title}
                </h3>
                <p class="text-[#6B7280] text-sm font-light line-clamp-2 leading-relaxed mb-6">
                  {node.description}
                </p>
                
                <div class="mt-auto flex items-center justify-between pt-4 border-t border-black/[0.04] md:border-none md:pt-0">
                  
                  <div class="flex flex-col">
                    <span class="text-[9px] tracking-[0.1em] font-semibold uppercase text-[#9CA3AF] mb-0.5">Price</span>
                    <p class="text-xl font-bold text-[#111827] leading-none">
                      <span class="text-sm font-medium text-[#6B7280] pr-1">{node.priceRange.minVariantPrice.currencyCode}</span>{node.priceRange.minVariantPrice.amount}
                    </p>
                  </div>
                  
                  <button 
                    class="relative overflow-hidden h-11 md:h-12 flex-1 md:flex-none ml-6 md:ml-0 md:w-12 md:group-hover:w-36 bg-[#166534] md:bg-[#F2F7F4] hover:bg-[#14532D] md:hover:bg-[#166534] text-white md:text-[#166534] md:hover:text-white rounded-full transition-all duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] flex items-center justify-center md:justify-start shadow-md md:shadow-sm md:hover:shadow-lg disabled:opacity-50 disabled:cursor-not-allowed"
                    disabled={!node.availableForSale}
                  >
                    <div class="hidden md:flex absolute left-0 w-12 h-12 items-center justify-center">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                      </svg>
                    </div>
                    <span class="md:pl-12 text-sm md:text-xs font-bold whitespace-nowrap md:opacity-0 md:group-hover:opacity-100 transition-opacity duration-500 md:delay-100">
                      Add to Cart
                    </span>
                  </button>

                </div>

              </div>
            </div>
          </a>
        ))}

      </div>
    </div>
  </main>

  <CartDrawer />

  <script>
    // Original Silicon Valley Magnetic Script - Kept exactly intact
    document.addEventListener('DOMContentLoaded', () => {
      const cards = document.querySelectorAll('.magnetic-card-wrapper');
      if (window.matchMedia("(min-width: 1024px)").matches) {
        cards.forEach(wrapper => {
          const card = wrapper.querySelector('.magnetic-card');
          
          wrapper.addEventListener('mousemove', (e) => {
            const rect = wrapper.getBoundingClientRect();
            const x = (e.clientX - rect.left - rect.width / 2) / (rect.width / 2);
            const y = (e.clientY - rect.top - rect.height / 2) / (rect.height / 2);
            
            const rotateX = y * -8;
            const rotateY = x * 8;
            
            card.style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
          });

          wrapper.addEventListener('mouseleave', () => {
            card.style.transform = `rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)`;
          });
        });
      }
    });
  </script>
</StoreLayout>