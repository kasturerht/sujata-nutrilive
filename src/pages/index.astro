---
import StoreLayout from '../layouts/StoreLayout.astro';
import StoreHeader from '../components/StoreHeader.astro';
import StoreHero from '../components/StoreHero.astro';
import StoreGoals from '../components/StoreGoals.astro';
import StoreProducts from '../components/StoreProducts.astro';
import StoreTrustBadges from '../components/StoreTrustBadges.astro';
import StoreQuiz from '../components/StoreQuiz.astro';
import StoreConviction from '../components/StoreConviction.astro';
import StoreSocialProof from '../components/StoreSocialProof.astro';
import StoreTrustFAQ from '../components/StoreTrustFAQ.astro';
import StoreFooter from '../components/StoreFooter.astro';
import StoreProtocol from '../components/StoreProtocol.astro';
import CartDrawer from '../components/CartDrawer.astro';
import ExitPopup from '../components/ExitPopup.astro';

// New conversion modules
import StoreMedia from '../components/StoreMedia.astro';
import StoreProductBreakdown from '../components/StoreProductBreakdown.astro';
import StoreBundles from '../components/StoreBundles.astro';


// १. तुझे Shopify डिटेल्स
const shopifyDomain = import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_DOMAIN || "skadas-headless-demo.myshopify.com"; 
const storefrontToken = import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_TOKEN || "32f678c5f8d1345e945ed48713d9cf2f"; 

// २. संपूर्ण GraphQL Query
const query = `
  {
    products(first: 6) {
      edges {
        node {
          id
          handle
          title
          description
          availableForSale
          priceRange {
            minVariantPrice {
              amount
              currencyCode
            }
          }
          variants(first: 1) {
            edges {
              node {
                id
              }
            }
          }
          images(first: 2) {
            edges {
              node {
                url
                altText
              }
            }
          }
        }
      }
    }
  }
`;

// ३. Server-side Fetch with safe handling
let products = [];
try {
  if (shopifyDomain && storefrontToken) {
    const response = await fetch(`https://${shopifyDomain}/api/2024-01/graphql.json`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Shopify-Storefront-Access-Token': storefrontToken,
      },
      body: JSON.stringify({ query }),
    });

    const json = await response.json();
    products = json.data?.products?.edges || [];
  } else {
    console.warn("⚠️ Shopify credentials missing! Please configure PUBLIC_SHOPIFY_STOREFRONT_DOMAIN and PUBLIC_SHOPIFY_STOREFRONT_TOKEN.");
  }
} catch (error) {
  console.error("❌ Failed to fetch products from Shopify:", error);
}
---

<StoreLayout title="Sujata Nutrilive | Absolute Peak">
  
  <StoreHeader />
  
  {/* 1. The Hook */}
  <StoreHero />

  {/* 🌟 NEW: Media authority strip */}
  <StoreMedia />

  {/* 🌟 The Guidance (व्हिजिटरला दिशा दाखवणारा सेक्शन) */}
  <StoreGoals />
  
  {/* 2. The Product (Bento Box) */}
  <StoreProducts products={products} />

  {/* 🌟 NEW: High-AOV Combos & Bundles */}
  <StoreBundles />

  {/* 🌟 Trust Signals */}
  <StoreTrustBadges />

  {/* 🌟 NEW: Product breakdown instead of scroll science */}
  <StoreProductBreakdown />

  {/* 🌟 Apothecary Quiz & Doctor Consultation Bento Hub */}
  <StoreQuiz />

  {/* 3. The Conviction & Comparison Matrix */}
  <StoreConviction />

  {/* 5. The 30-Day Protocol Stacking cards */}
  <StoreProtocol />

  {/* 7. Symmetrical Customer Proof */}
  <StoreSocialProof />
  
  {/* 8. Trust FAQ */}
  <StoreTrustFAQ />

  {/* 9. Page Footer */}
  <StoreFooter />

  {/* Background Services */}
  <ExitPopup />

</StoreLayout>