---
// src/layouts/StoreLayout.astro
import CartDrawer from '../components/CartDrawer.astro';
const { title = "Sujata Nutrilive | Premium Spirulina" } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="Sujata Nutrilive – Premium cold-pressed Spirulina supplements. Lab-tested, 100% pure. Boost energy, immunity, and mental clarity with nature's most nutrient-dense superfood." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600;700&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-[#FAF9F6] text-[#111827] antialiased selection:bg-[#166534]/20 selection:text-[#166534] flex flex-col min-h-screen relative overflow-x-hidden font-['Inter']">
    <slot />
    <CartDrawer />

    {/* Global Live Purchase Toast (FOMO) */}
    <div id="live-toast" class="fixed bottom-6 left-6 z-[9999] bg-white/90 backdrop-blur-xl border border-black/[0.05] shadow-[0_20px_40px_rgba(0,0,0,0.08)] p-3 pr-6 rounded-2xl flex items-center gap-4 translate-y-[150%] opacity-0 transition-all duration-700 ease-[cubic-bezier(0.1,0,0,1)] pointer-events-none md:pointer-events-auto">
      <div class="w-10 h-10 rounded-full bg-[#f0fdf4] border border-emerald-100 flex items-center justify-center flex-shrink-0"><svg class="w-5 h-5 text-[#166534]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg></div>
      <div class="flex flex-col">
        <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5" id="toast-title">Live Order</span>
        <span class="text-xs font-bold text-[#111827]" id="toast-name">Rahul from Pune</span>
        <span class="text-[10px] text-[#166534] font-medium" id="toast-action">just bought Spirulina Capsules 2 mins ago 🔥</span>
      </div>
    </div>

    <script is:inline>
      function initLiveToast() {
        const toast = document.getElementById('live-toast');
        const toastName = document.getElementById('toast-name');
        const toastAction = document.getElementById('toast-action');
        const toastTitle = document.getElementById('toast-title');
        
        const names = [
          { name: "Rahul from Pune", loc: "Spirulina Capsules", time: "2 mins ago" },
          { name: "Neha from Mumbai", loc: "Spirulina Powder", time: "1 min ago" },
          { name: "Amit from Nagpur", loc: "Spirulina Capsules", time: "just now" },
          { name: "Priya from Nashik", loc: "Spirulina Powder", time: "4 mins ago" },
          { name: "Vikram from Pune", loc: "Spirulina Capsules", time: "3 mins ago" },
          { name: "Sneha from Mumbai", loc: "Spirulina Powder", time: "2 mins ago" }
        ];

        if (toast && toastName && toastAction) {
          if (toastTitle) toastTitle.innerText = "Live Order";
          
          setTimeout(() => {
            const buyer = names[Math.floor(Math.random() * names.length)];
            toastName.innerText = buyer.name;
            toastAction.innerText = `just bought ${buyer.loc} ${buyer.time} 🔥`;
            toast.classList.remove('translate-y-[150%]', 'opacity-0');
            setTimeout(() => { toast.classList.add('translate-y-[150%]', 'opacity-0'); }, 4000);
          }, 6000);

          setInterval(() => {
            const buyer = names[Math.floor(Math.random() * names.length)];
            toastName.innerText = buyer.name;
            toastAction.innerText = `just bought ${buyer.loc} ${buyer.time} 🔥`;
            toast.classList.remove('translate-y-[150%]', 'opacity-0');
            setTimeout(() => { toast.classList.add('translate-y-[150%]', 'opacity-0'); }, 4000);
          }, Math.floor(Math.random() * 12000) + 24000);
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initLiveToast);
      } else {
        initLiveToast();
      }
      document.addEventListener('astro:page-load', initLiveToast);
    </script>
  </body>
</html>