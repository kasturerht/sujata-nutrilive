<script>
  function initQuizEngine() {
    console.log("🧬 Apothecary Quiz Engine Initializing...");
    
    // Elements
    const pBar = document.getElementById('quiz-progress-bar');
    const step1 = document.getElementById('quiz-step-1');
    const step2 = document.getElementById('quiz-step-2');
    const step3 = document.getElementById('quiz-step-3');
    const stepAnalyzing = document.getElementById('quiz-analyzing');
    const stepResult = document.getElementById('quiz-result');
    
    const back2 = document.getElementById('quiz-back-2');
    const back3 = document.getElementById('quiz-back-3');
    const restart = document.getElementById('quiz-restart');
    
    const analyzingText = document.getElementById('analyzing-status-text');
    
    // Result elements
    const recTitle = document.getElementById('recommendation-title');
    const recDesc1 = document.getElementById('recommendation-desc-1');
    const recDesc2 = document.getElementById('recommendation-desc-2');
    const recProdTitle = document.getElementById('recommendation-prod-title');
    const recPrice = document.getElementById('recommendation-price');
    const recImg = document.getElementById('recommendation-img') as HTMLImageElement | null;
    const quizAtcBtn = document.getElementById('quiz-atc-btn');
    
    // State storage
    const quizData = {
      concern: '',
      style: '',
      lifestyle: ''
    };

    if (!step1 || !step2 || !step3 || !stepAnalyzing || !stepResult) {
      console.warn("⚠️ Quiz elements missing in DOM.");
      return;
    }

    // Options click event
    const options = document.querySelectorAll('.quiz-option');
    options.forEach(opt => {
      opt.addEventListener('click', (e) => {
        const step = opt.getAttribute('data-step');
        const val = opt.getAttribute('data-value');
        
        if (step === '1') {
          quizData.concern = val;
          goToStep(2);
        } else if (step === '2') {
          quizData.style = val;
          goToStep(3);
        } else if (step === '3') {
          quizData.lifestyle = val;
          processResults();
        }
      });
    });

    // Navigation back buttons
    back2?.addEventListener('click', () => goToStep(1));
    back3?.addEventListener('click', () => goToStep(2));
    restart?.addEventListener('click', () => {
      // Reset variables
      quizData.concern = '';
      quizData.style = '';
      quizData.lifestyle = '';
      
      // Hide results
      stepResult.classList.remove('opacity-100');
      stepResult.classList.add('hidden', 'opacity-0');
      
      // Go to 1
      goToStep(1);
    });

    function goToStep(num: number) {
      // Hide all
      step1.classList.add('hidden');
      step2.classList.add('hidden');
      step3.classList.add('hidden');
      stepAnalyzing.classList.add('hidden');
      stepResult.classList.add('hidden');

      // Reset step transitions
      step1.classList.remove('opacity-100');
      step2.classList.remove('opacity-100');
      step3.classList.remove('opacity-100');

      if (num === 1) {
        step1.classList.remove('hidden');
        setTimeout(() => step1.classList.add('opacity-100'), 50);
        if (pBar) pBar.style.width = '33%';
      } else if (num === 2) {
        step2.classList.remove('hidden');
        setTimeout(() => step2.classList.add('opacity-100'), 50);
        if (pBar) pBar.style.width = '66%';
      } else if (num === 3) {
        step3.classList.remove('hidden');
        setTimeout(() => step3.classList.add('opacity-100'), 50);
        if (pBar) pBar.style.width = '100%';
      }
    }

    const analyzingPhrases = [
      "Analyzing biological profile and metabolic indicators...",
      "Mapping phycocyanin targets to cellular antioxidant pathways...",
      "Matching cold-pressed enzymology thresholds with digestion rates...",
      "Custom protocol compiled successfully."
    ];

    function processResults() {
      // Hide step 3
      step3.classList.add('hidden', 'opacity-0');
      stepAnalyzing.classList.remove('hidden');
      if (pBar) pBar.style.width = '100%';

      let phraseIndex = 0;
      const interval = setInterval(() => {
        if (phraseIndex < analyzingPhrases.length) {
          if (analyzingText) analyzingText.innerText = analyzingPhrases[phraseIndex];
          phraseIndex++;
        } else {
          clearInterval(interval);
          displayClinicalResult();
        }
      }, 600);
    }

    function displayClinicalResult() {
      stepAnalyzing.classList.add('hidden');
      stepResult.classList.remove('hidden');
      
      setTimeout(() => {
        stepResult.classList.remove('opacity-0');
        stepResult.classList.add('opacity-100');
      }, 50);

      // Clinical recommendation engine mapping:
      // Shopify products retrieved from store:
      // 1. Tablets (gid://shopify/ProductVariant/59247880438094, price ₹1200)
      // 2. Powder (gid://shopify/ProductVariant/59276906103118, price ₹600)
      
      let variantId = "gid://shopify/ProductVariant/59247880438094"; // default Tablets
      let title = "Sujata Premium Tablets";
      let price = "₹1,200";
      let imgPath = "/spirulina-bottle.png";
      let pName = "Spirulina Tablets";
      
      let concernLabel = "Cellular Optimization";
      let desc1 = "";
      let desc2 = "";
      let absorption = "98% Bioactive";
      let batchCode = "#TBL-0426";

      // If user chooses powder specifically or combo
      if (quizData.style === 'powder' || (quizData.concern === 'energy' && quizData.style !== 'tablets')) {
        variantId = "gid://shopify/ProductVariant/59276906103118"; // Powder
        title = "Sujata Live Enzyme Powder";
        price = "₹600";
        imgPath = "/spirulina-powder.png";
        pName = "Spirulin Powder";
        absorption = "99.4% Bioactive";
        batchCode = "#PWD-0426";
      }

      // Generate personalized copy based on Q1
      if (quizData.concern === 'energy') {
        concernLabel = "Sustained Energy & Focus";
        desc1 = "Based on your goal to combat fatigue, your biological profile indicates high efficiency response to cold-pressed phycocyanin compounds. This batch maximizes immediate cognitive oxygenation and sustained ATP mitochondrial release.";
        desc2 = "Recommended usage: Consume in the morning or early afternoon. Avoid consuming within 3 hours of sleep to preserve natural melatonin pathways.";
      } else if (quizData.concern === 'immunity') {
        concernLabel = "Gut Health & Cellular Immunity";
        desc1 = "Your objective for cellular defense and gut health matches our laboratory-grade pure aqua culture batch. Rich in bioavailable chlorophyll and essential trace elements, this routine triggers deep cellular detoxification and restores gut alkaline balance.";
        desc2 = "Recommended usage: Take daily on an empty stomach. Standard protocols show maximum gastrointestinal microbiome alignment in 14-21 days.";
      } else {
        concernLabel = "Dermal & Follicular Rejuvenation";
        desc1 = "To address skin elasticity and follicular strength, this protocol delivers heavy-metal-free, organic amino acids directly to your bloodstream. The high concentration of active Vitamin B12 and GLA stimulates natural collagen and keratin synthesis.";
        desc2 = "Recommended usage: Make this a consistent part of your daily nutrition. Symmetrical results in hair density and skin glow are clinically validated at Day 30.";
      }

      // Update UI elements
      if (recTitle) recTitle.innerHTML = `Your custom protocol: <br class="hidden sm:inline"/><span class="italic text-emerald-300">${concernLabel}</span>`;
      if (recDesc1) recDesc1.innerText = desc1;
      if (recDesc2) recDesc2.innerText = desc2;
      if (recProdTitle) recProdTitle.innerText = pName;
      if (recPrice) recPrice.innerText = price;
      if (recImg) recImg.src = imgPath;
      
      const absMetric = document.getElementById('quiz-metric-absorption');
      if (absMetric) absMetric.innerText = absorption;
      const bchMetric = document.getElementById('quiz-metric-batch');
      if (bchMetric) bchMetric.innerText = batchCode;

      // Update Add to Cart Button attributes
      if (quizAtcBtn) {
        const quizContainer = document.getElementById('apothecary-quiz');
        const shopDomain = quizContainer?.getAttribute('data-domain') || 'skadas-headless-demo.myshopify.com';
        const storeToken = quizContainer?.getAttribute('data-token') || '32f678c5f8d1345e945ed48713d9cf2f';
        quizAtcBtn.setAttribute('data-variant-id', variantId);
        quizAtcBtn.setAttribute('data-domain', shopDomain);
        quizAtcBtn.setAttribute('data-token', storeToken);
      }
    }
  }

  // Initialize
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initQuizEngine);
  } else {
    initQuizEngine();
  }
  
  // Astro View Transitions compatibility
  document.addEventListener('astro:page-load', initQuizEngine);
</script>

