---
const steps = [
  {
    number: "01",
    title: "Architecture Diagnostics",
    description: "We don't guess; we run telemetry. We map your current infrastructure, identifying specific Core Web Vitals bottlenecks, indexability flaws, and GA4 telemetry gaps.",
    highlight: "Phase 01 // Discovery"
  },
  {
    number: "02",
    title: "Headless Decoupling",
    description: "We separate your monolithic constraints. We engineer a pristine Astro front-end and migrate your data layer to a headless Sanity CMS environment for sub-second velocity.",
    highlight: "Phase 02 // Engineering"
  },
  {
    number: "03",
    title: "Server-Side Calibration",
    description: "We secure your signal purity. We deploy Google Cloud containers, route your GTM through first-party domains, and ensure 100% ad-blocker resistance for Meta/Google pixels.",
    highlight: "Phase 03 // Telemetry"
  },
  {
    number: "04",
    title: "Algorithmic Scaling",
    description: "Once the pipeline is zero-latency and data-pure, we deploy advanced programmatic SEO and precision ad campaigns to acquire high-ticket leads at a fraction of standard CPA.",
    highlight: "Phase 04 // Acquisition"
  }
];
---

<section id="process" class="py-24 md:py-32 relative z-10 bg-[#000000] border-y border-white/5">
  
  <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">
    
    <div class="mb-16 md:mb-24 text-center md:text-left">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-900/80 border border-slate-700/50 text-xs text-slate-300 font-mono mb-6 backdrop-blur-sm">
        <span class="w-1.5 h-1.5 rounded-full bg-cyan-500 animate-pulse"></span>
        The Methodology
      </div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tighter text-white leading-tight">
        How we engineer <br class="hidden md:block"/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500 drop-shadow-[0_0_15px_rgba(34,211,238,0.2)]">predictable growth.</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 relative">
      
      <div class="hidden lg:block relative">
        <div class="sticky top-32 w-full h-[500px] rounded-[2rem] bg-[#0a0a0a] border border-white/10 overflow-hidden shadow-[0_0_50px_rgba(0,0,0,0.5)]">
            
            <div class="absolute inset-0 opacity-[0.03] bg-[linear-gradient(to_right,#fff_1px,transparent_1px),linear-gradient(to_bottom,#fff_1px,transparent_1px)] bg-[size:30px_30px]"></div>
            
            <div class="canvas-visual absolute inset-0 flex items-center justify-center transition-all duration-700 opacity-100 scale-100" data-visual="0">
                <div class="absolute inset-0 bg-radial-gradient from-cyan-900/20 to-transparent opacity-50"></div>
                <div class="relative w-64 h-64 border border-cyan-500/20 rounded-full flex items-center justify-center">
                    <div class="absolute w-48 h-48 border border-cyan-500/10 rounded-full"></div>
                    <div class="absolute w-32 h-32 border border-cyan-500/30 rounded-full"></div>
                    <div class="w-2 h-2 bg-cyan-400 rounded-full shadow-[0_0_15px_#22d3ee] animate-ping"></div>
                    <div class="absolute top-1/2 left-1/2 w-32 h-1 bg-gradient-to-r from-transparent to-cyan-400/50 origin-left animate-[spin_3s_linear_infinite]"></div>
                </div>
            </div>

            <div class="canvas-visual absolute inset-0 flex items-center justify-center transition-all duration-700 opacity-0 scale-95 pointer-events-none" data-visual="1">
                <div class="absolute w-full h-full flex items-center justify-center">
                    <div class="absolute w-12 h-12 bg-slate-900 border border-blue-500/50 rounded-xl flex items-center justify-center z-10 translate-x-[-80px] translate-y-[-60px] shadow-[0_0_20px_rgba(59,130,246,0.2)]">
                        <div class="w-2 h-2 bg-blue-400 rounded-full"></div>
                    </div>
                    <div class="absolute w-12 h-12 bg-slate-900 border border-blue-500/50 rounded-xl flex items-center justify-center z-10 translate-x-[80px] translate-y-[-60px] shadow-[0_0_20px_rgba(59,130,246,0.2)]">
                        <div class="w-2 h-2 bg-blue-400 rounded-full"></div>
                    </div>
                    <div class="absolute w-16 h-16 bg-[#030712] border-2 border-cyan-500/80 rounded-xl flex items-center justify-center z-10 translate-y-[60px] shadow-[0_0_30px_rgba(34,211,238,0.3)]">
                        <div class="w-3 h-3 bg-cyan-400 rounded-full animate-pulse"></div>
                    </div>
                    <svg class="absolute inset-0 w-full h-full pointer-events-none">
                        <path d="M 180 190 L 250 310" stroke="rgba(34,211,238,0.3)" stroke-width="2" fill="none" stroke-dasharray="4 4" class="animate-[dash_2s_linear_infinite]" />
                        <path d="M 340 190 L 250 310" stroke="rgba(34,211,238,0.3)" stroke-width="2" fill="none" stroke-dasharray="4 4" class="animate-[dash_2s_linear_infinite]" />
                    </svg>
                </div>
            </div>

            <div class="canvas-visual absolute inset-0 flex flex-col items-center justify-center transition-all duration-700 opacity-0 scale-95 pointer-events-none gap-6" data-visual="2">
                <div class="w-3/4 h-[2px] bg-slate-800 relative overflow-hidden rounded-full">
                    <div class="absolute top-0 left-0 h-full w-1/3 bg-gradient-to-r from-transparent via-cyan-400 to-transparent animate-[flow_1.5s_linear_infinite]"></div>
                </div>
                <div class="w-2/4 h-[2px] bg-slate-800 relative overflow-hidden rounded-full">
                    <div class="absolute top-0 left-0 h-full w-1/3 bg-gradient-to-r from-transparent via-blue-500 to-transparent animate-[flow_1.5s_linear_infinite_0.4s]"></div>
                </div>
                <div class="w-3/4 h-[2px] bg-slate-800 relative overflow-hidden rounded-full">
                    <div class="absolute top-0 left-0 h-full w-1/3 bg-gradient-to-r from-transparent via-cyan-400 to-transparent animate-[flow_1.5s_linear_infinite_0.8s]"></div>
                </div>
                <div class="mt-4 px-6 py-2 border border-cyan-500/30 bg-cyan-500/10 rounded-full text-[10px] font-mono text-cyan-400 tracking-widest uppercase shadow-[0_0_20px_rgba(34,211,238,0.2)]">
                    Deploying Architecture
                </div>
            </div>

            <div class="canvas-visual absolute inset-0 flex items-center justify-center transition-all duration-700 opacity-0 scale-95 pointer-events-none" data-visual="3">
                <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-0 h-0 bg-blue-500/20 rounded-full blur-2xl animate-[expandGlow_3s_ease-out_infinite]"></div>
                <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-0 h-0 bg-cyan-400/20 rounded-full blur-xl animate-[expandGlow_3s_ease-out_infinite_1s]"></div>
                
                <svg class="w-64 h-32 overflow-visible" viewBox="0 0 200 100">
                    <path d="M0,100 C50,90 80,60 120,40 C160,20 180,10 200,0" fill="none" stroke="url(#scaleGrad)" stroke-width="4" stroke-linecap="round" />
                    <defs>
                        <linearGradient id="scaleGrad" x1="0%" y1="100%" x2="100%" y2="0%">
                            <stop offset="0%" stop-color="#3b82f6" stop-opacity="0.2" />
                            <stop offset="100%" stop-color="#22d3ee" stop-opacity="1" />
                        </linearGradient>
                    </defs>
                    <circle cx="200" cy="0" r="6" fill="#22d3ee" class="shadow-[0_0_20px_#22d3ee]" />
                </svg>
            </div>

        </div>
      </div>

      <div class="relative w-full pb-10 lg:pb-32 space-y-24 lg:space-y-[40vh] step-container">
        {steps.map((step, index) => (
          <div class="step-block relative opacity-40 transition-opacity duration-500" data-index={index}>
            
            <div class="lg:hidden mb-8 inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-900 border border-slate-800 text-xs text-cyan-400 font-mono">
                Phase {step.number}
            </div>

            <div class="relative">
                <h3 class="text-[5rem] lg:text-[7rem] font-black text-white/5 tracking-tighter leading-none absolute -top-12 lg:-top-20 -left-4 select-none pointer-events-none">
                    {step.number}
                </h3>
                <div class="relative z-10">
                    <p class="text-xs text-cyan-500 font-mono uppercase tracking-widest mb-4 font-semibold">{step.highlight}</p>
                    <h4 class="text-3xl lg:text-4xl font-bold text-white mb-6 tracking-tight leading-tight">{step.title}</h4>
                    <p class="text-lg text-slate-400 leading-relaxed font-light">{step.description}</p>
                </div>
            </div>

          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  /* =========================================
     ANIMATIONS FOR CANVAS VISUALS
     ========================================= */
  @keyframes flow {
    0% { left: -50%; opacity: 0; }
    50% { opacity: 1; }
    100% { left: 100%; opacity: 0; }
  }

  @keyframes expandGlow {
    0% { width: 0; height: 0; opacity: 1; }
    100% { width: 300px; height: 300px; opacity: 0; }
  }

  @keyframes dash {
    to { stroke-dashoffset: -8; }
  }

  /* Active state for scrolling steps */
  .step-block.is-active {
    opacity: 1;
  }
</style>

<script is:inline>
  function initScrollTelling() {
    const steps = document.querySelectorAll('.step-block');
    const visuals = document.querySelectorAll('.canvas-visual');

    if (steps.length === 0) return;

    // Set up the Intersection Observer
    // 'rootMargin' is set so the intersection happens when the step is near the middle of the viewport
    const observerOptions = {
        root: null,
        rootMargin: '-40% 0px -40% 0px', 
        threshold: 0
    };

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const activeIndex = entry.target.getAttribute('data-index');

                // 1. Highlight the active text step
                steps.forEach(step => step.classList.remove('is-active'));
                entry.target.classList.add('is-active');

                // 2. Morph the Sticky Canvas Visual
                visuals.forEach(visual => {
                    if (visual.getAttribute('data-visual') === activeIndex) {
                        visual.classList.replace('opacity-0', 'opacity-100');
                        visual.classList.replace('scale-95', 'scale-100');
                    } else {
                        visual.classList.replace('opacity-100', 'opacity-0');
                        visual.classList.replace('scale-100', 'scale-95');
                    }
                });
            }
        });
    }, observerOptions);

    steps.forEach(step => observer.observe(step));
    
    // Fallback logic to activate the first step immediately on load
    if(steps[0]) steps[0].classList.add('is-active');
  }

  document.addEventListener('astro:page-load', initScrollTelling);
  initScrollTelling();
</script>