---
// src/components/SocialProof.astro
---

<section id="proof" class="relative w-full lg:h-[100vh] min-h-[800px] max-h-[1000px] flex flex-col justify-center bg-[#000000] border-y border-white/5 py-24 lg:py-0 selection:bg-emerald-500/30">
  
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1000px] h-[500px] bg-emerald-900/10 blur-[150px] rounded-full pointer-events-none z-0"></div>

  <div class="w-full max-w-7xl mx-auto px-6 lg:px-8 relative z-10 flex flex-col h-full justify-center">
    
    <div class="flex flex-col md:flex-row justify-between items-end gap-6 mb-12 scroll-reveal" style="opacity: 0; transform: translateY(20px); transition: all 0.8s ease-out;">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/[0.03] border border-white/10 text-[10px] text-emerald-400 font-mono mb-6 uppercase tracking-widest shadow-sm">
            <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full shadow-[0_0_8px_#10b981]"></span>
            Telemetry & Data
        </div>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-medium text-white leading-[1.1] tracking-tighter mb-4">
          Don't trust us. <br class="md:hidden"/>
          <span class="text-slate-500">Trust the data.</span>
        </h2>
        <p class="text-slate-400 text-sm md:text-base leading-relaxed font-light max-w-2xl">
          Global enterprises are migrating to Headless Architecture. Adjust the metrics below to calculate the invisible revenue bleed in your current monolithic setup.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 h-auto lg:h-[480px]">
        
        <div class="lg:col-span-5 relative group rounded-[1.5rem] border border-white/10 bg-[#050505] p-8 md:p-10 flex flex-col justify-between shadow-2xl overflow-hidden scroll-reveal" 
             style="opacity: 0; transform: translateY(20px); transition: all 0.8s ease-out 0.1s;"
             onmousemove="handleSpotlight(event, this)">
            
            <div class="pointer-events-none absolute -inset-px opacity-0 transition duration-300 group-hover:opacity-100 z-0" 
                 style="background: radial-gradient(600px circle at var(--x, 0px) var(--y, 0px), rgba(16,185,129,0.15), transparent 40%);"></div>
            
            <div class="relative z-10">
                <h3 class="text-xl font-medium text-white tracking-tight mb-2">Revenue Bleed Calculator</h3>
                <p class="text-xs text-slate-500 font-light mb-10 max-w-xs">Simulate your architectural loss in real-time.</p>
                
                <div class="space-y-10">
                    <div class="space-y-4">
                        <div class="flex justify-between items-end">
                            <label class="text-[10px] font-mono tracking-widest uppercase text-slate-500">Monthly Traffic</label>
                            <span class="text-xl font-medium text-white tracking-tight" id="trafficVal">100,000</span>
                        </div>
                        <input type="range" id="trafficInput" min="10000" max="1000000" step="10000" value="100000" class="premium-slider" oninput="runCalculator()">
                    </div>

                    <div class="space-y-4">
                        <div class="flex justify-between items-end">
                            <label class="text-[10px] font-mono tracking-widest uppercase text-slate-500">Conversion Rate</label>
                            <span class="text-xl font-medium text-white tracking-tight"><span id="crVal">2.0</span>%</span>
                        </div>
                        <input type="range" id="crInput" min="0.5" max="10" step="0.1" value="2.0" class="premium-slider" oninput="runCalculator()">
                    </div>

                    <div class="space-y-4">
                        <div class="flex justify-between items-end">
                            <label class="text-[10px] font-mono tracking-widest uppercase text-slate-500">Avg. Order Value</label>
                            <span class="text-xl font-medium text-white tracking-tight">$<span id="aovVal">150</span></span>
                        </div>
                        <input type="range" id="aovInput" min="50" max="1000" step="10" value="150" class="premium-slider" oninput="runCalculator()">
                    </div>
                </div>
            </div>

            <div class="mt-10 pt-6 border-t border-white/5 relative z-10">
                <div class="flex items-center justify-between text-[10px] font-mono text-slate-500 uppercase tracking-widest">
                    <span>Baseline: Deloitte Benchmark</span>
                    <span class="flex items-center gap-1.5 text-emerald-500/70"><span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></span> Sync Active</span>
                </div>
            </div>
        </div>

        <div class="lg:col-span-7 flex flex-col gap-6 h-full">
            
            <div class="relative group flex-1 flex flex-col justify-center rounded-[1.5rem] border border-white/10 bg-[#050505] p-6 md:p-10 shadow-2xl overflow-hidden scroll-reveal"
                 style="opacity: 0; transform: translateY(20px); transition: all 0.8s ease-out 0.2s;"
                 onmousemove="handleSpotlight(event, this)">
                
                <div class="pointer-events-none absolute -inset-px opacity-0 transition duration-300 group-hover:opacity-100 z-0" 
                     style="background: radial-gradient(800px circle at var(--x, 0px) var(--y, 0px), rgba(16,185,129,0.12), transparent 40%);"></div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 relative z-10 min-w-0">
                    
                    <div class="flex flex-col justify-center min-w-0">
                        <p class="text-[10px] font-mono uppercase tracking-widest text-slate-500 mb-3 truncate">Legacy Revenue</p>
                        <h4 class="text-2xl lg:text-3xl font-medium text-slate-400 tracking-tight truncate">$<span id="currentRev" data-val="300000">300,000</span></h4>
                        <div class="w-full h-[2px] bg-white/5 rounded-full mt-5 overflow-hidden">
                            <div class="h-full bg-slate-700 w-[65%]"></div>
                        </div>
                    </div>
                    
                    <div class="relative flex flex-col justify-center pl-0 md:pl-6 md:border-l border-white/5 min-w-0">
                        <p class="text-[10px] font-mono uppercase tracking-widest text-emerald-400 mb-3 truncate">Skadas Edge Potential</p>
                        
                        <h4 class="font-medium text-white tracking-tighter mb-4 drop-shadow-[0_0_20px_rgba(16,185,129,0.1)] truncate" 
                            style="font-size: clamp(1.5rem, 3.5vw, 3.2rem); line-height: 1.1;">
                            $<span id="potentialRev" class="text-transparent bg-clip-text bg-gradient-to-b from-white to-white/70" data-val="360000">360,000</span>
                        </h4>
                        
                        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-emerald-500/10 border border-emerald-500/20 rounded-full text-emerald-400 text-[10px] font-medium uppercase tracking-widest w-max max-w-full">
                            <svg class="w-3 h-3 text-emerald-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                            <span class="truncate">+$<span id="upliftRev" data-val="60000">60,000</span> / Mo</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-3 gap-4 lg:gap-6 h-auto md:h-[140px]">
                
                <div class="relative group rounded-2xl border border-white/10 bg-[#050505] p-5 flex flex-col justify-center shadow-lg overflow-hidden scroll-reveal"
                     style="opacity: 0; transform: translateY(20px); transition: all 0.8s ease-out 0.3s;"
                     onmousemove="handleSpotlight(event, this)">
                    <div class="pointer-events-none absolute -inset-px opacity-0 transition duration-300 group-hover:opacity-100 z-0" style="background: radial-gradient(400px circle at var(--x, 0px) var(--y, 0px), rgba(16,185,129,0.15), transparent 40%);"></div>
                    <div class="relative z-10">
                        <p class="text-slate-500 font-mono text-[9px] uppercase tracking-widest mb-2">Deloitte</p>
                        <h4 class="text-2xl md:text-3xl font-medium text-white mb-1 tracking-tight">8.4<span class="text-sm text-slate-500">%</span></h4>
                        <p class="text-[10px] md:text-[11px] text-slate-500 leading-snug font-light">Conversion lift per 0.1s mobile speed improvement.</p>
                    </div>
                </div>
                
                <div class="relative group rounded-2xl border border-white/10 bg-[#050505] p-5 flex flex-col justify-center shadow-lg overflow-hidden scroll-reveal"
                     style="opacity: 0; transform: translateY(20px); transition: all 0.8s ease-out 0.4s;"
                     onmousemove="handleSpotlight(event, this)">
                    <div class="pointer-events-none absolute -inset-px opacity-0 transition duration-300 group-hover:opacity-100 z-0" style="background: radial-gradient(400px circle at var(--x, 0px) var(--y, 0px), rgba(34,211,238,0.15), transparent 40%);"></div>
                    <div class="relative z-10">
                        <p class="text-slate-500 font-mono text-[9px] uppercase tracking-widest mb-2">Meta Eng</p>
                        <h4 class="text-2xl md:text-3xl font-medium text-white mb-1 tracking-tight">20<span class="text-sm text-slate-500">%+</span></h4>
                        <p class="text-[10px] md:text-[11px] text-slate-500 leading-snug font-light">CPA reduction via Server-Side pixel signal recovery.</p>
                    </div>
                </div>

                <div class="relative group rounded-2xl border border-white/10 bg-[#050505] p-5 flex flex-col justify-center shadow-lg overflow-hidden scroll-reveal"
                     style="opacity: 0; transform: translateY(20px); transition: all 0.8s ease-out 0.5s;"
                     onmousemove="handleSpotlight(event, this)">
                    <div class="pointer-events-none absolute -inset-px opacity-0 transition duration-300 group-hover:opacity-100 z-0" style="background: radial-gradient(400px circle at var(--x, 0px) var(--y, 0px), rgba(59,130,246,0.15), transparent 40%);"></div>
                    <div class="relative z-10">
                        <p class="text-slate-500 font-mono text-[9px] uppercase tracking-widest mb-2">Portent</p>
                        <h4 class="text-2xl md:text-3xl font-medium text-white mb-1 tracking-tight">3<span class="text-sm text-slate-500">x</span></h4>
                        <p class="text-[10px] md:text-[11px] text-slate-500 leading-snug font-light">Revenue multiplier for sub-second headless load times.</p>
                    </div>
                </div>
            </div>

        </div>

    </div>
  </div>
</section>

<style is:global>
    /* Premium Slider styling that won't get stripped by Astro */
    .premium-slider {
        -webkit-appearance: none;
        width: 100%;
        height: 2px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 2px;
        outline: none;
    }
    .premium-slider::-webkit-slider-thumb {
        -webkit-appearance: none;
        height: 18px;
        width: 18px;
        border-radius: 50%;
        background: #fff;
        cursor: grab;
        margin-top: -8px; 
        box-shadow: 0 0 10px rgba(0,0,0,0.5);
        border: 2px solid #000;
        transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275), background 0.2s;
    }
    .premium-slider:active::-webkit-slider-thumb {
        cursor: grabbing;
        transform: scale(1.2);
        background: #10b981; 
        border-color: #10b981;
        box-shadow: 0 0 15px rgba(16,185,129,0.5);
    }
</style>

<script is:inline>
  // 1. VERCEL SPOTLIGHT ENGINE (Attached globally so HTML inline handlers work perfectly)
  window.handleSpotlight = function(e, element) {
      const rect = element.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      element.style.setProperty('--x', `${x}px`);
      element.style.setProperty('--y', `${y}px`);
  };

  // 2. STRIPE ODOMETER (Spring Animation Engine)
  window.animateNumber = function(elementId, targetValue) {
      const el = document.getElementById(elementId);
      if(!el) return;
      
      const startValue = parseFloat(el.getAttribute('data-val')) || 0;
      if (startValue === targetValue) return;

      const duration = 800;
      let startTimestamp = null;

      // EaseOut Expo (Apple-like smooth decelerating roll)
      const easeOutExpo = (x) => {
          return x === 1 ? 1 : 1 - Math.pow(2, -10 * x);
      };

      const step = (timestamp) => {
          if (!startTimestamp) startTimestamp = timestamp;
          const progress = Math.min((timestamp - startTimestamp) / duration, 1);
          const easedProgress = easeOutExpo(progress);
          
          const current = startValue + (targetValue - startValue) * easedProgress;
          
          el.innerText = Math.round(current).toLocaleString('en-US');
          
          if (progress < 1) {
              window.requestAnimationFrame(step);
          } else {
              el.innerText = Math.round(targetValue).toLocaleString('en-US');
              el.setAttribute('data-val', targetValue);
          }
      };
      window.requestAnimationFrame(step);
  };

  // 3. THE CALCULATOR LOGIC
  window.runCalculator = function() {
      const traffic = parseFloat(document.getElementById('trafficInput').value);
      const cr = parseFloat(document.getElementById('crInput').value) / 100;
      const aov = parseFloat(document.getElementById('aovInput').value);

      // Update text above sliders
      document.getElementById('trafficVal').innerText = traffic.toLocaleString('en-US');
      document.getElementById('crVal').innerText = (cr * 100).toFixed(1);
      document.getElementById('aovVal').innerText = aov.toLocaleString('en-US');

      // Math
      const currentMonthly = traffic * cr * aov;
      const potentialMonthly = traffic * (cr * 1.20) * aov; // 20% Lift
      const uplift = potentialMonthly - currentMonthly;

      // Trigger Odometer Animation
      window.animateNumber('currentRev', currentMonthly);
      window.animateNumber('potentialRev', potentialMonthly);
      window.animateNumber('upliftRev', uplift);
  };

  // 4. BULLETPROOF SCROLL REVEAL (Runs independently of Astro lifecycle)
  (function initScrollReveal() {
      const elements = document.querySelectorAll('.scroll-reveal');
      if(elements.length === 0) return;

      const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
              if (entry.isIntersecting) {
                  entry.target.style.opacity = '1';
                  entry.target.style.transform = 'translateY(0)';
                  observer.unobserve(entry.target);
              }
          });
      }, { threshold: 0.1 });

      elements.forEach(el => observer.observe(el));
  })();
</script>