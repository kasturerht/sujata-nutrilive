<script>
  function initCollapsibleComparison() {
    const btn = document.getElementById('toggle-comparison-btn');
    const content = document.getElementById('collapsible-comparison-content');
    const icon = document.getElementById('toggle-comparison-icon');

    if (!btn || !content || !icon) return;

    // Reset state on load
    content.classList.add('hidden');
    icon.classList.remove('rotate-180');
    btn.querySelector('span').innerText = 'Expand Specifications Matrix';

    btn.addEventListener('click', () => {
      const isHidden = content.classList.contains('hidden');
      if (isHidden) {
        content.classList.remove('hidden');
        icon.classList.add('rotate-180');
        btn.querySelector('span').innerText = 'Collapse Specifications Matrix';
      } else {
        content.classList.add('hidden');
        icon.classList.remove('rotate-180');
        btn.querySelector('span').innerText = 'Expand Specifications Matrix';
      }
    });
  }

  // Bind for DOMContentLoaded and Astro transitions
  document.addEventListener('DOMContentLoaded', initCollapsibleComparison);
  document.addEventListener('astro:page-load', initCollapsibleComparison);
</script>

