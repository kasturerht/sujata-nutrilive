---
// src/components/StoreConviction.astro
import { Image } from 'astro:assets';
---

<section id="conviction-engine" class="relative bg-[#FCFBF7] py-24 lg:py-32 overflow-hidden font-['Inter'] selection:bg-[#166534] selection:text-white">
  
  {/* BACKGROUND ELEMENTS - Luxury Texture */}
  <div class="absolute inset-0 pointer-events-none opacity-40">
    <div class="absolute top-0 left-0 w-full h-32 bg-gradient-to-b from-white to-transparent"></div>
    <div class="absolute -right-24 top-1/4 w-96 h-96 bg-[#166534]/5 rounded-full blur-[100px]"></div>
  </div>

  <div class="max-w-[90rem] mx-auto px-6 md:px-12 relative z-10">
    
    {/* 1. EDITORIAL HEADER */}
    <div class="flex flex-col items-center text-center mb-20">
      <div class="flex items-center gap-3 mb-6">
        <div class="h-px w-8 md:w-12 bg-[#B45309]"></div>
        <span class="text-[#B45309] text-[10px] md:text-xs font-black uppercase tracking-[0.4em]">The Science of Heritage</span>
        <div class="h-px w-8 md:w-12 bg-[#B45309]"></div>
      </div>
      <h2 class="text-4xl md:text-6xl font-['Playfair_Display'] font-black text-[#111827] tracking-tight leading-[1.1] mb-6">
        Nature Rooted in <br/> <span class="italic text-[#166534]">Surgical Precision.</span>
      </h2>
      <p class="text-gray-500 max-w-2xl text-sm md:text-base leading-relaxed">
        भारतातील सर्वात शुद्ध Spirulina बनवण्यासाठी आम्ही ५० वर्षांच्या पारंपरिक ज्ञानाला आधुनिक 'Cold-Press' तंत्रज्ञानाची जोड दिली आहे.
      </p>
    </div>

    {/* 2. THE SYMMETRICAL ANATOMY (The "Wow" Orbital Visual) */}
    <div class="grid grid-cols-1 lg:grid-cols-3 items-center gap-12 lg:gap-8 mb-32">
      
      {/* Left Callouts */}
      <div class="space-y-12 order-2 lg:order-1 relative z-20">
        <div class="flex flex-col lg:items-end lg:text-right group">
          <div class="w-12 h-12 rounded-full bg-white shadow-xl flex items-center justify-center mb-4 border border-gray-100 group-hover:bg-[#166534] group-hover:text-white transition-all duration-500">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
          </div>
          <h4 class="text-lg font-black text-[#111827] uppercase tracking-widest mb-2">60% Protein Bio-Matrix</h4>
          <p class="text-gray-500 text-sm leading-relaxed">स्नायूंच्या बळकटीसाठी आणि दिवसभर टिकणाऱ्या ऊर्जेसाठी नैसर्गिक प्रोटिनचा सर्वात मोठा स्रोत.</p>
        </div>

        <div class="flex flex-col lg:items-end lg:text-right group">
          <div class="w-12 h-12 rounded-full bg-white shadow-xl flex items-center justify-center mb-4 border border-gray-100 group-hover:bg-[#166534] group-hover:text-white transition-all duration-500">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <h4 class="text-lg font-black text-[#111827] uppercase tracking-widest mb-2">Lab-Certified Purity</h4>
          <p class="text-gray-500 text-sm leading-relaxed">प्रत्येक बॅचची ३ स्तरांवर चाचणी केली जाते—Heavy Metals आणि Toxins ची कोणतीही भीती नाही.</p>
        </div>
      </div>

      {/* Center Image with Rotating Orbital Dials */}
      <div class="relative order-1 lg:order-2 flex justify-center items-center py-12 lg:py-0 w-full z-10">
        {/* Core Glow */}
        <div class="absolute inset-0 bg-gradient-to-tr from-[#166534]/10 to-[#B45309]/5 rounded-full blur-[80px] animate-pulse"></div>
        
        {/* THE PRECISION ORBITAL RINGS */}
        <div class="absolute w-[280px] h-[280px] sm:w-[350px] sm:h-[350px] lg:w-[420px] lg:h-[420px] pointer-events-none flex items-center justify-center">
          
          {/* Outer Dashed Ring (Slow Reverse Spin) */}
          <div class="absolute inset-0 border-[1.5px] border-dashed border-[#B45309]/20 rounded-full animate-[spin_30s_linear_infinite_reverse]"></div>
          
          {/* Middle Ring (Clockwise Spin) */}
          <div class="absolute inset-4 sm:inset-6 lg:inset-8 border border-[#166534]/15 rounded-full animate-[spin_20s_linear_infinite]">
            {/* Emerald Glowing Dot */}
            <div class="absolute -top-1.5 left-1/2 w-3 h-3 bg-[#166534] rounded-full shadow-[0_0_12px_rgba(22,101,52,0.8)] -translate-x-1/2"></div>
          </div>
          
          {/* Inner Ring (Fast Reverse Spin) */}
          <div class="absolute inset-10 sm:inset-12 lg:inset-16 border border-[#B45309]/15 rounded-full animate-[spin_25s_linear_infinite_reverse]">
            {/* Antique Gold Glowing Dot */}
            <div class="absolute bottom-[-4px] left-1/2 w-2 h-2 bg-[#B45309] rounded-full shadow-[0_0_10px_rgba(180,83,9,0.8)] -translate-x-1/2"></div>
          </div>
        </div>

        {/* Floating Product Image optimized via Astro Image */}
        <Image 
          src="/spirulina-bottle.png" 
          alt="Sujata Nutrilive Premium" 
          width={320}
          height={400}
          class="relative z-20 w-full max-w-[220px] sm:max-w-[280px] lg:max-w-[320px] h-auto drop-shadow-[0_40px_80px_rgba(22,101,52,0.15)] product-float"
        />
      </div>

      {/* Right Callouts */}
      <div class="space-y-12 order-3 relative z-20">
        <div class="flex flex-col group">
          <div class="w-12 h-12 rounded-full bg-white shadow-xl flex items-center justify-center mb-4 border border-gray-100 group-hover:bg-[#166534] group-hover:text-white transition-all duration-500">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
          </div>
          <h4 class="text-lg font-black text-[#111827] uppercase tracking-widest mb-2">Zero-Heat Cold Press</h4>
          <p class="text-gray-500 text-sm leading-relaxed">उष्णतेचा वापर न केल्यामुळे स्पिरुलिनामधील सर्व नैसर्गिक एन्झाईम्स आणि जीवनसत्त्वे जिवंत राहतात.</p>
        </div>

        <div class="flex flex-col group">
          <div class="w-12 h-12 rounded-full bg-white shadow-xl flex items-center justify-center mb-4 border border-gray-100 group-hover:bg-[#166534] group-hover:text-white transition-all duration-500">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
          </div>
          <h4 class="text-lg font-black text-[#111827] uppercase tracking-widest mb-2">Odourless & Fresh</h4>
          <p class="text-gray-500 text-sm leading-relaxed">बाजारातील इतर स्पिरुलिनासारखा घाणेरडा वास येत नाही. हे खाणे सोपे आणि चविष्ट आहे.</p>
        </div>
      </div>

    </div>

    {/* 3. THE LUXURY COMPARISON MATRIX (Side-by-Side Table & Cards) */}
    <div class="w-full max-w-5xl mx-auto relative z-20">
      
      <div class="text-center mb-10">
        <h3 class="text-2xl md:text-3xl font-['Playfair_Display'] font-bold text-[#111827]">
          Sujata Gold Standard vs. Others
        </h3>
        <p class="text-xs md:text-sm text-gray-400 mt-2 uppercase tracking-widest font-bold">clinical verification comparison</p>
      </div>

      {/* TABLE (Hidden on mobile, visible on tablet/desktop) */}
      <div class="hidden md:block overflow-hidden bg-white rounded-[2rem] border border-gray-100 shadow-[0_40px_100px_rgba(0,0,0,0.06)]">
        <table class="w-full border-collapse text-left">
          <thead>
            <tr class="border-b border-gray-100">
              <th class="p-6 text-xs font-bold text-gray-400 uppercase tracking-wider w-[30%]">Comparison Parameters</th>
              <th class="p-6 bg-gradient-to-r from-[#064e3b] to-[#022c22] text-xs font-black text-amber-400 uppercase tracking-widest text-center w-[35%] relative shadow-md">
                Sujata Gold Standard
                <span class="absolute top-0 right-0 transform translate-x-1/2 -translate-y-1/2 bg-amber-500 text-white text-[8px] font-black uppercase px-2 py-0.5 rounded tracking-widest shadow-lg">ELITE</span>
              </th>
              <th class="p-6 bg-gray-50/80 text-xs font-bold text-gray-400 uppercase tracking-wider text-center w-[35%]">Ordinary Brands</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 text-sm">
            {/* Row 1 */}
            <tr class="hover:bg-gray-50/50 transition-colors">
              <td class="p-6 font-bold text-gray-700">Protein Concentration</td>
              <td class="p-6 bg-emerald-50/30 text-center font-bold text-[#064e3b] border-x border-[#064e3b]/10">
                <div class="flex items-center justify-center gap-2">
                  <svg class="w-4 h-4 text-emerald-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                  <span>60%+ Bio-Active Protein</span>
                </div>
              </td>
              <td class="p-6 text-gray-500 text-center">40% Typical (Diluted Power)</td>
            </tr>
            {/* Row 2 */}
            <tr class="hover:bg-gray-50/50 transition-colors">
              <td class="p-6 font-bold text-gray-700">Cultivation Method</td>
              <td class="p-6 bg-emerald-50/30 text-center font-bold text-[#064e3b] border-x border-[#064e3b]/10">
                <div class="flex items-center justify-center gap-2">
                  <svg class="w-4 h-4 text-emerald-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                  <span>Lab-Grade Aqua Culture</span>
                </div>
              </td>
              <td class="p-6 text-gray-500 text-center">Open Industrial Ponds</td>
            </tr>
            {/* Row 3 */}
            <tr class="hover:bg-gray-50/50 transition-colors">
              <td class="p-6 font-bold text-gray-700">Extraction & Processing</td>
              <td class="p-6 bg-emerald-50/30 text-center font-bold text-[#064e3b] border-x border-[#064e3b]/10">
                <div class="flex items-center justify-center gap-2">
                  <svg class="w-4 h-4 text-emerald-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                  <span>Zero-Heat Cold Pressed</span>
                </div>
              </td>
              <td class="p-6 text-gray-500 text-center">High-Heat Spray Dried</td>
            </tr>
            {/* Row 4 */}
            <tr class="hover:bg-gray-50/50 transition-colors">
              <td class="p-6 font-bold text-gray-700">Toxin & Metal Screening</td>
              <td class="p-6 bg-emerald-50/30 text-center font-bold text-[#064e3b] border-x border-[#064e3b]/10">
                <div class="flex items-center justify-center gap-2">
                  <svg class="w-4 h-4 text-emerald-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                  <span>Triple-Certified Heavy Metal Free</span>
                </div>
              </td>
              <td class="p-6 text-gray-500 text-center">Unchecked/Vulnerable</td>
            </tr>
            {/* Row 5 */}
            <tr class="hover:bg-gray-50/50 transition-colors">
              <td class="p-6 font-bold text-gray-700">Chemical Binders/Fillers</td>
              <td class="p-6 bg-emerald-50/30 text-center font-bold text-[#064e3b] border-x border-[#064e3b]/10">
                <div class="flex items-center justify-center gap-2">
                  <svg class="w-4 h-4 text-emerald-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                  <span>100% Pure Extract (Zero Fillers)</span>
                </div>
              </td>
              <td class="p-6 text-gray-500 text-center">Synthetic Chemical Binders</td>
            </tr>
          </tbody>
        </table>
      </div>

      {/* CARDS FOR MOBILE VIEWS (Collapsible panel to save space) */}
      <div class="md:hidden space-y-4" id="mobile-comparison-container">
        
        {/* Toggle Button */}
        <button 
          id="toggle-comparison-btn"
          class="w-full bg-white border border-gray-200 py-4 px-6 rounded-2xl font-bold text-xs uppercase tracking-wider text-gray-700 flex items-center justify-between shadow-sm cursor-pointer outline-none"
        >
          <span>Expand Specifications Matrix</span>
          <svg id="toggle-comparison-icon" class="w-4 h-4 text-gray-500 transform transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path></svg>
        </button>

        {/* Collapsible Content */}
        <div id="collapsible-comparison-content" class="hidden space-y-4 pt-2 transition-all duration-300">
          {[
            { title: "Protein Concentration", sujata: "60%+ Bio-Active Protein", other: "40% Typical" },
            { title: "Cultivation Method", sujata: "Lab-Grade Aqua Culture", other: "Open Industrial Ponds" },
            { title: "Extraction & Processing", sujata: "Zero-Heat Cold Pressed", other: "High-Heat Spray Dried" },
            { title: "Toxin & Metal Screening", sujata: "Triple-Certified Toxin Free", other: "Unchecked/Vulnerable" },
            { title: "Chemical Binders/Fillers", sujata: "100% Pure (Zero Fillers)", other: "Synthetic Binders" }
          ].map((item) => (
            <div class="bg-white rounded-2xl border border-gray-100 p-5 shadow-sm space-y-3">
              <h4 class="text-sm font-black text-gray-700 border-b border-gray-50 pb-2">{item.title}</h4>
              
              <div class="grid grid-cols-2 gap-3 text-xs">
                <div class="bg-emerald-50/40 p-3 rounded-xl border border-emerald-100 text-[#064e3b] font-bold space-y-1">
                  <span class="text-[9px] uppercase tracking-widest text-[#B45309]">Sujata</span>
                  <p class="leading-tight flex items-start gap-1">
                    <svg class="w-3.5 h-3.5 text-emerald-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                    {item.sujata}
                  </p>
                </div>
                <div class="bg-gray-50 p-3 rounded-xl border border-gray-100 text-gray-500 space-y-1">
                  <span class="text-[9px] uppercase tracking-widest text-gray-400">Others</span>
                  <p class="leading-tight flex items-start gap-1">
                    <svg class="w-3.5 h-3.5 text-gray-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
                    {item.other}
                  </p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      {/* Trust Badges Footer - Premium Scalable SVGs to avoid broken images */}
      <div class="mt-16 flex flex-wrap justify-center items-center gap-8 md:gap-16 opacity-50 hover:opacity-90 transition-all duration-700">
        
        {/* FSSAI Seal SVG */}
        <div class="flex items-center gap-2 group cursor-default">
          <svg class="w-10 h-10 text-[#064e3b]" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="50" cy="50" r="45" stroke="currentColor" stroke-width="3"/>
            <path d="M30 52l12 12 28-28" stroke="currentColor" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"/>
            <text x="50%" y="82%" dominant-baseline="middle" text-anchor="middle" font-family="Inter, sans-serif" font-weight="900" font-size="12" fill="currentColor">FSSAI</text>
          </svg>
          <div class="flex flex-col text-left">
            <span class="text-[10px] font-black text-gray-800 uppercase tracking-widest leading-none">fssai</span>
            <span class="text-[8px] font-medium text-gray-400">REGISTERED</span>
          </div>
        </div>

        {/* GMP Seal SVG */}
        <div class="flex items-center gap-2 group cursor-default">
          <svg class="w-10 h-10 text-[#064e3b]" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="50" cy="50" r="45" stroke="currentColor" stroke-width="3"/>
            <rect x="25" y="30" width="50" height="40" rx="3" stroke="currentColor" stroke-width="3"/>
            <path d="M35 50h30M50 35v30" stroke="currentColor" stroke-width="3"/>
            <text x="50%" y="82%" dominant-baseline="middle" text-anchor="middle" font-family="Inter, sans-serif" font-weight="900" font-size="12" fill="currentColor">GMP</text>
          </svg>
          <div class="flex flex-col text-left">
            <span class="text-[10px] font-black text-gray-800 uppercase tracking-widest leading-none">gmp</span>
            <span class="text-[8px] font-medium text-gray-400">CERTIFIED</span>
          </div>
        </div>

        {/* 100% Organic Leaf SVG */}
        <div class="flex items-center gap-2 group cursor-default">
          <svg class="w-10 h-10 text-[#064e3b]" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="50" cy="50" r="45" stroke="currentColor" stroke-width="3"/>
            <path d="M50 25c15 0 25 10 25 25S65 75 50 75s-25-10-25-25 10-25 25-25zm0 0v50" stroke="currentColor" stroke-width="3"/>
            <path d="M50 40c8 0 12 5 12 10s-4 10-12 10" stroke="currentColor" stroke-width="3"/>
          </svg>
          <div class="flex flex-col text-left">
            <span class="text-[10px] font-black text-gray-800 uppercase tracking-widest leading-none">organic</span>
            <span class="text-[8px] font-medium text-gray-400">100% NATURAL</span>
          </div>
        </div>

        {/* AYUSH Premium SVG */}
        <div class="flex items-center gap-2 group cursor-default">
          <svg class="w-10 h-10 text-[#064e3b]" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="50" cy="50" r="45" stroke="currentColor" stroke-width="3"/>
            <path d="M50 22L30 45h40L50 22zm0 23v33" stroke="currentColor" stroke-width="3"/>
            <circle cx="50" cy="78" r="3" fill="currentColor"/>
          </svg>
          <div class="flex flex-col text-left">
            <span class="text-[10px] font-black text-gray-800 uppercase tracking-widest leading-none">ayush</span>
            <span class="text-[8px] font-medium text-gray-400">COMPLIANT</span>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>

<script>
  function initCollapsibleComparison() {
    const btn = document.getElementById('toggle-comparison-btn');
    const content = document.getElementById('collapsible-comparison-content');
    const icon = document.getElementById('toggle-comparison-icon');

    if (!btn || !content || !icon) return;

    // Reset state on load
    content.classList.add('hidden');
    icon.classList.remove('rotate-180');
    btn.querySelector('span').innerText = 'Expand Specifications Matrix';

    btn.addEventListener('click', () => {
      const isHidden = content.classList.contains('hidden');
      if (isHidden) {
        content.classList.remove('hidden');
        icon.classList.add('rotate-180');
        btn.querySelector('span').innerText = 'Collapse Specifications Matrix';
      } else {
        content.classList.add('hidden');
        icon.classList.remove('rotate-180');
        btn.querySelector('span').innerText = 'Expand Specifications Matrix';
      }
    });
  }

  // Bind for DOMContentLoaded and Astro transitions
  document.addEventListener('DOMContentLoaded', initCollapsibleComparison);
  document.addEventListener('astro:page-load', initCollapsibleComparison);
</script>

<style is:global>
  @keyframes product-float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-15px); }
  }
  .product-float {
    animation: product-float 6s ease-in-out infinite;
  }
</style>