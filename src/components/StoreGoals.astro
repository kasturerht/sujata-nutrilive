---
// src/components/StoreGoals.astro
import { Image } from 'astro:assets';
---

<section id="shop-by-goal" class="relative bg-[#022c22] py-20 lg:py-32 font-['Inter'] overflow-hidden border-b border-white/5">
  
  {/* Subtle Background Elements */}
  <div class="absolute inset-0 z-0 opacity-20">
    <div class="absolute top-0 right-0 w-[50vw] h-[50vw] bg-[radial-gradient(circle_at_center,rgba(16,185,129,0.2)_0%,transparent_70%)] blur-[80px]"></div>
  </div>

  <div class="max-w-[90rem] mx-auto px-5 md:px-6 lg:px-12 relative z-10">
    
    {/* Header */}
    <div class="text-center mb-16 md:mb-20">
      <span class="text-emerald-400 text-[10px] md:text-xs font-bold tracking-[0.3em] uppercase mb-4 block">Personalized Routine</span>
      <h2 class="text-3xl md:text-5xl font-['Playfair_Display'] font-black text-white leading-tight">
        What is your <span class="italic text-emerald-300">Goal?</span>
      </h2>
      <p class="text-emerald-100/70 text-sm md:text-base mt-4 max-w-lg mx-auto">Select your primary objective to discover the perfect Spirulina formulation for your body.</p>
    </div>

    {/* The Goal Cards (Scroll Swiper on mobile, Elegant Grid on Desktop) */}
    <div class="flex overflow-x-auto snap-x snap-mandatory md:grid md:grid-cols-3 gap-6 lg:gap-8 pb-8 md:pb-0 scroll-smooth no-scrollbar">
      
      {/* Goal 1: Pure Energy */}
      <a href="#apothecary-quiz" data-goal-select="energy" class="group relative bg-white/5 hover:bg-white/10 border border-white/10 hover:border-emerald-500/30 rounded-3xl p-8 transition-all duration-500 flex flex-col items-center text-center overflow-hidden h-full w-[85vw] sm:w-[50vw] md:w-auto shrink-0 snap-center">
        <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#166534]/20 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        
        {/* Crisp circular realworld micro-image with glowing ring */}
        <div class="relative w-20 h-20 rounded-full overflow-hidden mb-6 border-2 border-emerald-500/25 group-hover:border-emerald-400 group-hover:scale-110 transition-all duration-500 shadow-lg z-10 shrink-0">
          <Image src="/sujata_goal_energy.png" alt="Pure Energy & Focus" width={80} height={80} class="w-full h-full object-cover" />
        </div>
        
        <h3 class="text-xl md:text-2xl font-bold text-white mb-3 relative z-10">Pure Energy & Focus</h3>
        <p class="text-emerald-100/60 text-sm mb-8 relative z-10 leading-relaxed">Beat the afternoon crash. Formulations designed for immediate cognitive clarity and sustained physical stamina.</p>
        <span class="mt-auto text-emerald-400 text-xs font-bold uppercase tracking-widest flex items-center gap-2 group-hover:gap-3 transition-all relative z-10">
          Start Quiz Recommendation
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </span>
      </a>

      {/* Goal 2: Cellular Immunity */}
      <a href="#apothecary-quiz" data-goal-select="immunity" class="group relative bg-white/5 hover:bg-white/10 border border-white/10 hover:border-emerald-500/30 rounded-3xl p-8 transition-all duration-500 flex flex-col items-center text-center overflow-hidden h-full w-[85vw] sm:w-[50vw] md:w-auto shrink-0 snap-center">
        <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#166534]/20 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        
        {/* Crisp circular realworld micro-image with glowing ring */}
        <div class="relative w-20 h-20 rounded-full overflow-hidden mb-6 border-2 border-emerald-500/25 group-hover:border-emerald-400 group-hover:scale-110 transition-all duration-500 shadow-lg z-10 shrink-0">
          <Image src="/sujata_goal_immunity.png" alt="Controlled Close-Pond Aquaculture" width={80} height={80} class="w-full h-full object-cover" />
        </div>
        
        <h3 class="text-xl md:text-2xl font-bold text-white mb-3 relative z-10">Gut & Immunity</h3>
        <p class="text-emerald-100/60 text-sm mb-8 relative z-10 leading-relaxed">Deep cellular repair. Cold-pressed capsules that restore gut micro-biome and fortify your immune defense.</p>
        <span class="mt-auto text-[#00E676] text-xs font-bold uppercase tracking-widest flex items-center gap-2 group-hover:gap-3 transition-all relative z-10">
          Start Quiz Recommendation
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </span>
      </a>

      {/* Goal 3: Skin & Hair */}
      <a href="#apothecary-quiz" data-goal-select="beauty" class="group relative bg-white/5 hover:bg-white/10 border border-white/10 hover:border-emerald-500/30 rounded-3xl p-8 transition-all duration-500 flex flex-col items-center text-center overflow-hidden h-full w-[85vw] sm:w-[50vw] md:w-auto shrink-0 snap-center">
        <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#166534]/20 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        
        {/* Crisp circular realworld micro-image with glowing ring */}
        <div class="relative w-20 h-20 rounded-full overflow-hidden mb-6 border-2 border-emerald-500/25 group-hover:border-emerald-400 group-hover:scale-110 transition-all duration-500 shadow-lg z-10 shrink-0">
          <Image src="/sujata_goal_beauty.png" alt="Organic Skin & Hair Purity" width={80} height={80} class="w-full h-full object-cover" />
        </div>
        
        <h3 class="text-xl md:text-2xl font-bold text-white mb-3 relative z-10">Skin & Hair Health</h3>
        <p class="text-emerald-100/60 text-sm mb-8 relative z-10 leading-relaxed">External application meets internal purity. Stop hair fall and detoxify your skin with raw topical solutions.</p>
        <span class="mt-auto text-[#00E676] text-xs font-bold uppercase tracking-widest flex items-center gap-2 group-hover:gap-3 transition-all relative z-10">
          Start Quiz Recommendation
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </span>
      </a>

    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const goalLinks = document.querySelectorAll('[data-goal-select]');
    goalLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const goalValue = link.getAttribute('data-goal-select');
        const targetQuiz = document.getElementById('apothecary-quiz');
        if (targetQuiz) {
          // Scroll smoothly to the quiz
          targetQuiz.scrollIntoView({ behavior: 'smooth', block: 'center' });
          
          // Wait briefly for scroll to finish, then select the quiz option
          setTimeout(() => {
            // Find option and click it
            const quizOption = targetQuiz.querySelector(`.quiz-option[data-value="${goalValue}"][data-step="1"]`) as HTMLElement;
            if (quizOption) {
              const restartBtn = document.getElementById('quiz-restart') as HTMLElement;
              const step2 = document.getElementById('quiz-step-2') as HTMLElement;
              const step3 = document.getElementById('quiz-step-3') as HTMLElement;
              const resultStep = document.getElementById('quiz-result') as HTMLElement;

              if (restartBtn && (!step2.classList.contains('hidden') || !step3.classList.contains('hidden') || !resultStep.classList.contains('hidden'))) {
                restartBtn.click();
              }

              // Click the selected option
              quizOption.click();
            }
          }, 600);
        }
      });
    });
  });
</script>