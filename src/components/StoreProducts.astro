                <span class="absolute top-[30%] right-[0%] bg-white/90 backdrop-blur-md border border-gray-100 px-3 py-1.5 rounded-full text-[9px] font-bold uppercase tracking-widest text-amber-600 shadow-xl animate-[spin_15s_linear_infinite_reverse] flex items-center gap-1.5">
