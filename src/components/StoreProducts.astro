              class="relative z-20 w-auto h-[180px] object-contain drop-shadow-[0_20px_40px_rgba(0,0,0,0.6)] group-hover/img:scale-105 group-hover/img:-translate-y-2 transition-transform duration-700 mb-0 mx-auto"
            />
          </a>

          <div class="relative z-20 w-full flex-1 flex flex-col items-center justify-center pt-6 pointer-events-none">
            <div class="flex items-center gap-1 mb-2">
               {[...Array(5)].map((_) => (
                  <svg class="w-3 h-3 text-[#F59E0B] fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                ))}
            </div>

            <a href={`/product/${acceleratorProduct.handle}`} class="hover:text-emerald-400 transition-colors pointer-events-auto">
              <h3 class="text-2xl font-['Playfair_Display'] font-bold text-white mb-2 text-center line-clamp-1">
                {acceleratorProduct.title}
              </h3>
            </a>
            
            <p class="text-gray-400 text-xs text-center line-clamp-2 max-w-[220px]">
              {acceleratorProduct.description || "Perfect for on-the-go energy and cellular repair."}
            </p>
          </div>

          <div class="relative z-10 w-full mt-auto pt-5 border-t border-white/10 flex items-center justify-between">
            <div class="flex flex-col">
              <span class="text-gray-500 text-[10px] line-through decoration-gray-600">
                {formatPrice(Number(acceleratorProduct.priceRange.minVariantPrice.amount) * 1.2)}
              </span>
              <span class="text-xl font-bold text-white">
                {formatPrice(acceleratorProduct.priceRange.minVariantPrice.amount)}
              </span>
            </div>
            
            <button class="add-to-cart-btn bg-white/10 hover:bg-white text-white hover:text-[#111827] border border-white/20 hover:border-white font-bold text-xs uppercase tracking-wider px-5 py-2.5 rounded-full transition-all duration-300 flex items-center gap-2 group/add"
              data-title={acceleratorProduct.title} 
              data-price={acceleratorProduct.priceRange.minVariantPrice.amount}
              data-variant-id={acceleratorProduct.variants?.edges[0]?.node?.id}
              data-image={getImageUrl(acceleratorProduct)}>
              Quick Add
              <svg class="w-3.5 h-3.5 transform group-hover/add:rotate-90 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"></path></svg>
            </button>
          </div>
        </div>
      )}

      {/* -------------------------------------------------------------------------------- */}
      {/* BENTO ITEM 3: TRAVEL PACK */}
      {/* -------------------------------------------------------------------------------- */}
      {travelPack && (
        <div class="group relative md:col-span-6 lg:col-span-6 bg-white rounded-[2rem] p-8 border border-black/[0.03] shadow-[0_15px_30px_rgba(0,0,0,0.02)] hover:shadow-[0_20px_40px_rgba(0,0,0,0.06)] transition-all duration-500 overflow-hidden flex flex-col md:flex-row items-center gap-6 h-[auto] min-h-[250px]">
          <a href={`/product/${travelPack.handle}`} class="w-2/5 sm:w-1/3 md:w-1/3 flex-shrink-0 flex items-center justify-center relative block">
            <div class="absolute inset-0 bg-gray-50 rounded-full blur-xl group-hover:bg-[#f0fdf4] transition-colors duration-500 pointer-events-none"></div>
            <img src={getImageUrl(travelPack)} alt={travelPack.title} loading="lazy" decoding="async" class="relative z-10 h-[110px] md:h-[130px] lg:h-[150px] object-contain group-hover:-translate-y-1 transition-transform duration-500 mx-auto"/>
          </a>
          <div class="flex-1 min-w-0 flex flex-col text-center md:text-left">
            <a href={`/product/${travelPack.handle}`} class="hover:text-[#166534] transition-colors">
              <h3 class="text-lg md:text-xl font-bold text-[#111827] mb-2">{travelPack.title}</h3>
            </a>
            <p class="text-gray-500 text-sm mb-4 line-clamp-2">{travelPack.description || "Perfect for on-the-go energy."}</p>
            <div class="mt-auto flex items-center justify-center md:justify-start gap-4">
              <span class="text-lg font-black text-[#111827]">{formatPrice(travelPack.priceRange.minVariantPrice.amount)}</span>
              <button class="add-to-cart-btn text-[#166534] font-bold text-sm hover:text-[#111827] underline decoration-2 underline-offset-4 transition-colors"
                data-title={travelPack.title}
                data-price={travelPack.priceRange.minVariantPrice.amount}
                data-variant-id={travelPack.variants?.edges[0]?.node?.id}
                data-image={getImageUrl(travelPack)}>
                Add to Cart
              </button>
            </div>
          </div>
        </div>
      )}

      {/* -------------------------------------------------------------------------------- */}
      {/* BENTO ITEM 4: THE RITUAL BUNDLE */}
      {/* -------------------------------------------------------------------------------- */}
      {ritualBundle && (
        <div class="group relative md:col-span-6 lg:col-span-6 bg-white rounded-[2rem] p-8 border border-black/[0.03] shadow-[0_15px_30px_rgba(0,0,0,0.02)] hover:shadow-[0_20px_40px_rgba(0,0,0,0.06)] transition-all duration-500 overflow-hidden flex flex-col md:flex-row items-center gap-6 h-[auto] min-h-[250px]">
          <a href={`/product/${ritualBundle.handle}`} class="w-2/5 sm:w-1/3 md:w-1/3 flex-shrink-0 flex items-center justify-center relative block">
            <div class="absolute inset-0 bg-gray-50 rounded-full blur-xl group-hover:bg-[#f0fdf4] transition-colors duration-500 pointer-events-none"></div>
            <img src={getImageUrl(ritualBundle)} alt={ritualBundle.title} loading="lazy" decoding="async" class="relative z-10 h-[110px] md:h-[130px] lg:h-[150px] object-contain group-hover:-translate-y-1 transition-transform duration-500 mx-auto"/>
          </a>
          <div class="flex-1 min-w-0 flex flex-col text-center md:text-left">
            <span class="text-[10px] font-bold uppercase tracking-wider text-[#166534] mb-1">Premium Option</span>
            <a href={`/product/${ritualBundle.handle}`} class="hover:text-[#166534] transition-colors">
              <h3 class="text-lg md:text-xl font-bold text-[#111827] mb-2">{ritualBundle.title}</h3>
            </a>
            <div class="mt-auto flex items-center justify-center md:justify-start gap-4 pt-4">
              <span class="text-lg font-black text-[#111827]">{formatPrice(ritualBundle.priceRange.minVariantPrice.amount)}</span>
              <button class="add-to-cart-btn text-[#166534] font-bold text-sm hover:text-[#111827] underline decoration-2 underline-offset-4 transition-colors"
                data-title={ritualBundle.title}
                data-price={ritualBundle.priceRange.minVariantPrice.amount}
                data-variant-id={ritualBundle.variants?.edges[0]?.node?.id}
                data-image={getImageUrl(ritualBundle)}>
                Add to Cart
              </button>
            </div>
          </div>
        </div>
      )}

    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // UI Elements
    const cartBtns = document.querySelectorAll('.add-to-cart-btn');
    const drawer = document.getElementById('cart-drawer');
    const overlay = document.getElementById('cart-overlay');
    const closeBtn = document.getElementById('close-cart-btn');
    const checkoutBtn = document.querySelector('#cart-drawer button.group');
    const cartItemsContainer = document.getElementById('cart-items-container');
    const drawerCartBadge = document.getElementById('cart-count-badge');
    const headerCartBadge = document.getElementById('header-cart-badge');
    const headerCartBtn = document.getElementById('cart-drawer-trigger');
    const cartSubtotal = document.getElementById('cart-subtotal');

    // Shopify Credentials
    const domain = 'skadas-headless-demo.myshopify.com';
    const storefrontToken = '32f678c5f8d1345e945ed48713d9cf2f';

    // UI Toggles
    const openCart = () => {
      overlay.classList.remove('opacity-0', 'pointer-events-none');
      overlay.classList.add('opacity-100');
      drawer.classList.remove('translate-x-[100%]');
      drawer.classList.add('translate-x-0');
      document.body.style.overflow = 'hidden'; 
    };

    const closeCart = () => {
      overlay.classList.remove('opacity-100');
      overlay.classList.add('opacity-0', 'pointer-events-none');
      drawer.classList.remove('translate-x-0');
      drawer.classList.add('translate-x-[100%]');
      document.body.style.overflow = '';
    };

    closeBtn?.addEventListener('click', closeCart);
    overlay?.addEventListener('click', closeCart);
    headerCartBtn?.addEventListener('click', (e) => {
      e.preventDefault();
      openCart();
    });

    // 🌟 1. SHOPIFY API FETCHER
    async function shopifyFetch(query, variables) {
      const response = await fetch(`https://${domain}/api/2024-01/graphql.json`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Shopify-Storefront-Access-Token': storefrontToken,
        },
        body: JSON.stringify({ query, variables }),
      });
      return await response.json();
    }

    // Common Cart Data Structure needed from Shopify
    const cartFragment = `
      id checkoutUrl totalQuantity
      cost { totalAmount { amount } }
      lines(first: 10) {
        edges {
          node {
            id quantity
            merchandise {
              ... on ProductVariant {
                id title image { url } price { amount } product { title }
              }
            }
          }
        }
      }
    `;

    // 🌟 4. RENDER CART DYNAMICALLY (Upgraded with AOV Maximizer)
    function renderCartUI(cart) {
      if (!cart) return;

      const count = cart.totalQuantity || 0;
      if (drawerCartBadge) drawerCartBadge.innerText = count;
      if (headerCartBadge) {
        headerCartBadge.innerText = count;
        headerCartBadge.style.display = count > 0 ? 'flex' : 'none';
      }

      const currentTotal = cart.cost?.totalAmount?.amount || 0;
      const formatPrice = new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(currentTotal);
      if (cartSubtotal) cartSubtotal.innerText = formatPrice;

      if (checkoutBtn && cart.checkoutUrl) checkoutBtn.onclick = () => window.location.href = cart.checkoutUrl;

      cartItemsContainer.innerHTML = '';

      if (count === 0) {
        cartItemsContainer.innerHTML = `<div class="text-center py-10 text-gray-600 font-medium">Your routine is empty.</div>`;
        return;
      }

      // 🌟 NEW: THE FREE SHIPPING PROGRESS BAR (Gamification)
      const shippingThreshold = 2000; // ₹2000 ला फ्री शिपिंग
      const amountRemaining = shippingThreshold - currentTotal;
      const progressPercent = Math.min((currentTotal / shippingThreshold) * 100, 100);
      
      let shippingHTML = '';

      if (amountRemaining > 0) {
        // Not reached yet
        shippingHTML = `
          <div class="mb-5 bg-gray-50 p-4 rounded-2xl border border-gray-100 relative overflow-hidden group">
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white to-transparent opacity-50 translate-x-[-100%] group-hover:animate-[shimmer_1.5s_infinite]"></div>
            <p class="text-[11px] font-bold text-gray-800 text-center mb-3 tracking-wide">
              You're only <span class="text-[#166534] text-sm font-black">₹${amountRemaining}</span> away from <span class="uppercase tracking-widest border-b border-[#166534]">Free Shipping</span> 🚚
            </p>
            <div class="w-full h-2.5 bg-gray-200 rounded-full overflow-hidden shadow-inner">
              <div class="h-full bg-[#111827] rounded-full transition-all duration-700 ease-out relative" style="width: ${progressPercent}%">
                 <div class="absolute inset-0 bg-[linear-gradient(45deg,transparent_25%,rgba(255,255,255,0.2)_25%,rgba(255,255,255,0.2)_50%,transparent_50%,transparent_75%,rgba(255,255,255,0.2)_75%,rgba(255,255,255,0.2)_100%)] bg-[length:1rem_1rem] animate-[stripe_1s_linear_infinite]"></div>
              </div>
            </div>
          </div>
        `;
      } else {
        // Goal Reached!
        shippingHTML = `
          <div class="mb-5 bg-[#f0fdf4] p-4 rounded-2xl border border-emerald-200 animate-[pulse_2s_ease-in-out_1]">
            <p class="text-xs font-black text-[#166534] text-center uppercase tracking-widest flex items-center justify-center gap-2">
              <span class="w-2 h-2 bg-emerald-500 rounded-full animate-ping"></span>
              Free Shipping Unlocked! 🎉
            </p>
            <div class="w-full h-1.5 bg-emerald-200 rounded-full overflow-hidden mt-3">
              <div class="h-full bg-emerald-500 transition-all duration-700 ease-out" style="width: 100%"></div>
            </div>
          </div>
        `;
      }

      // ॲनिमेशनसाठी CSS लावणं (जर आधी नसेल तर)
      if (!document.getElementById('shipping-styles')) {
        const style = document.createElement('style');
        style.id = 'shipping-styles';
        style.innerHTML = `
          @keyframes stripe { from { background-position: 1rem 0; } to { background-position: 0 0; } }
          @keyframes shimmer { 100% { transform: translateX(100%); } }
        `;
        document.head.appendChild(style);
      }

      // Insert Shipping Bar first
      cartItemsContainer.insertAdjacentHTML('beforeend', shippingHTML);

      // Loop through cart items
      cart.lines.edges.forEach(({ node }) => {
        const product = node.merchandise.product;
        const variant = node.merchandise;
        const itemPrice = new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(variant.price.amount);
        const imageUrl = variant.image?.url || '/spirulina-bottle.png';

        const itemHTML = `
          <div class="flex gap-4 p-4 bg-white rounded-2xl shadow-sm border border-gray-50 mb-4 animate-[fadeInUp_0.5s_ease-out]">
            <div class="w-20 h-24 bg-[#f0fdf4] rounded-xl flex items-center justify-center p-2 relative">
              <div id="loader-${node.id}" class="absolute inset-0 bg-white/80 backdrop-blur-sm hidden flex-center justify-center items-center rounded-xl z-10">
                <div class="w-4 h-4 border-2 border-[#166534] border-t-transparent rounded-full animate-spin mt-10 ml-8"></div>
              </div>
              <img src="${imageUrl}" alt="${product.title}" class="w-full h-full object-contain drop-shadow-md"/>
            </div>
            <div class="flex-1 flex flex-col justify-between py-1">
              <div>
                <h3 class="text-sm font-bold text-[#111827] line-clamp-1">${product.title}</h3>
                <p class="text-[10px] uppercase tracking-wider text-gray-600 font-semibold mt-1">${variant.title !== 'Default Title' ? variant.title : 'Pure Form'}</p>
              </div>
              <div class="flex items-center justify-between mt-3">
                <div class="flex items-center gap-3 bg-gray-50 rounded-full px-2 py-1 border border-gray-100">
                  <button class="qty-btn w-5 h-5 flex items-center justify-center text-gray-500 hover:text-black font-bold" data-line-id="${node.id}" data-action="decrease" data-current="${node.quantity}">-</button>
                  <span class="text-xs font-bold text-[#111827] w-3 text-center">${node.quantity}</span>
                  <button class="qty-btn w-5 h-5 flex items-center justify-center text-gray-500 hover:text-black font-bold" data-line-id="${node.id}" data-action="increase" data-current="${node.quantity}">+</button>
                </div>
                <span class="text-sm font-black text-[#111827]">${itemPrice}</span>
              </div>
            </div>
          </div>
        `;
        cartItemsContainer.insertAdjacentHTML('beforeend', itemHTML);
      });

      attachQuantityListeners();
    }

    // 🌟 3. CART ACTIONS (Create, Add, Fetch)
    async function initCart() {
      const cartId = localStorage.getItem('sujata_cart_id');
      if (cartId) {
        const query = `query { cart(id: "${cartId}") { ${cartFragment} } }`;
        const res = await shopifyFetch(query);
        if (res.data?.cart) renderCartUI(res.data.cart);
        else localStorage.removeItem('sujata_cart_id'); // Cart expired
      }
    }

    async function addProductToCart(variantId) {
      let cartId = localStorage.getItem('sujata_cart_id');

      if (!cartId) {
        // Create new cart
        const query = `mutation cartCreate($input: CartInput!) { cartCreate(input: $input) { cart { ${cartFragment} } } }`;
        const res = await shopifyFetch(query, { input: { lines: [{ merchandiseId: variantId, quantity: 1 }] } });
        const cart = res.data.cartCreate.cart;
        localStorage.setItem('sujata_cart_id', cart.id);
        return cart;
      } else {
        // Add to existing
        const query = `mutation cartLinesAdd($cartId: ID!, $lines: [CartLineInput!]!) { cartLinesAdd(cartId: $cartId, lines: $lines) { cart { ${cartFragment} } } }`;
        const res = await shopifyFetch(query, { cartId: cartId, lines: [{ merchandiseId: variantId, quantity: 1 }] });
        if (res.errors) { localStorage.removeItem('sujata_cart_id'); return addProductToCart(variantId); }
        return res.data.cartLinesAdd.cart;
      }
    }

    // 🌟 4. QUANTITY UPDATE LOGIC (+ / -)
    async function updateQuantity(lineId, newQuantity) {
      const cartId = localStorage.getItem('sujata_cart_id');
      if(!cartId) return;

      // Show tiny loader on product image
      const loader = document.getElementById(`loader-${lineId}`);
      if(loader) loader.classList.remove('hidden');

      let query, variables;

      if (newQuantity === 0) {
        // Remove item
        query = `mutation cartLinesRemove($cartId: ID!, $lineIds: [ID!]!) { cartLinesRemove(cartId: $cartId, lineIds: $lineIds) { cart { ${cartFragment} } } }`;
        variables = { cartId, lineIds: [lineId] };
      } else {
        // Update quantity
        query = `mutation cartLinesUpdate($cartId: ID!, $lines: [CartLineUpdateInput!]!) { cartLinesUpdate(cartId: $cartId, lines: $lines) { cart { ${cartFragment} } } }`;
        variables = { cartId, lines: [{ id: lineId, quantity: newQuantity }] };
      }

      const res = await shopifyFetch(query, variables);
      const cart = res.data.cartLinesUpdate?.cart || res.data.cartLinesRemove?.cart;
      if (cart) renderCartUI(cart);
    }

    function attachQuantityListeners() {
      document.querySelectorAll('.qty-btn').forEach(btn => {
        btn.addEventListener('click', function() {
          const lineId = this.getAttribute('data-line-id');
          const currentQty = parseInt(this.getAttribute('data-current'));
          const action = this.getAttribute('data-action');
          const newQty = action === 'increase' ? currentQty + 1 : currentQty - 1;
          updateQuantity(lineId, newQty);
        });
      });
    }

    // 🌟 5. MAIN ADD TO ROUTINE EVENT
    cartBtns.forEach(btn => {
      btn.addEventListener('click', async function(e) {
        e.preventDefault();
        const button = this;
        const originalHTML = button.innerHTML;
        const variantId = button.getAttribute('data-variant-id');
        
        button.classList.add('pointer-events-none', '!bg-[#166534]');
        button.innerHTML = `<svg class="animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> AUTHORIZING...`;

        try {
          const cart = await addProductToCart(variantId);
          renderCartUI(cart); // Automatically updates drawer, header badge, and subtotal

          button.innerHTML = `<svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg> ADDED TO ROUTINE`;

          setTimeout(() => {
            openCart();
            setTimeout(() => {
              button.innerHTML = originalHTML;
              button.classList.remove('pointer-events-none', '!bg-[#166534]');
            }, 1000);
          }, 500);
        } catch (error) {
          console.error("Cart Error:", error);
          button.innerHTML = `ERROR`;
          setTimeout(() => { button.innerHTML = originalHTML; button.classList.remove('pointer-events-none', '!bg-[#166534]'); }, 2000);
        }
      });
    });

    // Run on page load
    initCart();
  });
</script>