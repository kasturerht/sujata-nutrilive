                <span class="absolute bottom-[20%] left-[5%] bg-white/90 backdrop-blur-md border border-gray-100 px-3 py-1.5 rounded-full text-[9px] font-bold uppercase tracking-widest text-teal-700 shadow-xl animate-[spin_15s_linear_infinite_reverse] flex items-center gap-1.5">
                  <span class="w-1.5 h-1.5 rounded-full bg-teal-500 animate-pulse"></span> 60% Protein
                </span>
              </div>
            </div>

            {/* Glowing Background */}
            <div class="absolute w-[90%] h-[90%] bg-[#f0fdf4] rounded-full blur-[60px] opacity-70 group-hover/img:scale-110 transition-transform duration-700 z-0 pointer-events-none"></div>
            <div class="absolute bottom-[10%] w-[60%] h-6 bg-black/10 blur-xl rounded-[100%] z-0 pointer-events-none"></div>
            
            {/* The Image */}
            <img
              src={getImageUrl(heroProduct)}
              alt={heroProduct.title}
              fetchpriority="high"
              decoding="async"
              class="relative z-20 w-auto h-full max-h-[110%] md:max-h-[130%] object-contain drop-shadow-[0_30px_40px_rgba(0,0,0,0.2)] group-hover/img:scale-105 group-hover/img:-translate-y-3 transition-all duration-700 ease-[cubic-bezier(0.1,0,0,1)]"
            />
          </a>
        </div>
