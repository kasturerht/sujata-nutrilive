      {/* -------------------------------------------------------------------------------- */}
      {/* BENTO ITEM 2: THE ACCELERATOR (Dark Card) */}
      {/* -------------------------------------------------------------------------------- */}
      {acceleratorProduct && (
        <div class="group relative md:col-span-6 lg:col-span-4 bg-[#111827] rounded-[2rem] p-8 shadow-[0_20px_40px_rgba(17,24,39,0.2)] transition-all duration-700 overflow-hidden flex flex-col h-auto min-h-[420px] md:h-[420px] lg:h-[480px] border border-white/5 hover:border-[#166534]/30">
          
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,#166534_0%,transparent_70%)] opacity-20 group-hover:opacity-40 transition-opacity duration-700 pointer-events-none"></div>

          {/* Top Tag */}
          <div class="relative z-10 w-full flex justify-center mb-4">
            <span class="bg-emerald-500/10 text-emerald-400 text-[9px] font-bold uppercase tracking-widest px-3 py-1 rounded-full border border-emerald-500/20">Daily Essential</span>
          </div>

          {/* THE Hyper-Contained IMAGE CONTAINER (Linked to PDP) */}
          <a href={`/product/${acceleratorProduct.handle}`} class="relative z-10 w-full h-[250px] flex items-center justify-center group/img block">
            <div class="absolute inset-0 z-10 pointer-events-none opacity-0 group-hover/img:opacity-100 transition-opacity duration-700">
              <div class="absolute inset-0 animate-[spin_12s_linear_infinite_reverse]">
                <span class="absolute top-[10%] left-[5%] bg-white/10 backdrop-blur-md border border-white/20 px-3 py-1.5 rounded-full text-[9px] font-bold uppercase tracking-widest text-white shadow-2xl animate-[spin_12s_linear_infinite] flex items-center gap-1.5">
