---
// src/components/StoreProducts.astro

// 1. Shopify API Configuration (Added for Direct Checkout)
const shopifyDomain = import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_DOMAIN;
const storefrontToken = import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_TOKEN;

// 2. Shopify Data
const { products = [] } = Astro.props; 

// 3. Formatting Tools
const formatPrice = (amount) => {
  if (!amount) return '';
  return new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(amount);
};

const calculateSavings = (amount) => {
  if (!amount) return { old: '', saved: '' };
  const numAmount = Number(amount);
  const oldPrice = numAmount * 1.35; 
  const saved = oldPrice - numAmount;
  return {
    old: formatPrice(oldPrice),
    saved: formatPrice(saved)
  };
};

const getImageUrl = (product) => {
  return product?.images?.edges[0]?.node?.url || '/spirulina-bottle.png';
};

// 4. ULTRA-PREMIUM CONVERSION TAGS
const conversionData = [
  { 
    tag: "★ Bestseller", 
    tagClass: "bg-[#111827]/90 text-[#F59E0B] border-[#F59E0B]/30", 
    benefit: "⚡ Energy & Focus", 
    badge: "60% Protein" 
  },
  { 
    tag: "Bundled Offer", 
    tagClass: "bg-[#166534]/90 text-emerald-100 border-emerald-400/30", 
    benefit: "🛡️ Cellular Immunity", 
    badge: "Cold Pressed" 
  },
  { 
    tag: "Ultimate Value", 
    tagClass: "bg-[#78350F]/90 text-amber-100 border-amber-500/30", 
    benefit: "🦠 Gut Health", 
    badge: "Zero Toxins" 
  },
  { 
    tag: "Trial Pack", 
    tagClass: "bg-[#4C1D95]/90 text-purple-100 border-purple-400/30", 
    benefit: "✨ Skin & Hair", 
    badge: "Pure Extract" 
  }
];
---

<section id="product-ecosystem" class="relative z-10 bg-[#F9FAFB] pt-16 md:pt-24 pb-24 lg:pb-32 font-['Inter'] selection:bg-[#166534] selection:text-white">
  
  <div class="max-w-[90rem] mx-auto px-5 md:px-6 lg:px-12 relative z-10">
    
    {/* ==========================================
        THE SPLIT HEADER (Ultra Pro Max Luxury)
        ========================================== */}
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 md:gap-10 mb-12 md:mb-16">
      
      {/* LEFT SIDE: The Editorial Titles */}
      <div class="flex flex-col items-start text-left">
        <span class="text-[#166534] text-[10px] md:text-xs font-black uppercase tracking-[0.3em] mb-3 block">Engineered for Performance</span>
        <h2 class="text-4xl md:text-5xl lg:text-[3.5rem] font-['Playfair_Display'] font-black text-[#111827] tracking-tight leading-none">
          Choose Your <span class="italic text-[#166534]">Routine.</span>
        </h2>
      </div>

      {/* RIGHT SIDE: The Sleek Trust Pill */}
      <div class="inline-flex flex-wrap items-center gap-3 lg:gap-5 bg-white/80 backdrop-blur-xl border border-gray-200/60 shadow-[0_8px_30px_rgba(0,0,0,0.04)] px-5 py-3 rounded-2xl md:rounded-full self-start md:self-auto">
        
        {/* Trust 1 */}
        <div class="flex items-center gap-2 group cursor-default">
          <svg class="w-3.5 h-3.5 md:w-4 md:h-4 text-[#166534] group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          <span class="text-[9px] lg:text-[10px] font-bold text-gray-500 group-hover:text-gray-800 transition-colors uppercase tracking-widest">FSSAI Approved</span>
        </div>

        {/* Minimal Dot Divider */}
        <div class="w-1 h-1 rounded-full bg-gray-300"></div>

        {/* Trust 2 */}
        <div class="flex items-center gap-2 group cursor-default">
           <svg class="w-3.5 h-3.5 md:w-4 md:h-4 text-[#166534] group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
           <span class="text-[9px] lg:text-[10px] font-bold text-gray-500 group-hover:text-gray-800 transition-colors uppercase tracking-widest">GMP Certified</span>
        </div>

        {/* Minimal Dot Divider */}
        <div class="hidden sm:block w-1 h-1 rounded-full bg-gray-300"></div>

        {/* Trust 3 */}
        <div class="hidden sm:flex items-center gap-2 group cursor-default">
          <svg class="w-3.5 h-3.5 md:w-4 md:h-4 text-[#166534] group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          <span class="text-[9px] lg:text-[10px] font-bold text-gray-500 group-hover:text-gray-800 transition-colors uppercase tracking-widest">100% Organic</span>
        </div>

      </div>

    </div>

    {/* ==========================================
        THE SALES GRID (The God Level Conversion Engine)
        ========================================== */}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
      
      {products.slice(0, 4).map((edge, index) => {
        const product = edge.node;
        const priceAmount = product.priceRange.minVariantPrice.amount;
        const pricing = calculateSavings(priceAmount);
        const meta = conversionData[index] || conversionData[0];

        return (
          <div class="group relative bg-white rounded-[2rem] shadow-[0_4px_20px_rgba(0,0,0,0.03)] hover:shadow-[0_40px_80px_rgba(22,101,52,0.08)] transition-all duration-500 flex flex-col overflow-hidden border border-gray-100 hover:border-[#166534]/20 h-full">
            
            {/* TOP HALF: STUDIO IMAGE */}
            <a href={`/product/${product.handle}`} class="relative w-full h-[280px] md:h-[320px] bg-[#F8FAFC] flex items-center justify-center p-6 block overflow-hidden">
              
              <div class={`absolute top-4 md:top-5 left-4 md:left-5 ${meta.tagClass} backdrop-blur-md px-3 py-1.5 rounded-full border shadow-lg z-20 transition-transform group-hover:scale-105`}>
                <span class="text-[9px] font-black uppercase tracking-[0.15em]">{meta.tag}</span>
              </div>

              <div class="absolute top-4 md:top-5 right-4 md:right-5 bg-white/60 backdrop-blur-md border border-white px-2.5 py-1 rounded-md shadow-sm z-20">
                <span class="text-[9px] font-bold text-gray-600 uppercase tracking-widest">{meta.badge}</span>
              </div>

              <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.8)_0%,transparent_70%)] z-0 pointer-events-none"></div>
              <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[80%] h-[80%] bg-[#166534]/5 rounded-full blur-[40px] group-hover:bg-[#166534]/15 transition-colors duration-500 z-0"></div>

              <img 
                src={getImageUrl(product)} 
                alt={product.title} 
                class="relative z-10 w-auto h-full max-h-[85%] object-contain drop-shadow-[0_20px_40px_rgba(0,0,0,0.15)] group-hover:scale-110 group-hover:-translate-y-3 transition-all duration-700 ease-[cubic-bezier(0.16,1,0.3,1)]"
                loading={index < 2 ? "eager" : "lazy"}
              />
            </a>

            {/* BOTTOM HALF: EDITORIAL DETAILS */}
            <div class="p-5 md:p-8 flex flex-col flex-1 bg-white relative z-20">
              
              <div class="flex items-center gap-1.5 mb-3 md:mb-4">
                <div class="flex items-center gap-0.5">
                  {[...Array(5)].map(() => (
                    <svg class="w-3.5 h-3.5 text-[#D97706] fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                  ))}
                </div>
                <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-0.5">4.9 (1.2k)</span>
              </div>

              <a href={`/product/${product.handle}`} class="mb-2">
                 <h3 class="text-lg md:text-[1.35rem] font-black font-['Playfair_Display'] text-[#111827] leading-tight group-hover:text-[#166534] transition-colors">{product.title}</h3>
              </a>
              
              <div class="flex items-center gap-2 mb-5 md:mb-6">
                 <span class="w-1.5 h-1.5 rounded-full bg-[#166534]"></span>
                 <span class="text-xs font-semibold text-gray-500">{meta.benefit}</span>
               </div>

              <div class="mt-auto pt-5 md:pt-6 pb-5 md:pb-6 flex flex-col md:flex-row md:items-end justify-between gap-2 border-t border-gray-100">
                <div class="flex flex-col">
                   <div class="flex items-center gap-2 mb-1">
                    <span class="text-[11px] md:text-xs font-bold text-gray-400 line-through decoration-gray-300">{pricing.old}</span>
                    <span class="text-[9px] font-black text-[#166534] bg-[#f0fdf4] border border-emerald-100 px-2 py-0.5 rounded-sm uppercase tracking-widest">Save {pricing.saved}</span>
                  </div>
                  <span class="text-2xl md:text-3xl font-black text-[#111827] leading-none tracking-tight">{formatPrice(priceAmount)}</span>
                </div>
               </div>

              {/* THE DIRECT CHECKOUT BUTTON */}
              <button class="add-to-cart-btn relative w-full overflow-hidden bg-[#111827] text-white py-3.5 md:py-4 rounded-xl font-bold text-[11px] uppercase tracking-[0.2em] shadow-[0_10px_20px_rgba(17,24,39,0.08)] hover:shadow-[0_15px_30px_rgba(22,101,52,0.25)] transition-all duration-300 group/btn disabled:opacity-80 disabled:cursor-not-allowed"
                data-variant-id={product.variants?.edges[0]?.node?.id}
                data-domain={shopifyDomain}
                data-token={storefrontToken}
              >
                {/* Hover Background Effect */}
                <div class="absolute inset-0 bg-[#166534] translate-y-full group-hover/btn:translate-y-0 transition-transform duration-500 ease-[cubic-bezier(0.1,0,0,1)] z-0"></div>
                
                {/* Button Text */}
                <span class="btn-text relative z-10 flex items-center justify-center gap-3 transition-opacity duration-300">
                  Add To Routine
                  <svg class="w-4 h-4 transform group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                </span>

                {/* Loading Spinner (Hidden by default) */}
                <div class="btn-spinner absolute inset-0 z-10 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
                  <svg class="w-5 h-5 text-white animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                </div>
              </button>

            </div>
          </div>
         );
      })}

    </div>
  </div>
</section>
