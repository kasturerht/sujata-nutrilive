---
// src/components/StoreProducts.astro

// १. index.astro madhun alela data ithe catch kela
const { products = [] } = Astro.props; 

// २. Shopify chya list madhun pahile 4 products vegale kadhle
const heroProduct = products[0]?.node;       // Main motha daba
const acceleratorProduct = products[1]?.node; // Kala daba
const travelPack = products[2]?.node;         // Tisra daba
const ritualBundle = products[3]?.node;       // Chautha daba

// ३. Price la Indian Rupees (₹) madhe format karnyasathi function
const formatPrice = (amount) => {
  if (!amount) return '';
  return new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(amount);
};

// ४. Product chi image asel tar ti ghyaychi, nasel tar apli dummy image dakhvaychi
const getImageUrl = (product) => {
  return product?.images?.edges[0]?.node?.url || '/spirulina-bottle.png';
};
---

<section id="product-ecosystem" class="relative bg-[#FAF9F6] py-24 lg:py-32 font-['Inter'] overflow-hidden selection:bg-[#166534] selection:text-white">
  
  {/* Subtle Background Glows */}
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[80vw] h-[500px] bg-gradient-to-b from-[#e8f3ed]/50 to-transparent blur-[100px] pointer-events-none z-0"></div>

  <div class="max-w-[90rem] mx-auto px-5 md:px-6 lg:px-12 relative z-10">
    
    {/* Section Header */}
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 lg:mb-20 gap-6">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white border border-gray-200 shadow-sm mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-[#166534] animate-pulse"></span>
          <span class="text-[10px] md:text-xs font-bold tracking-[0.2em] uppercase text-gray-600">Pure Formulations</span>
        </div>
        <h2 class="text-[clamp(2.5rem,4vw,4.5rem)] font-['Playfair_Display'] font-black leading-[1.05] text-[#111827] tracking-tighter">
          Curated for your <br/> <span class="italic text-[#166534]">Absolute Peak.</span>
        </h2>
      </div>
      <div class="md:text-right">
        <p class="text-sm md:text-base text-gray-500 font-medium mb-4 max-w-sm">Every batch is lab-tested, cold-extracted, and engineered for maximum cellular absorption.</p>
      </div>
    </div>

    {/* THE EDITORIAL BENTO BOX GRID */}
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 lg:gap-8">

      {/* -------------------------------------------------------------------------------- */}
      {/* BENTO ITEM 1: THE ANCHOR PRODUCT (Ultra-Polished Hero Product) */}
      {/* -------------------------------------------------------------------------------- */}
      {heroProduct && (
        <div class="group relative md:col-span-12 lg:col-span-8 bg-white rounded-[2rem] p-8 md:p-12 border border-black/[0.04] shadow-[0_20px_50px_rgba(0,0,0,0.04)] hover:shadow-[0_30px_60px_rgba(22,101,52,0.08)] transition-all duration-700 overflow-hidden flex flex-col md:flex-row items-center justify-between gap-10 md:gap-0 h-auto md:h-[480px]">
          
          {/* Subtle Glass/Glow effect in background */}
          <div class="absolute inset-0 bg-gradient-to-br from-[#166534]/[0.03] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none z-0"></div>

          {/* LEFT SIDE: Product Details (Took 55% width to reduce empty space) */}
          <div class="relative z-10 w-full md:w-[55%] flex flex-col h-full justify-center order-2 md:order-1 pr-0 md:pr-10">
            
            {/* Tag */}
            <div class="flex items-center gap-2 mb-4">
              <span class="bg-amber-100/80 text-amber-800 text-[10px] font-black uppercase tracking-widest px-3 py-1.5 rounded-full border border-amber-200/50">Best Seller</span>
            </div>
            
            {/* DYNAMIC TITLE */}
            <h3 class="text-3xl md:text-[2.5rem] font-['Playfair_Display'] font-black text-[#111827] leading-[1.1] mb-4">
              {heroProduct.title}
            </h3>
            
            {/* DYNAMIC DESCRIPTION */}
            <p class="text-[#6B7280] text-sm md:text-base leading-relaxed mb-8 max-w-md line-clamp-3">
              {heroProduct.description || "100% raw, cold-pressed Spirulina. Packed with 60% bio-available protein to instantly supercharge your morning routine."}
            </p>
            
            {/* THE ACTION AREA: Price & Button Aligned Perfectly */}
            <div class="mt-auto pt-6 border-t border-gray-100 flex flex-col sm:flex-row sm:items-center justify-between gap-6">
              
              {/* Price Block */}
              <div class="flex flex-col">
                <span class="text-[9px] uppercase tracking-[0.2em] font-bold text-gray-400 mb-1">Your Price</span>
                <div class="flex items-center gap-3">
                  <span class="text-3xl md:text-4xl font-black text-[#111827] tracking-tight">
                    {formatPrice(heroProduct.priceRange.minVariantPrice.amount)}
                  </span>
                  {/* The Anchor / Fake Decoy Price (Assumes 20% more for visual effect) */}
                  <span class="text-sm font-bold text-gray-400 line-through decoration-gray-300 decoration-2">
                    {formatPrice(Number(heroProduct.priceRange.minVariantPrice.amount) * 1.2)}
                  </span>
                </div>
              </div>
              
              {/* The Button */}
              {/* THE ACTION AREA: Price & Button */}
<button class="add-to-cart-btn w-full sm:w-auto bg-[#111827] text-white font-bold text-xs uppercase tracking-widest px-8 py-4 rounded-full flex items-center justify-center gap-3 transition-all duration-300 hover:bg-[#166534] shadow-[0_10px_20px_rgba(0,0,0,0.1)] hover:shadow-[0_15px_30px_rgba(22,101,52,0.25)] hover:-translate-y-1 group/btn" 
  data-title={heroProduct.title} 
  data-price={heroProduct.priceRange.minVariantPrice.amount}>
  
  Add to Routine
  <svg class="w-4 h-4 transform group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"></path></svg>

</button>

            </div>
          </div>

          {/* RIGHT SIDE: Product Image (Took 45% width, centered better) */}
          <div class="relative z-10 w-full md:w-[45%] h-[300px] md:h-full flex items-center justify-center order-1 md:order-2">
            
            {/* Premium Glow & Shadow */}
            <div class="absolute w-[90%] h-[90%] bg-[#f0fdf4] rounded-full blur-[60px] opacity-70 group-hover:scale-110 transition-transform duration-700 z-0"></div>
            <div class="absolute bottom-[10%] w-[60%] h-6 bg-black/10 blur-xl rounded-[100%] z-0"></div>
            
            {/* DYNAMIC IMAGE */}
            <img 
              src={getImageUrl(heroProduct)} 
              alt={heroProduct.title} 
              class="relative z-20 w-auto h-full max-h-[110%] md:max-h-[130%] object-contain drop-shadow-[0_30px_40px_rgba(0,0,0,0.2)] group-hover:scale-105 group-hover:-translate-y-3 transition-all duration-700 ease-[cubic-bezier(0.1,0,0,1)]"
            />
            
            {/* Small Trust Badge on Image */}
            <div class="absolute top-[10%] right-[0%] bg-white/90 backdrop-blur-md px-3 py-1.5 rounded-lg shadow-lg border border-gray-100 flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-all duration-500 translate-x-4 group-hover:translate-x-0 z-30 pointer-events-none">
              <svg class="w-3 h-3 text-[#166534]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-[9px] font-bold text-gray-900 uppercase tracking-widest">In Stock</span>
            </div>

          </div>
        </div>
      )}

      {/* -------------------------------------------------------------------------------- */}
      {/* BENTO ITEM 2: THE ACCELERATOR (Dark Card) */}
      {/* -------------------------------------------------------------------------------- */}
      {acceleratorProduct && (
        <div class="group relative md:col-span-6 lg:col-span-4 bg-[#111827] rounded-[2rem] p-8 md:p-10 shadow-2xl transition-all duration-700 overflow-hidden flex flex-col items-center text-center h-[450px]">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,#166534_0%,transparent_70%)] opacity-30 group-hover:opacity-50 transition-opacity duration-700"></div>

          <div class="relative z-10 w-full flex-1 flex flex-col items-center justify-center">
            {/* DYNAMIC IMAGE */}
            <img 
              src={getImageUrl(acceleratorProduct)} 
              alt={acceleratorProduct.title} 
              class="w-auto h-[160px] object-contain drop-shadow-[0_20px_40px_rgba(0,0,0,0.5)] group-hover:scale-110 transition-transform duration-700 mb-6"
            />
            {/* DYNAMIC TITLE */}
            <h3 class="text-xl md:text-2xl font-['Playfair_Display'] font-bold text-white mb-2 line-clamp-2">
              {acceleratorProduct.title}
            </h3>
          </div>

          <div class="relative z-10 w-full mt-auto pt-6 border-t border-white/10 flex items-center justify-between">
            {/* DYNAMIC PRICE */}
            <span class="text-xl font-bold text-white">
              {formatPrice(acceleratorProduct.priceRange.minVariantPrice.amount)}
            </span>
            <button class="bg-white text-[#111827] font-bold text-xs uppercase tracking-wider px-5 py-2.5 rounded-full hover:bg-[#166534] hover:text-white transition-colors duration-300">
              Quick Add
            </button>
          </div>
        </div>
      )}

      {/* -------------------------------------------------------------------------------- */}
      {/* BENTO ITEM 3: TRAVEL PACK */}
      {/* -------------------------------------------------------------------------------- */}
      {travelPack && (
        <div class="group relative md:col-span-6 lg:col-span-6 bg-white rounded-[2rem] p-8 border border-black/[0.03] shadow-[0_15px_30px_rgba(0,0,0,0.02)] hover:shadow-[0_20px_40px_rgba(0,0,0,0.06)] transition-all duration-500 overflow-hidden flex flex-col md:flex-row items-center gap-6 h-[auto] min-h-[250px]">
          <div class="w-1/2 md:w-1/3 flex items-center justify-center relative">
            <div class="absolute inset-0 bg-gray-50 rounded-full blur-xl group-hover:bg-[#f0fdf4] transition-colors duration-500"></div>
            <img src={getImageUrl(travelPack)} alt={travelPack.title} class="relative z-10 h-[150px] object-contain group-hover:-translate-y-1 transition-transform duration-500"/>
          </div>
          <div class="w-full md:w-2/3 flex flex-col text-center md:text-left">
            <h3 class="text-lg md:text-xl font-bold text-[#111827] mb-2">{travelPack.title}</h3>
            <p class="text-gray-500 text-sm mb-4 line-clamp-2">{travelPack.description || "Perfect for on-the-go energy."}</p>
            <div class="mt-auto flex items-center justify-center md:justify-start gap-4">
              <span class="text-lg font-black text-[#111827]">{formatPrice(travelPack.priceRange.minVariantPrice.amount)}</span>
              <button class="text-[#166534] font-bold text-sm hover:text-[#111827] underline decoration-2 underline-offset-4 transition-colors">
                Add to Cart
              </button>
            </div>
          </div>
        </div>
      )}

      {/* -------------------------------------------------------------------------------- */}
      {/* BENTO ITEM 4: THE RITUAL BUNDLE */}
      {/* -------------------------------------------------------------------------------- */}
      {ritualBundle && (
        <div class="group relative md:col-span-6 lg:col-span-6 bg-white rounded-[2rem] p-8 border border-black/[0.03] shadow-[0_15px_30px_rgba(0,0,0,0.02)] hover:shadow-[0_20px_40px_rgba(0,0,0,0.06)] transition-all duration-500 overflow-hidden flex flex-col md:flex-row items-center gap-6 h-[auto] min-h-[250px]">
          <div class="w-1/2 md:w-1/3 flex items-center justify-center relative">
            <div class="absolute inset-0 bg-gray-50 rounded-full blur-xl group-hover:bg-[#f0fdf4] transition-colors duration-500"></div>
            <img src={getImageUrl(ritualBundle)} alt={ritualBundle.title} class="relative z-10 h-[150px] object-contain group-hover:-translate-y-1 transition-transform duration-500"/>
          </div>
          <div class="w-full md:w-2/3 flex flex-col text-center md:text-left">
            <span class="text-[10px] font-bold uppercase tracking-wider text-[#166534] mb-1">Premium Option</span>
            <h3 class="text-lg md:text-xl font-bold text-[#111827] mb-2">{ritualBundle.title}</h3>
            <div class="mt-auto flex items-center justify-center md:justify-start gap-4 pt-4">
              <span class="text-lg font-black text-[#111827]">{formatPrice(ritualBundle.priceRange.minVariantPrice.amount)}</span>
              <button class="text-[#166534] font-bold text-sm hover:text-[#111827] underline decoration-2 underline-offset-4 transition-colors">
                Add to Cart
              </button>
            </div>
          </div>
        </div>
      )}

    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const cartBtns = document.querySelectorAll('.add-to-cart-btn');
    const drawer = document.getElementById('cart-drawer');
    const overlay = document.getElementById('cart-overlay');
    const closeBtn = document.getElementById('close-cart-btn');

    const openCart = () => {
      overlay.classList.remove('opacity-0', 'pointer-events-none');
      overlay.classList.add('opacity-100');
      drawer.classList.remove('translate-x-[100%]');
      drawer.classList.add('translate-x-0');
      document.body.style.overflow = 'hidden'; 
    };

    const closeCart = () => {
      overlay.classList.remove('opacity-100');
      overlay.classList.add('opacity-0', 'pointer-events-none');
      drawer.classList.remove('translate-x-0');
      drawer.classList.add('translate-x-[100%]');
      document.body.style.overflow = '';
    };

    closeBtn?.addEventListener('click', closeCart);
    overlay?.addEventListener('click', closeCart);

    cartBtns.forEach(btn => {
      btn.addEventListener('click', async function(e) {
        e.preventDefault();
        const button = this;
        
        // Save original design
        const originalHTML = button.innerHTML;
        const productTitle = button.getAttribute('data-title');
        const productPrice = button.getAttribute('data-price');
        
        // 1. Loading State (Tailwind !bg overrides the default black)
        button.classList.add('pointer-events-none', '!bg-[#166534]');
        button.innerHTML = `
          <svg class="animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          AUTHORIZING...
        `;

        // 2. Fake API Delay
        await new Promise(resolve => setTimeout(resolve, 800)); 

        // 3. Success State
        button.innerHTML = `
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
          ADDED TO ROUTINE
        `;

        // Update Drawer UI dynamically
        const formatPrice = new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(productPrice);
        document.getElementById('cart-item-title').innerText = productTitle || 'Pure Spirulina';
        document.getElementById('cart-item-price').innerText = formatPrice;
        document.getElementById('cart-subtotal').innerText = formatPrice;

        // 4. Open Drawer 
        setTimeout(() => {
          openCart();
          
          // Reset button design after drawer opens
          setTimeout(() => {
            button.innerHTML = originalHTML;
            button.classList.remove('pointer-events-none', '!bg-[#166534]');
          }, 1000);
          
        }, 500);

      });
    });
  });
</script>