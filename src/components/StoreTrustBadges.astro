---
// src/components/StoreTrustBadges.astro
---

<section id="trust-signals-bar" class="w-full bg-white border-y border-gray-100 py-10 md:py-14 font-['Inter'] relative overflow-hidden">
  
  {/* Symmetrical grid layout matching modern luxury D2C guidelines */}
  <div class="max-w-[90rem] mx-auto px-5 md:px-6 lg:px-12 relative z-10">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 md:gap-12">
      
      {/* Badge 1: Free Express Delivery */}
      <div class="group flex flex-col sm:flex-row items-center sm:items-start text-center sm:text-left gap-4 transition-all duration-300">
        <div class="w-12 h-12 rounded-2xl bg-emerald-50 border border-emerald-100 flex items-center justify-center text-[#166534] group-hover:bg-[#166534] group-hover:text-white transition-all duration-500 flex-shrink-0 shadow-sm group-hover:scale-110">
          <svg class="w-6 h-6 transform group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124l-.847-13.433A1.875 1.875 0 0 0 19.333 3H16.5M16.5 18.75h-2.25m-10.5-3.75h10.5m-10.5-3.75h10.5M3.75 6h10.5a1.5 1.5 0 0 1 1.5 1.5v5.25a1.5 1.5 0 0 1-1.5 1.5H3.75A1.5 1.5 0 0 1 2.25 12.75V7.5A1.5 1.5 0 0 1 3.75 6Z" />
          </svg>
        </div>
        <div>
          <h4 class="text-xs font-black uppercase tracking-widest text-[#111827] mb-1">Free Shipping</h4>
          <p class="text-gray-500 text-[11px] leading-normal font-medium">Automatic upgrade on all orders above ₹999.</p>
        </div>
      </div>

      {/* Badge 2: COD Available */}
      <div class="group flex flex-col sm:flex-row items-center sm:items-start text-center sm:text-left gap-4 transition-all duration-300">
        <div class="w-12 h-12 rounded-2xl bg-emerald-50 border border-emerald-100 flex items-center justify-center text-[#166534] group-hover:bg-[#166534] group-hover:text-white transition-all duration-500 flex-shrink-0 shadow-sm group-hover:scale-110">
          <svg class="w-6 h-6 transform group-hover:rotate-6 transition-transform" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
          </svg>
        </div>
        <div>
          <h4 class="text-xs font-black uppercase tracking-widest text-[#111827] mb-1">Cash on Delivery</h4>
          <p class="text-gray-500 text-[11px] leading-normal font-medium">Pay securely at your doorstep. Zero extra charges.</p>
        </div>
      </div>

      {/* Badge 3: Extra 5% Off UPI */}
      <div class="group flex flex-col sm:flex-row items-center sm:items-start text-center sm:text-left gap-4 transition-all duration-300">
        <div class="w-12 h-12 rounded-2xl bg-emerald-50 border border-emerald-100 flex items-center justify-center text-[#166534] group-hover:bg-[#166534] group-hover:text-white transition-all duration-500 flex-shrink-0 shadow-sm group-hover:scale-110">
          <svg class="w-6 h-6 transform group-hover:scale-105 transition-transform" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
          </svg>
        </div>
        <div>
          <h4 class="text-xs font-black uppercase tracking-widest text-[#111827] mb-1">Prepaid Incentives</h4>
          <p class="text-gray-500 text-[11px] leading-normal font-medium">Get flat 5% extra discount instantly on UPI & Cards.</p>
        </div>
      </div>

      {/* Badge 4: NABL Lab Certified */}
      <div class="group flex flex-col sm:flex-row items-center sm:items-start text-center sm:text-left gap-4 transition-all duration-300">
        <div class="w-12 h-12 rounded-2xl bg-emerald-50 border border-emerald-100 flex items-center justify-center text-[#166534] group-hover:bg-[#166534] group-hover:text-white transition-all duration-500 flex-shrink-0 shadow-sm group-hover:scale-110">
          <svg class="w-6 h-6 transform group-hover:-rotate-6 transition-transform" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v13.01a4.5 4.5 0 001.071 2.991l.007.007c.3.3.618.57.947.81a4.5 4.5 0 005.454 0c.329-.24.648-.51.947-.81l.008-.008a4.5 4.5 0 001.071-2.99V3.104M16.5 7.5h.008v.008H16.5V7.5zm0 3.75h.008v.008H16.5v-.008zm-9-5.25h.008v.008H7.5V6zm0 3.75h.008v.008H7.5v-.008zM3.75 18h16.5" />
          </svg>
        </div>
        <div>
          <h4 class="text-xs font-black uppercase tracking-widest text-[#111827] mb-1">NABL Lab Certified</h4>
          <p class="text-gray-500 text-[11px] leading-normal font-medium">100% heavy metal & toxin free. Complete clinical safety.</p>
        </div>
      </div>

    </div>
  </div>
</section>
