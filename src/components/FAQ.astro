---
const faqs = [
  {
    id: "q1",
    question: "Why headless architecture over WordPress?",
    answer: "Traditional CMS platforms couple the frontend and backend, resulting in heavy database queries and bloated JavaScript. We decouple them, serving pre-rendered HTML globally via Edge Networks for instant load times and zero plugin bloat."
  },
  {
    id: "q2",
    question: "How do you guarantee 99+ Core Web Vitals?",
    answer: "We engineer from the ground up using Astro.js, strictly limiting client-side JavaScript. By optimizing asset delivery and eliminating render-blocking resources, we ensure your metrics stay in the green zone consistently."
  },
  {
    id: "q3",
    question: "What is Server-Side Tagging?",
    answer: "We implement Server-Side GTM, routing all data through a first-party subdomain. This bypasses ad-blockers, ensures 100% data accuracy for campaigns, and speeds up your website by removing heavy third-party scripts."
  },
  {
    id: "q4",
    question: "Timeline for a full infrastructure migration?",
    answer: "A standard migration takes 4 to 6 weeks. This includes a technical SEO audit, data architecture setup, custom UI/UX development, and rigorous pre-launch QA testing to ensure zero traffic loss."
  },
  {
    id: "q5",
    question: "Do you handle the SEO transition?",
    answer: "Absolutely. We map every URL, implement 301 redirect architectures, migrate schema markups, and monitor Google Search Console strictly post-launch to ensure your search rankings improve."
  }
];
---

<section id="faq" class="py-24 md:py-32 border-b border-white/5 relative z-10 bg-[#000000] overflow-hidden">
  
  <div class="absolute top-1/2 right-0 -translate-y-1/2 w-[500px] h-[500px] bg-cyan-900/10 blur-[120px] rounded-full pointer-events-none z-0"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">
    
    <div class="mb-16">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-900/80 border border-slate-700/50 text-xs text-slate-300 font-mono mb-6 backdrop-blur-sm">
            <span class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse"></span>
            Knowledge Base
        </div>
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tighter text-white leading-tight">
            Query the <br class="hidden md:block"/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500 drop-shadow-[0_0_15px_rgba(34,211,238,0.2)]">System.</span>
        </h2>
    </div>

    <div class="flex flex-col lg:flex-row gap-6 lg:gap-10">
        
        <div class="w-full lg:w-5/12 flex flex-col gap-3 pr-0 lg:pr-4">
            {faqs.map((faq, index) => (
                <button 
                    class="faq-trigger group relative w-full text-left outline-none"
                    data-answer={faq.answer}
                    data-question={faq.question}
                    data-index={index}
                >
                    <div class="absolute inset-0 bg-cyan-500/20 blur-xl opacity-0 group-hover:opacity-30 group-[.is-active]:opacity-100 transition-opacity duration-500 pointer-events-none rounded-xl"></div>
                    
                    <div class="relative w-full bg-[#050505] group-hover:bg-[#0c0c0c] border border-white/5 group-hover:border-white/20 rounded-xl p-4 md:px-5 md:py-4 flex items-center gap-4 transition-all duration-300 shadow-[inset_0_1px_0_rgba(255,255,255,0.03),0_8px_20px_rgba(0,0,0,0.4)] z-10 overflow-hidden bg-gradient-to-br from-white/[0.02] to-transparent group-[.is-active]:bg-slate-900/90 group-[.is-active]:border-cyan-500/30">
                        
                        <div class="absolute left-0 top-0 bottom-0 w-[2px] bg-slate-800/30"></div>
                        <div class="absolute left-0 top-1/2 -translate-y-1/2 w-[2px] h-0 group-hover:h-1/3 group-[.is-active]:h-full bg-cyan-400 transition-all duration-300 opacity-0 group-hover:opacity-50 group-[.is-active]:opacity-100 shadow-[0_0_10px_#22d3ee]"></div>

                        <div class="shrink-0 flex items-center justify-center w-8 h-8 rounded-lg bg-[#000000] group-hover:bg-slate-900 border border-white/5 group-hover:border-white/10 text-[10px] font-mono text-slate-500 group-hover:text-slate-300 group-[.is-active]:bg-cyan-500/10 group-[.is-active]:border-cyan-500/40 group-[.is-active]:text-cyan-400 transition-all duration-300 shadow-[inset_0_2px_6px_rgba(0,0,0,0.8),0_1px_0_rgba(255,255,255,0.02)]">
                            0{index + 1}
                        </div>
                        
                        <span class="text-sm md:text-base text-slate-400 group-hover:text-slate-200 group-[.is-active]:text-white font-medium tracking-wide transition-colors duration-300 leading-snug pr-4">{faq.question}</span>

                        <div class="ml-auto opacity-0 group-hover:opacity-40 group-[.is-active]:opacity-100 -translate-x-4 group-hover:-translate-x-1 group-[.is-active]:translate-x-0 transition-all duration-300">
                            <svg class="w-4 h-4 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                        </div>
                    </div>
                </button>
            ))}
        </div>

        <div class="w-full lg:w-7/12">
            <div class="sticky top-32 w-full min-h-[350px] bg-[#030712] border border-white/10 rounded-2xl p-8 md:p-12 relative overflow-hidden flex flex-col shadow-[0_0_40px_rgba(0,0,0,0.5)]">
                
                <div class="absolute inset-0 opacity-[0.03] bg-[linear-gradient(to_right,#fff_1px,transparent_1px),linear-gradient(to_bottom,#fff_1px,transparent_1px)] bg-[size:20px_20px] pointer-events-none"></div>
                
                <div class="flex items-center gap-2 mb-8 relative z-10 border-b border-white/5 pb-4">
                    <div class="w-3 h-3 rounded-full bg-slate-800"></div>
                    <div class="w-3 h-3 rounded-full bg-slate-800"></div>
                    <div class="w-3 h-3 rounded-full bg-slate-800"></div>
                    <div class="ml-4 text-[10px] font-mono text-cyan-500/50 tracking-widest uppercase">Output Console_</div>
                </div>

                <div class="relative z-10 flex-1 flex flex-col">
                    
                    <div id="terminal-idle" class="absolute inset-0 flex flex-col items-center justify-center text-center opacity-100 transition-opacity duration-500">
                        <svg class="w-12 h-12 text-slate-800 mb-4 animate-[spin_10s_linear_infinite]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>
                        <p class="text-slate-500 font-mono text-sm tracking-widest uppercase">Awaiting Query Selection...</p>
                    </div>

                    <div id="terminal-active" class="opacity-0 transition-opacity duration-300">
                        <h3 id="display-question" class="text-2xl md:text-3xl font-bold text-white mb-6 tracking-tight leading-tight"></h3>
                        <div class="relative">
                            <p id="display-answer" class="text-lg text-slate-400 font-light leading-relaxed"></p>
                            <span id="cursor" class="inline-block w-2 h-5 bg-cyan-400 ml-1 animate-pulse opacity-0"></span>
                        </div>
                    </div>

                </div>
            </div>
        </div>

    </div>
  </div>
</section>

<style>
  /* Active Button Styles */
  .faq-trigger.is-active {
    border-color: rgba(34, 211, 238, 0.4);
    background-color: rgba(34, 211, 238, 0.05);
  }
  .faq-trigger.is-active .active-bg {
    opacity: 1;
  }
  .faq-trigger.is-active span:last-child {
    color: #fff;
  }
  .faq-trigger.is-active span:first-child {
    color: #22d3ee;
  }
</style>

<script is:inline>
  function initTerminalFAQ() {
    const triggers = document.querySelectorAll('.faq-trigger');
    const idleState = document.getElementById('terminal-idle');
    const activeState = document.getElementById('terminal-active');
    const displayQuestion = document.getElementById('display-question');
    const displayAnswer = document.getElementById('display-answer');
    const cursor = document.getElementById('cursor');

    let typeWriterTimeout;

    triggers.forEach(trigger => {
        trigger.addEventListener('click', () => {
            // 1. Reset all buttons
            triggers.forEach(btn => btn.classList.remove('is-active'));
            // 2. Activate clicked button
            trigger.classList.add('is-active');

            // 3. Get Data
            const questionText = trigger.getAttribute('data-question');
            const answerText = trigger.getAttribute('data-answer');

            console.log("🔥 FAQ Clicked! Sending to GTM:", questionText);

            window.dataLayer = window.dataLayer || [];
  window.dataLayer.push({ 
      'event': 'faq_query_terminal',
      'question_viewed': questionText 
  });

            // 4. UI Transition
            idleState.style.opacity = '0';
            idleState.style.pointerEvents = 'none';
            
            // Clear previous text
            activeState.style.opacity = '0';
            clearTimeout(typeWriterTimeout);
            displayAnswer.innerHTML = '';
            cursor.style.opacity = '0';

            // 5. The Cyber Reveal
            setTimeout(() => {
                displayQuestion.innerText = questionText;
                activeState.style.opacity = '1';
                cursor.style.opacity = '1';

                // Typewriter Effect Logic
                let i = 0;
                const speed = 15; // Speed in ms

                function typeWriter() {
                    if (i < answerText.length) {
                        displayAnswer.innerHTML += answerText.charAt(i);
                        i++;
                        typeWriterTimeout = setTimeout(typeWriter, speed);
                    } else {
                        // Keep cursor blinking at the end
                    }
                }
                
                typeWriter();

            }, 300); // Wait for fade out
        });
    });
  }

  document.addEventListener('astro:page-load', initTerminalFAQ);
  initTerminalFAQ();
</script>