---
---
<section class="py-24 md:py-32 relative z-10 bg-[#000000] border-b border-white/5 overflow-hidden">
  
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-blue-900/10 blur-[120px] rounded-full pointer-events-none z-0"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      
      <div>
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-sm bg-slate-900/80 border border-slate-700/50 text-xs text-slate-300 font-mono mb-8 backdrop-blur-sm">
            <span class="w-1.5 h-1.5 bg-cyan-500 animate-pulse shadow-[0_0_10px_#22d3ee]"></span>
            The Boutique Advantage
        </div>
        
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-white leading-[1.1] tracking-tighter mb-8">
            Direct access to the <br class="hidden md:block"/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500 drop-shadow-[0_0_15px_rgba(34,211,238,0.2)]">architects of your growth.</span>
        </h2>
        
        <div class="space-y-6 text-lg text-slate-400 font-light leading-relaxed max-w-lg">
            <p>
                Traditional agencies win your business with their founders, then hand your critical infrastructure over to junior developers and account managers. 
            </p>
            <p>
                <strong class="text-white font-medium">We operate differently.</strong> Skadas is a highly specialized, elite engineering command center. When you partner with us, your architecture and data pipelines are engineered directly by the core team.
            </p>
            <p class="text-cyan-400 font-medium border-l-2 border-cyan-500 pl-4 bg-cyan-500/5 py-2">
                Absolute focus. Zero agency bloat. Just raw, scalable performance.
            </p>
        </div>
      </div>

      <div class="relative w-full py-12 md:py-0 min-h-[500px] md:h-[550px] rounded-2xl bg-[#030712] border border-white/5 overflow-hidden flex items-center justify-center px-4 md:px-6 lg:p-10">
        
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff05_1px,transparent_1px),linear-gradient(to_bottom,#ffffff05_1px,transparent_1px)] bg-[size:32px_32px]"></div>

        <div class="absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-[1px] bg-slate-800 z-0">
            <div class="w-full h-1/3 bg-gradient-to-b from-transparent via-cyan-500/50 to-transparent animate-[flowDown_3s_linear_infinite]"></div>
        </div>

        <div class="flex flex-col gap-5 w-full max-w-sm z-10 relative">
            
            <div class="group/blade relative w-full bg-[#0a0a0a] border border-slate-800 p-5 rounded-lg overflow-hidden transition-all duration-500 hover:bg-slate-900/80 hover:translate-x-2 hover:border-orange-500/30 shadow-2xl">
                <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-orange-400 to-transparent -translate-x-full group-hover/blade:animate-[shimmer_1.5s_infinite]"></div>
                
                <div class="flex justify-between items-center mb-3">
                    <span class="text-[10px] font-mono tracking-widest text-slate-500">SYS.01 // INFRASTRUCTURE</span>
                    <div class="w-1.5 h-1.5 bg-orange-500 shadow-[0_0_10px_#f97316]"></div> 
                </div>
                <h3 class="text-white font-bold text-xl tracking-tight mb-2">Zero-Latency Web Delivery</h3>
                <div class="flex items-center gap-2">
                    <span class="text-orange-400/90 font-mono text-[10px] bg-orange-500/10 px-2 py-1 rounded-sm border border-orange-500/20 uppercase">Core_Web_Vitals: Flawless</span>
                    <span class="w-full h-[1px] bg-slate-800 grow"></span>
                </div>
            </div>

            <div class="group/blade relative w-full bg-[#0a0a0a] border border-slate-800 p-5 rounded-lg overflow-hidden transition-all duration-500 hover:bg-slate-900/80 hover:-translate-x-2 hover:border-emerald-500/30 shadow-2xl">
                <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-emerald-400 to-transparent -translate-x-full group-hover/blade:animate-[shimmer_1.5s_infinite_0.2s]"></div>
                
                <div class="flex justify-between items-center mb-3">
                    <span class="text-[10px] font-mono tracking-widest text-slate-500">SYS.02 // DATA PIPELINE</span>
                    <div class="w-1.5 h-1.5 bg-emerald-500 shadow-[0_0_10px_#10b981]"></div>
                </div>
                <h3 class="text-white font-bold text-xl tracking-tight mb-2">First-Party Telemetry</h3>
                <div class="flex items-center gap-2">
                    <span class="text-emerald-400/90 font-mono text-[10px] bg-emerald-500/10 px-2 py-1 rounded-sm border border-emerald-500/20 uppercase">Signal_Accuracy: 100%</span>
                    <span class="w-full h-[1px] bg-slate-800 grow"></span>
                </div>
            </div>

            <div class="group/blade relative w-full bg-[#0a0a0a] border border-slate-800 p-5 rounded-lg overflow-hidden transition-all duration-500 hover:bg-slate-900/80 hover:translate-x-2 hover:border-blue-500/30 shadow-2xl">
                <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-blue-400 to-transparent -translate-x-full group-hover/blade:animate-[shimmer_1.5s_infinite_0.4s]"></div>
                
                <div class="flex justify-between items-center mb-3">
                    <span class="text-[10px] font-mono tracking-widest text-slate-500">SYS.03 // ACQUISITION</span>
                    <div class="w-1.5 h-1.5 bg-blue-500 shadow-[0_0_10px_#3b82f6]"></div>
                </div>
                <h3 class="text-white font-bold text-xl tracking-tight mb-2">Precision Client Acquisition</h3>
                <div class="flex items-center gap-2">
                    <span class="text-blue-400/90 font-mono text-[10px] bg-blue-500/10 px-2 py-1 rounded-sm border border-blue-500/20 uppercase">Lead_Quality: Verified</span>
                    <span class="w-full h-[1px] bg-slate-800 grow"></span>
                </div>
            </div>

        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* Strict Linear Animations (No rotation) */
  @keyframes flowDown {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(300%); }
  }

  @keyframes shimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }
</style>