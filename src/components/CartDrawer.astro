---
// src/components/CartDrawer.astro
---
{/* The Dark Overlay (Background blur) */}
<div id="cart-overlay" class="fixed inset-0 bg-black/40 backdrop-blur-sm z-[60] opacity-0 pointer-events-none transition-opacity duration-500 ease-out"></div>

{/* The Premium Drawer (Slides from Right) */}
<div id="cart-drawer" class="fixed top-0 right-0 w-full sm:w-[420px] h-[100svh] bg-[#FAF9F6] z-[70] translate-x-[100%] transition-transform duration-500 ease-[cubic-bezier(0.1,0,0,1)] shadow-2xl flex flex-col border-l border-black/5">
  
  {/* Drawer Header */}
  <div class="px-6 py-6 border-b border-gray-100 flex items-center justify-between bg-white/50 backdrop-blur-md">
    <div class="flex items-center gap-3">
      <h2 class="text-xl font-['Playfair_Display'] font-black text-[#111827]">Your Routine</h2>
      <span class="bg-[#166534] text-white text-[10px] font-bold px-2 py-0.5 rounded-full" id="cart-count-badge">1</span>
    </div>
    <button id="close-cart-btn" aria-label="Close cart" class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center text-gray-500 hover:bg-gray-200 hover:text-black transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>
  </div>

  {/* Cart Items Area (Scrollable) */}
  <div class="flex-1 overflow-y-auto p-6" id="cart-items-container">
    
    {/* DUMMY ITEM (He JS dware dynamic hoil, sadhya demo sathi ahe) */}
    <div class="flex gap-4 p-4 bg-white rounded-2xl shadow-sm border border-gray-50 mb-4 animate-[fadeInUp_0.5s_ease-out]">
      <div class="w-20 h-24 bg-[#f0fdf4] rounded-xl flex items-center justify-center p-2">
        <img src="/spirulina-bottle.png" alt="Product" class="w-full h-full object-contain drop-shadow-md" id="cart-item-image"/>
      </div>
      <div class="flex-1 flex flex-col justify-between py-1">
        <div>
          <h3 class="text-sm font-bold text-[#111827] line-clamp-1" id="cart-item-title">Pure Spirulina Blend</h3>
          <p class="text-[10px] uppercase tracking-wider text-gray-600 font-semibold mt-1">One-Time Purchase</p>
        </div>
        <div class="flex items-center justify-between mt-3">
          {/* Quantity Selector */}
          <div class="flex items-center gap-3 bg-gray-50 rounded-full px-2 py-1 border border-gray-100">
            <button class="w-5 h-5 flex items-center justify-center text-gray-500 hover:text-black">-</button>
            <span class="text-xs font-bold text-[#111827]">1</span>
            <button class="w-5 h-5 flex items-center justify-center text-gray-500 hover:text-black">+</button>
          </div>
          <span class="text-sm font-black text-[#111827]" id="cart-item-price">₹1,299</span>
        </div>
      </div>
    </div>

  </div>

  {/* Drawer Footer (Checkout Section) */}
  <div class="px-6 py-8 bg-white border-t border-gray-100 shadow-[0_-10px_20px_rgba(0,0,0,0.02)]">
    
    <div class="flex items-center justify-between mb-2">
      <span class="text-gray-500 font-medium text-sm">Subtotal</span>
      <span class="text-xl font-black text-[#111827]" id="cart-subtotal">₹1,299</span>
    </div>
    <p class="text-xs text-emerald-600 font-semibold mb-6 flex items-center gap-1.5">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
      Taxes and shipping calculated at checkout
    </p>

    <button class="w-full bg-[#111827] text-white font-bold text-sm uppercase tracking-widest px-8 py-5 rounded-xl flex items-center justify-center gap-3 transition-all duration-300 hover:bg-[#166534] shadow-[0_10px_20px_rgba(0,0,0,0.1)] hover:shadow-[0_15px_30px_rgba(22,101,52,0.25)] hover:-translate-y-1 group">
      Secure Checkout
      <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
    </button>
    
    {/* Trust Badges */}
    <div class="flex items-center justify-center gap-4 mt-6 opacity-60">
      <span class="text-[9px] font-bold uppercase tracking-widest text-gray-500">Encrypted</span>
      <span class="w-1 h-1 rounded-full bg-gray-300"></span>
      <span class="text-[9px] font-bold uppercase tracking-widest text-gray-500">SSL Secure</span>
    </div>
  </div>

</div>

<script>
  console.log("🚀 Master Cart Engine Loading...");

  const domain = import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_DOMAIN || "skadas-headless-demo.myshopify.com";
  const storefrontToken = import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_TOKEN || "32f678c5f8d1345e945ed48713d9cf2f";

  window.openSujataCart = () => {
    console.log("🟢 openSujataCart Triggered");
    const drawer = document.getElementById('cart-drawer');
    const overlay = document.getElementById('cart-overlay');
    if(overlay && drawer) {
      overlay.classList.remove('opacity-0', 'pointer-events-none');
      overlay.classList.add('opacity-100');
      drawer.classList.remove('translate-x-[100%]');
      drawer.classList.add('translate-x-0');
      document.body.style.overflow = 'hidden'; 
    } else {
      console.error("❌ Drawer elements not found in DOM!");
    }
  };

  window.closeSujataCart = () => {
    const drawer = document.getElementById('cart-drawer');
    const overlay = document.getElementById('cart-overlay');
    if(overlay && drawer) {
      overlay.classList.remove('opacity-100');
      overlay.classList.add('opacity-0', 'pointer-events-none');
      drawer.classList.remove('translate-x-0');
      drawer.classList.add('translate-x-[100%]');
      document.body.style.overflow = '';
    }
  };

  window.shopifyFetch = async (query, variables) => {
    const response = await fetch(`https://${domain}/api/2024-01/graphql.json`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Shopify-Storefront-Access-Token': storefrontToken,
      },
      body: JSON.stringify({ query, variables }),
    });
    return await response.json();
  };

  const cartFragment = `
    id checkoutUrl totalQuantity
    cost { totalAmount { amount } }
    lines(first: 10) { edges { node { id quantity merchandise { ... on ProductVariant { id title image { url } price { amount } product { title } } } } } }
  `;

  window.renderCartUI = (cart) => {
    const cartItemsContainer = document.getElementById('cart-items-container');
    const drawerCartBadge = document.getElementById('cart-count-badge');
    const headerCartBadge = document.getElementById('header-cart-badge');
    const cartSubtotal = document.getElementById('cart-subtotal');
    const checkoutBtn = document.querySelector('#cart-drawer button.group');

    if (!cart || !cartItemsContainer) return;

    const count = cart.totalQuantity || 0;
    if (drawerCartBadge) drawerCartBadge.innerText = count;
    if (headerCartBadge) {
      headerCartBadge.innerText = count;
      headerCartBadge.style.display = count > 0 ? 'flex' : 'none';
    }

    const currentTotal = cart.cost?.totalAmount?.amount || 0;
    const formatPrice = new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(currentTotal);
    if (cartSubtotal) cartSubtotal.innerText = formatPrice;

    if (checkoutBtn && cart.checkoutUrl) checkoutBtn.onclick = () => window.location.href = cart.checkoutUrl;

    cartItemsContainer.innerHTML = '';

    if (count === 0) {
      cartItemsContainer.innerHTML = `<div class="text-center py-10 text-gray-600 font-medium">Your routine is empty.</div>`;
      return;
    }

    const shippingThreshold = 2000;
    const amountRemaining = shippingThreshold - currentTotal;
    const progressPercent = Math.min((currentTotal / shippingThreshold) * 100, 100);
    
    let shippingHTML = amountRemaining > 0 
      ? `<div class="mb-5 bg-gray-50 p-4 rounded-2xl border border-gray-100 relative overflow-hidden group"><p class="text-[11px] font-bold text-gray-800 text-center mb-3 tracking-wide">You're only <span class="text-[#166534] text-sm font-black">₹${amountRemaining}</span> away from <span class="uppercase tracking-widest border-b border-[#166534]">Free Shipping</span> 🚚</p><div class="w-full h-2.5 bg-gray-200 rounded-full overflow-hidden shadow-inner"><div class="h-full bg-[#111827] rounded-full transition-all duration-700 ease-out" style="width: ${progressPercent}%"></div></div></div>`
      : `<div class="mb-5 bg-[#f0fdf4] p-4 rounded-2xl border border-emerald-200"><p class="text-xs font-black text-[#166534] text-center uppercase tracking-widest">Free Shipping Unlocked! 🎉</p><div class="w-full h-1.5 bg-emerald-200 rounded-full mt-3"><div class="h-full bg-emerald-500" style="width: 100%"></div></div></div>`;

    cartItemsContainer.insertAdjacentHTML('beforeend', shippingHTML);

    cart.lines.edges.forEach(({ node }) => {
      const variant = node.merchandise;
      const product = variant.product;
      const itemPrice = new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(variant.price.amount);
      const imageUrl = variant.image?.url || '/spirulina-bottle.png';

      const itemHTML = `
        <div class="flex gap-4 p-4 bg-white rounded-2xl shadow-sm border border-gray-50 mb-4 animate-[fadeInUp_0.5s_ease-out]">
          <div class="w-20 h-24 bg-[#f0fdf4] rounded-xl flex items-center justify-center p-2 relative">
            <div id="loader-${node.id}" class="absolute inset-0 bg-white/80 backdrop-blur-sm hidden flex-center justify-center items-center rounded-xl z-10">
              <div class="w-4 h-4 border-2 border-[#166534] border-t-transparent rounded-full animate-spin"></div>
            </div>
            <img src="${imageUrl}" class="w-full h-full object-contain drop-shadow-md"/>
          </div>
          <div class="flex-1 flex flex-col justify-between py-1">
            <div>
              <h3 class="text-sm font-bold text-[#111827] line-clamp-1">${product.title}</h3>
              <p class="text-[10px] uppercase tracking-wider text-gray-600 font-semibold mt-1">${variant.title !== 'Default Title' ? variant.title : 'Pure Form'}</p>
            </div>
            <div class="flex items-center justify-between mt-3">
              <div class="flex items-center gap-3 bg-gray-50 rounded-full px-2 py-1 border border-gray-100">
                <button class="qty-btn w-5 h-5 flex items-center justify-center text-gray-500 hover:text-black font-bold" data-line-id="${node.id}" data-action="decrease" data-current="${node.quantity}">-</button>
                <span class="text-xs font-bold text-[#111827] w-3 text-center">${node.quantity}</span>
                <button class="qty-btn w-5 h-5 flex items-center justify-center text-gray-500 hover:text-black font-bold" data-line-id="${node.id}" data-action="increase" data-current="${node.quantity}">+</button>
              </div>
              <span class="text-sm font-black text-[#111827]">${itemPrice}</span>
            </div>
          </div>
        </div>
      `;
      cartItemsContainer.insertAdjacentHTML('beforeend', itemHTML);
    });
  };

  window.addProductToCart = async (variantId) => {
    let cartId = localStorage.getItem('sujata_cart_id');
    let cart;
    if (!cartId) {
      const res = await window.shopifyFetch(`mutation cartCreate($input: CartInput!) { cartCreate(input: $input) { cart { ${cartFragment} } } }`, { input: { lines: [{ merchandiseId: variantId, quantity: 1 }] } });
      localStorage.setItem('sujata_cart_id', res.data.cartCreate.cart.id);
      cart = res.data.cartCreate.cart;
    } else {
      const res = await window.shopifyFetch(`mutation cartLinesAdd($cartId: ID!, $lines: [CartLineInput!]!) { cartLinesAdd(cartId: $cartId, lines: $lines) { cart { ${cartFragment} } } }`, { cartId, lines: [{ merchandiseId: variantId, quantity: 1 }] });
      if (res.errors) { localStorage.removeItem('sujata_cart_id'); return window.addProductToCart(variantId); }
      cart = res.data.cartLinesAdd.cart;
    }

    // --- DataLayer Tracking & Custom DOM Event ---
    try {
      const addedLine = cart.lines.edges.find(({ node }) => node.merchandise.id === variantId);
      if (addedLine) {
        const item = addedLine.node.merchandise;
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: 'sujata_add_to_cart',
          ecommerce: {
            items: [{
              item_id: variantId,
              item_name: item.product.title,
              price: item.price.amount,
              quantity: 1
            }]
          }
        });
      }
      document.dispatchEvent(new CustomEvent('sujata:add_to_cart', { detail: { variantId, cart } }));
    } catch (err) {
      console.warn("Tracking error in addProductToCart:", err);
    }

    return cart;
  };

  window.addMultipleProductsToCart = async (lines) => {
    let cartId = localStorage.getItem('sujata_cart_id');
    let cart;
    const formattedLines = lines.map(line => ({ merchandiseId: line.variantId, quantity: line.quantity || 1 }));
    if (!cartId) {
      const res = await window.shopifyFetch(`mutation cartCreate($input: CartInput!) { cartCreate(input: $input) { cart { ${cartFragment} } } }`, { input: { lines: formattedLines } });
      localStorage.setItem('sujata_cart_id', res.data.cartCreate.cart.id);
      cart = res.data.cartCreate.cart;
    } else {
      const res = await window.shopifyFetch(`mutation cartLinesAdd($cartId: ID!, $lines: [CartLineInput!]!) { cartLinesAdd(cartId: $cartId, lines: $lines) { cart { ${cartFragment} } } }`, { cartId, lines: formattedLines });
      if (res.errors) { localStorage.removeItem('sujata_cart_id'); return window.addMultipleProductsToCart(lines); }
      cart = res.data.cartLinesAdd.cart;
    }

    try {
      window.dataLayer = window.dataLayer || [];
      const trackingItems = [];
      lines.forEach(line => {
        const addedLine = cart.lines.edges.find(({ node }) => node.merchandise.id === line.variantId);
        if (addedLine) {
          const item = addedLine.node.merchandise;
          trackingItems.push({
            item_id: line.variantId,
            item_name: item.product.title,
            price: item.price.amount,
            quantity: line.quantity || 1
          });
        }
      });
      if (trackingItems.length > 0) {
        window.dataLayer.push({
          event: 'sujata_add_to_cart_multiple',
          ecommerce: { items: trackingItems }
        });
      }
      document.dispatchEvent(new CustomEvent('sujata:add_to_cart_multiple', { detail: { lines, cart } }));
    } catch (err) {
      console.warn("Tracking error in addMultipleProductsToCart:", err);
    }

    return cart;
  };


  window.updateQuantity = async (lineId, newQuantity) => {
    const cartId = localStorage.getItem('sujata_cart_id');
    if(!cartId) return;
    const loader = document.getElementById(`loader-${lineId}`);
    if(loader) loader.classList.remove('hidden');

    let query, variables;
    if (newQuantity === 0) {
      query = `mutation cartLinesRemove($cartId: ID!, $lineIds: [ID!]!) { cartLinesRemove(cartId: $cartId, lineIds: $lineIds) { cart { ${cartFragment} } } }`;
      variables = { cartId, lineIds: [lineId] };
    } else {
      query = `mutation cartLinesUpdate($cartId: ID!, $lines: [CartLineUpdateInput!]!) { cartLinesUpdate(cartId: $cartId, lines: $lines) { cart { ${cartFragment} } } }`;
      variables = { cartId, lines: [{ id: lineId, quantity: newQuantity }] };
    }
    const res = await window.shopifyFetch(query, variables);
    const cart = res.data.cartLinesUpdate?.cart || res.data.cartLinesRemove?.cart;
    if (cart) {
      window.renderCartUI(cart);
      
      // --- DataLayer Tracking & Custom DOM Event ---
      try {
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: 'sujata_cart_update',
          ecommerce: {
            cart_id: cart.id,
            total_quantity: cart.totalQuantity,
            value: cart.cost?.totalAmount?.amount
          }
        });
        document.dispatchEvent(new CustomEvent('sujata:cart_update', { detail: { cart } }));
      } catch (err) {
        console.warn("Tracking error in updateQuantity:", err);
      }
    }
  };

  // Event Listener (Click Catching)
  document.addEventListener('click', async (e) => {
    
    if (e.target.closest('#close-cart-btn') || e.target.id === 'cart-overlay') {
       window.closeSujataCart();
    }
    if (e.target.closest('#cart-drawer-trigger')) {
       e.preventDefault(); window.openSujataCart();
    }

    const qtyBtn = e.target.closest('.qty-btn');
    if (qtyBtn) {
        window.updateQuantity(qtyBtn.getAttribute('data-line-id'), parseInt(qtyBtn.getAttribute('data-current')) + (qtyBtn.getAttribute('data-action') === 'increase' ? 1 : -1));
    }

    const atcBtn = e.target.closest('.add-to-cart-btn') || e.target.closest('#add-to-cart-btn');
    if (atcBtn) {
        e.preventDefault();
        console.log("🔘 Button Clicked!", atcBtn);
        if (atcBtn.disabled) return;

        const variantIdsAttr = atcBtn.getAttribute('data-variant-ids');
        let variantId = atcBtn.getAttribute('data-variant-id') || atcBtn.getAttribute('data-default-variant');
        
        // Scope the variant search to the local product container if possible
        const parentContainer = atcBtn.closest('.product-card') || atcBtn.closest('.product-details-container');
        if (parentContainer) {
          const activeVariantBtn = parentContainer.querySelector('.variant-btn.selected-variant');
          if (activeVariantBtn) variantId = activeVariantBtn.getAttribute('data-variant-id');
        } else {
          const activeVariantBtn = document.querySelector('.variant-btn.selected-variant');
          if (activeVariantBtn) variantId = activeVariantBtn.getAttribute('data-variant-id');
        }

        if (!variantIdsAttr && !variantId) { alert("Product unavailable"); return; }

        const btnText = atcBtn.querySelector('#btn-text, .btn-text');
        const btnSpinner = atcBtn.querySelector('#btn-spinner, .btn-spinner');
        
        let hasCustomSpinner = btnText && btnSpinner;
        let originalHTML = '';
        let spinnerUsesHidden = false;
        
        if (hasCustomSpinner) {
          atcBtn.disabled = true;
          atcBtn.classList.add('pointer-events-none');
          btnText.style.opacity = '0';
          
          if (btnSpinner.classList.contains('hidden')) {
            spinnerUsesHidden = true;
            btnSpinner.classList.remove('hidden');
          } else {
            btnSpinner.classList.remove('opacity-0', 'pointer-events-none');
            btnSpinner.classList.add('opacity-100');
          }
        } else {
          originalHTML = atcBtn.innerHTML;
          atcBtn.disabled = true;
          atcBtn.classList.add('pointer-events-none', '!bg-[#166534]');
          atcBtn.innerHTML = `<svg class="animate-spin h-4 w-4 text-white inline-block mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> AUTHORIZING...`;
        }

        try {
          let cart;
          if (variantIdsAttr) {
            const lines = variantIdsAttr.split(',').map(id => ({ variantId: id.trim(), quantity: 1 }));
            cart = await window.addMultipleProductsToCart(lines);
          } else {
            cart = await window.addProductToCart(variantId);
          }
          console.log("📦 Cart Updated: ", cart);
          window.renderCartUI(cart);
          
          if (hasCustomSpinner) {
            const oldText = btnText.innerHTML;
            btnText.innerHTML = `ADDED TO ROUTINE`;
            
            if (spinnerUsesHidden) {
              btnSpinner.classList.add('hidden');
            } else {
              btnSpinner.classList.remove('opacity-100');
              btnSpinner.classList.add('opacity-0', 'pointer-events-none');
            }
            btnText.style.opacity = '1';
            
            setTimeout(() => {
              window.openSujataCart();
              setTimeout(() => {
                btnText.innerHTML = oldText;
                atcBtn.classList.remove('pointer-events-none');
                atcBtn.disabled = false;
              }, 1000);
            }, 500);
          } else {
            atcBtn.innerHTML = `ADDED TO ROUTINE`;
            setTimeout(() => {
              window.openSujataCart();
              setTimeout(() => { 
                atcBtn.innerHTML = originalHTML; 
                atcBtn.classList.remove('pointer-events-none', '!bg-[#166534]'); 
                atcBtn.disabled = false; 
              }, 1000);
            }, 500);
          }
        } catch (error) {
          console.error("❌ Cart Error: ", error);
          if (hasCustomSpinner) {
            const oldText = btnText.innerHTML;
            btnText.innerHTML = `ERROR`;
            
            if (spinnerUsesHidden) {
              btnSpinner.classList.add('hidden');
            } else {
              btnSpinner.classList.remove('opacity-100');
              btnSpinner.classList.add('opacity-0', 'pointer-events-none');
            }
            btnText.style.opacity = '1';
            setTimeout(() => {
              btnText.innerHTML = oldText;
              atcBtn.classList.remove('pointer-events-none');
              atcBtn.disabled = false;
            }, 2000);
          } else {
            atcBtn.innerHTML = `ERROR`;
            setTimeout(() => { 
              atcBtn.innerHTML = originalHTML; 
              atcBtn.classList.remove('pointer-events-none', '!bg-[#166534]'); 
              atcBtn.disabled = false; 
              }, 2000);
          }
        }
    }
  });

  const initCart = async () => {
    console.log("🔄 Fetching initial cart...");
    const cartId = localStorage.getItem('sujata_cart_id');
    if (cartId) {
      const res = await window.shopifyFetch(`query { cart(id: "${cartId}") { ${cartFragment} } }`);
      if (res.data?.cart) window.renderCartUI(res.data.cart);
      else localStorage.removeItem('sujata_cart_id');
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCart);
  } else {
    initCart();
  }
</script>