        </div>

        <div class="w-full md:w-[45%] flex items-center justify-center relative h-[200px] sm:h-[240px] md:h-full">
          <Image src="/spirulina-powder.png" alt="Powder" width={400} height={400} class="relative z-10 w-auto h-[85%] object-contain drop-shadow-2xl translate-x-6"/>
          <Image src="/spirulina-bottle.png" alt="Bottle" width={300} height={300} class="relative z-20 w-auto h-[65%] object-contain drop-shadow-xl -translate-x-6 translate-y-6"/>
          
          <div class="absolute top-[10%] left-[5%] lg:left-[15%] bg-white/10 backdrop-blur-md border border-white/10 text-[#D97706] px-3 py-1.5 md:px-4 md:py-2 text-[10px] md:text-xs font-black uppercase tracking-[0.2em] rounded shadow-xl -rotate-6 z-30">
            BEST VALUE
          </div>
        </div>
      </div>
    </div>

    {/* -----------------------------------
        SLIDE 4: THE LOW-BARRIER TRIAL (Clinical Cream Theme)
        ----------------------------------- */}
    <div class="slide absolute inset-0 w-full h-full transition-transform duration-700 ease-[cubic-bezier(0.25,1,0.5,1)] translate-x-full" data-index="3">
      <div class="absolute inset-0 bg-gradient-to-r from-[#FCFBF9] to-[#ECFDF5] z-0"></div>
      
      <div class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-16 relative z-10 w-full h-full pt-[100px] md:pt-[140px] pb-[80px] md:pb-[100px] flex flex-col md:flex-row items-center justify-between gap-6 md:gap-4">
        
        <div class="w-full md:w-[55%] flex flex-col items-center md:items-start text-center md:text-left z-20">
          <h2 class="text-base sm:text-lg md:text-2xl lg:text-3xl font-medium text-gray-800 mb-1 md:mb-2 font-['Playfair_Display']">New to Spirulina?</h2>
          
          <div class="flex flex-col items-center md:items-start mb-4 md:mb-5 lg:mb-8">
            <span class="text-[#064E3B] text-[clamp(2.5rem,5.5vw,5.5rem)] font-black leading-none tracking-tighter drop-shadow-sm uppercase">7-DAY TRIAL</span>
            <span class="text-lg sm:text-2xl md:text-3xl font-black text-[#B45309] uppercase mt-1 md:mt-2">AT JUST ₹499</span>
            <span class="text-xs sm:text-sm md:text-lg font-medium text-gray-600 mt-1 md:mt-2 lg:mt-3">Experience the energy shift. No commitments.</span>
          </div>

          <a href="#product-ecosystem" class="bg-[#064E3B] hover:bg-[#022C22] text-white text-center text-sm md:text-base lg:text-lg font-bold uppercase tracking-[0.15em] px-8 sm:px-12 py-3.5 md:py-4 rounded-md shadow-[0_10px_20px_rgba(6,78,59,0.2)] transition-all transform hover:-translate-y-1 w-full sm:w-auto mt-2">
            START TRIAL
          </a>
        </div>

        <div class="w-full md:w-[45%] flex items-center justify-center relative h-[200px] sm:h-[240px] md:h-full">
          <Image src="/sujata_morning_routine.png" alt="Trial Pack" width={500} height={500} class="relative z-10 w-auto h-[80%] lg:h-[85%] object-cover rounded-3xl shadow-2xl border border-[#064E3B]/10"/>
          
          <div class="absolute bottom-[15%] right-[5%] md:right-[15%] bg-[#064E3B] text-white px-3 py-1.5 md:px-4 md:py-2 text-[10px] lg:text-xs font-black uppercase tracking-[0.2em] rounded shadow-xl rotate-6 z-30">
            BEGINNER FRIENDLY
          </div>
        </div>
      </div>
    </div>

    {/* ==========================================
        SLIDER CONTROLS (Dots strictly positioned above the target goal line)
        ========================================== */}
    <div class="absolute bottom-12 md:bottom-16 left-1/2 -translate-x-1/2 flex gap-3 z-30">
      <button class="slider-dot w-2.5 h-2.5 lg:w-3 lg:h-3 rounded-full bg-[#D97706] border border-white/40 transition-colors shadow-sm cursor-pointer" data-index="0" aria-label="Slide 1"></button>
      <button class="slider-dot w-2.5 h-2.5 lg:w-3 lg:h-3 rounded-full bg-gray-300 border border-white/40 hover:bg-[#D97706] transition-colors shadow-sm cursor-pointer" data-index="1" aria-label="Slide 2"></button>
      <button class="slider-dot w-2.5 h-2.5 lg:w-3 lg:h-3 rounded-full bg-gray-300 border border-white/40 hover:bg-[#D97706] transition-colors shadow-sm cursor-pointer" data-index="2" aria-label="Slide 3"></button>
      <button class="slider-dot w-2.5 h-2.5 lg:w-3 lg:h-3 rounded-full bg-gray-300 border border-white/40 hover:bg-[#D97706] transition-colors shadow-sm cursor-pointer" data-index="3" aria-label="Slide 4"></button>
    </div>

  </div>

  {/* ==========================================
      2. THE TARGET GOAL TRACK (Safely placed right below the slider)
      ========================================== */}
  <div class="relative w-full z-40 flex justify-center px-4 -mt-7 lg:-mt-8">
    <div class="bg-white/95 backdrop-blur-xl p-1.5 md:p-2 rounded-full shadow-[0_15px_40px_rgba(0,0,0,0.08)] border border-gray-100 flex items-center overflow-x-auto no-scrollbar max-w-full pointer-events-auto">

      <div class="hidden md:flex items-center gap-2 px-4 border-r border-gray-200">
        <span class="text-[9px] font-black text-gray-400 uppercase tracking-[0.2em]">Target Goal</span>
      </div>

      <div class="flex items-center gap-1 md:pl-2">
        <a href="#product-ecosystem" class="flex-shrink-0 flex items-center gap-2 px-5 lg:px-6 py-2.5 lg:py-3 bg-[#064E3B] text-white rounded-full shadow-md transition-all group">
          <svg class="w-3.5 h-3.5 lg:w-4 lg:h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
          <span class="text-[11px] lg:text-xs font-bold tracking-wide">Energy & Focus</span>
        </a>
        <a href="#product-ecosystem" class="flex-shrink-0 flex items-center gap-2 px-5 lg:px-6 py-2.5 lg:py-3 text-gray-500 hover:text-[#064E3B] hover:bg-gray-100 rounded-full transition-all group">
           <svg class="w-3.5 h-3.5 lg:w-4 lg:h-4 group-hover:text-[#064E3B] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
          <span class="text-[11px] lg:text-xs font-bold tracking-wide">Immunity</span>
        </a>
        <a href="#product-ecosystem" class="flex-shrink-0 flex items-center gap-2 px-5 lg:px-6 py-2.5 lg:py-3 text-gray-500 hover:text-[#064E3B] hover:bg-gray-100 rounded-full transition-all group">
          <svg class="w-3.5 h-3.5 lg:w-4 lg:h-4 group-hover:text-[#064E3B] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path></svg>
          <span class="text-[11px] lg:text-xs font-bold tracking-wide">Skin & Hair</span>
        </a>
        <a href="#product-ecosystem" class="flex-shrink-0 flex items-center gap-2 px-5 lg:px-6 py-2.5 lg:py-3 text-gray-500 hover:text-[#064E3B] hover:bg-gray-100 rounded-full transition-all group">
          <svg class="w-3.5 h-3.5 lg:w-4 lg:h-4 group-hover:text-[#064E3B] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
          <span class="text-[11px] lg:text-xs font-bold tracking-wide">Gut Health</span>
        </a>
      </div>

    </div>
  </div>
</section>

<script>
  function initHeroSlider() {
    const sliderContainer = document.getElementById('hero-slider');
    if (!sliderContainer || sliderContainer.dataset.initialized === 'true') return;
    sliderContainer.dataset.initialized = 'true';

    console.log("🎬 Hero Slider Engine Loading...");
    const slides = document.querySelectorAll('.slide');
    const dots = document.querySelectorAll('.slider-dot');
    let currentSlide = 0;
    const totalSlides = slides.length;
    let autoSlideInterval;

    function goToSlide(index) {
      slides.forEach((slide, i) => {
        const slideEl = slide as HTMLElement;
        if (i === index) {
          slideEl.style.transform = 'translateX(0)';
          slideEl.style.zIndex = '10';
          slideEl.style.opacity = '1';
        } else if (i < index) {
          slideEl.style.transform = 'translateX(-100%)';
          slideEl.style.zIndex = '0';
          setTimeout(() => { if(currentSlide !== i) slideEl.style.opacity = '0'; }, 500);
        } else {
          slideEl.style.transform = 'translateX(100%)';
          slideEl.style.zIndex = '0';
          setTimeout(() => { if(currentSlide !== i) slideEl.style.opacity = '0'; }, 500);
        }
      });

      dots.forEach((dot, i) => {
        if (i === index) {
          dot.classList.remove('bg-gray-300');
          dot.classList.add('bg-[#D97706]');
        } else {
          dot.classList.remove('bg-[#D97706]');
          dot.classList.add('bg-gray-300');
        }
      });
      currentSlide = index;
    }

    function nextSlide() {
      const next = (currentSlide + 1) % totalSlides;
      goToSlide(next);
    }

    const startAutoSlide = () => { autoSlideInterval = setInterval(nextSlide, 5000); };
    const stopAutoSlide = () => { clearInterval(autoSlideInterval); };

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        stopAutoSlide();
        goToSlide(index);
        startAutoSlide();
      });
    });

    goToSlide(0);
    startAutoSlide();
    
    sliderContainer?.addEventListener('mouseenter', stopAutoSlide);
    sliderContainer?.addEventListener('mouseleave', startAutoSlide);
  }

  // Bind for standard page load and client-side view transition
  document.addEventListener('DOMContentLoaded', initHeroSlider);
  document.addEventListener('astro:page-load', initHeroSlider);
</script>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>