---
// src/components/StoreHero.astro
---

<section id="d2c-performance-hero" class="relative w-full font-['Inter'] z-20">

  {/* ==========================================
      1. THE MASTER SLIDER CONTAINER (Pure CSS Height - No JS Bugs!)
      ========================================== */}
  {/* The container has strict min-heights to support 14-inch laptops and large monitors flawlessly */}
  <div class="relative w-full overflow-hidden bg-[#F8FAFC] h-[90vh] min-h-[650px] lg:min-h-[750px] max-h-[900px]" id="hero-slider">
    
    {/* -----------------------------------
        SLIDE 1: THE BIG DISCOUNT
        ----------------------------------- */}
    <div class="slide absolute inset-0 w-full h-full transition-transform duration-700 ease-[cubic-bezier(0.25,1,0.5,1)] translate-x-0" data-index="0">
      <div class="absolute inset-0 bg-gradient-to-r from-[#f8fafc] to-[#f0fdf4] z-0"></div>
      
      {/* pt-[120px] clears header safely. pb-[100px] guarantees dots will never overlap text/images */}
      <div class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-16 relative z-10 w-full h-full pt-[120px] lg:pt-[150px] pb-[100px] lg:pb-[120px] flex flex-col md:flex-row items-center justify-between gap-8 md:gap-4">
        
        <div class="w-full md:w-[55%] flex flex-col items-center md:items-start text-center md:text-left z-20">
          <h2 class="text-lg md:text-2xl lg:text-3xl font-medium text-gray-800 mb-2 font-['Playfair_Display']">Peak Energy Made Affordable</h2>
          
          <div class="flex flex-col items-center md:items-start mb-5 lg:mb-8">
            <span class="text-[#D97706] text-[clamp(4rem,6vw,6.5rem)] font-black leading-none tracking-tighter drop-shadow-sm">SAVE ₹500</span>
            <span class="text-base md:text-xl font-medium text-gray-600 mt-2">on 30-Day Spirulina Powder Kit</span>
          </div>

          <div class="flex items-center gap-4 mb-8 lg:mb-10">
            <span class="text-xl md:text-2xl text-gray-400 font-bold line-through decoration-red-500/50 decoration-2">₹1,999</span>
            <span class="text-4xl md:text-6xl font-black text-[#111827]">₹1,499</span>
          </div>

          <button class="bg-[#4D7C0F] hover:bg-[#3F6212] text-white text-base md:text-lg font-bold uppercase tracking-[0.15em] px-12 py-4 md:py-5 rounded-md shadow-[0_10px_20px_rgba(77,124,15,0.2)] transition-all transform hover:-translate-y-1 w-full sm:w-auto">
            SHOP NOW
          </button>
        </div>

        {/* 14-inch Laptop Safe Image Sizing */}
        <div class="w-full md:w-[45%] flex items-center justify-center relative h-[280px] md:h-full">
          <img src="/spirulina-powder.png" alt="Spirulina Kit" class="relative z-10 w-auto h-full max-h-[100%] object-contain drop-shadow-2xl" fetchpriority="high"/>
          <div class="absolute top-[5%] right-0 lg:right-[10%] bg-white/95 px-4 py-2 rounded-lg shadow-xl border border-gray-100 flex flex-col z-30">
            <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Net Qty.</span>
            <span class="text-xs md:text-sm font-black text-[#111827]">250g (30 Days)</span>
          </div>
        </div>
      </div>
    </div>

    {/* -----------------------------------
        SLIDE 2: THE BUNDLE OFFER
        ----------------------------------- */}
    <div class="slide absolute inset-0 w-full h-full transition-transform duration-700 ease-[cubic-bezier(0.25,1,0.5,1)] translate-x-full" data-index="1">
      <div class="absolute inset-0 bg-gradient-to-r from-[#eff6ff] to-[#f0f9ff] z-0"></div>
      
      <div class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-16 relative z-10 w-full h-full pt-[120px] lg:pt-[150px] pb-[100px] lg:pb-[120px] flex flex-col md:flex-row items-center justify-between gap-8 md:gap-4">
        
        <div class="w-full md:w-[55%] flex flex-col items-center md:items-start text-center md:text-left z-20">
          <h2 class="text-lg md:text-2xl lg:text-3xl font-medium text-gray-800 mb-2 font-['Playfair_Display']">Complete Cellular Immunity</h2>
          
          <div class="flex flex-col items-center md:items-start mb-5 lg:mb-8">
            <span class="text-[#0369A1] text-[clamp(3.5rem,5.5vw,6rem)] font-black leading-[0.9] tracking-tighter drop-shadow-sm uppercase">Buy 2 Get 1</span>
            <span class="text-xl md:text-3xl font-black text-[#0284C7] uppercase mt-2">Absolutely Free</span>
            <span class="text-base md:text-xl font-medium text-gray-600 mt-2">on Pure Spirulina Capsules</span>
          </div>

          <button class="bg-[#0369A1] hover:bg-[#0284C7] text-white text-base md:text-lg font-bold uppercase tracking-[0.15em] px-12 py-4 md:py-5 rounded-md shadow-[0_10px_20px_rgba(3,105,161,0.2)] transition-all transform hover:-translate-y-1 w-full sm:w-auto mt-2">
            CLAIM BUNDLE
          </button>
        </div>

        <div class="w-full md:w-[45%] flex items-center justify-center relative h-[280px] md:h-full">
          <img src="/spirulina-bottle.png" alt="Bottle 1" class="relative z-10 h-[75%] object-contain drop-shadow-xl -rotate-6 translate-x-4 opacity-90"/>
          <img src="/spirulina-bottle.png" alt="Bottle 2" class="relative z-20 h-[90%] object-contain drop-shadow-2xl"/>
          <img src="/spirulina-bottle.png" alt="Bottle 3" class="relative z-10 h-[75%] object-contain drop-shadow-xl rotate-6 -translate-x-4 opacity-90"/>
          
          <div class="absolute bottom-[10%] right-[5%] lg:right-[15%] bg-red-600 text-white px-3 py-1.5 md:px-4 md:py-2 text-xs font-black uppercase tracking-[0.2em] rounded shadow-xl -rotate-12 z-30 animate-pulse">
            FREE
          </div>
        </div>
      </div>
    </div>

    {/* -----------------------------------
        SLIDE 3: THE COMBO PACK
        ----------------------------------- */}
    <div class="slide absolute inset-0 w-full h-full transition-transform duration-700 ease-[cubic-bezier(0.25,1,0.5,1)] translate-x-full" data-index="2">
      <div class="absolute inset-0 bg-gradient-to-r from-[#fefce8] to-[#fffbeb] z-0"></div>
      
      <div class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-16 relative z-10 w-full h-full pt-[120px] lg:pt-[150px] pb-[100px] lg:pb-[120px] flex flex-col md:flex-row items-center justify-between gap-8 md:gap-4">
        
        <div class="w-full md:w-[55%] flex flex-col items-center md:items-start text-center md:text-left z-20">
          <h2 class="text-lg md:text-2xl lg:text-3xl font-medium text-gray-800 mb-2 font-['Playfair_Display']">The Ultimate Protocol</h2>
          
          <div class="flex flex-col items-center md:items-start mb-5 lg:mb-8">
            <span class="text-[#B45309] text-[clamp(4rem,6vw,6rem)] font-black leading-[0.9] tracking-tighter drop-shadow-sm uppercase">FLAT 30% OFF</span>
            <span class="text-base md:text-xl font-medium text-gray-600 mt-2">Powder + Capsules Dual Pack</span>
          </div>

          <button class="bg-[#B45309] hover:bg-[#92400E] text-white text-base md:text-lg font-bold uppercase tracking-[0.15em] px-12 py-4 md:py-5 rounded-md shadow-[0_10px_20px_rgba(180,83,9,0.2)] transition-all transform hover:-translate-y-1 w-full sm:w-auto mt-2">
            SHOP THE COMBO
          </button>
        </div>

        <div class="w-full md:w-[45%] flex items-center justify-center relative h-[280px] md:h-full">
          <img src="/spirulina-powder.png" alt="Powder" class="relative z-10 w-auto h-[85%] object-contain drop-shadow-2xl translate-x-6"/>
          <img src="/spirulina-bottle.png" alt="Bottle" class="relative z-20 w-auto h-[65%] object-contain drop-shadow-xl -translate-x-6 translate-y-6"/>
          
          <div class="absolute top-[10%] left-[5%] lg:left-[15%] bg-[#111827] text-[#F59E0B] px-3 py-1.5 md:px-4 md:py-2 text-[10px] md:text-xs font-black uppercase tracking-[0.2em] rounded shadow-xl -rotate-6 z-30">
            BEST VALUE
          </div>
        </div>
      </div>
    </div>

    {/* -----------------------------------
        SLIDE 4: THE LOW-BARRIER TRIAL
        ----------------------------------- */}
    <div class="slide absolute inset-0 w-full h-full transition-transform duration-700 ease-[cubic-bezier(0.25,1,0.5,1)] translate-x-full" data-index="3">
      <div class="absolute inset-0 bg-gradient-to-r from-[#fdf4ff] to-[#f5f3ff] z-0"></div>
      
      <div class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-16 relative z-10 w-full h-full pt-[120px] lg:pt-[150px] pb-[100px] lg:pb-[120px] flex flex-col md:flex-row items-center justify-between gap-8 md:gap-4">
        
        <div class="w-full md:w-[55%] flex flex-col items-center md:items-start text-center md:text-left z-20">
          <h2 class="text-lg md:text-2xl lg:text-3xl font-medium text-gray-800 mb-2 font-['Playfair_Display']">New to Spirulina?</h2>
          
          <div class="flex flex-col items-center md:items-start mb-5 lg:mb-8">
            <span class="text-[#7E22CE] text-[clamp(4.5rem,6vw,6.5rem)] font-black leading-none tracking-tighter drop-shadow-sm uppercase">7-DAY TRIAL</span>
            <span class="text-lg md:text-3xl font-black text-[#6B21A8] uppercase mt-2">AT JUST ₹499</span>
            <span class="text-sm md:text-lg font-medium text-gray-600 mt-2 lg:mt-3">Experience the energy shift. No commitments.</span>
          </div>

          <button class="bg-[#7E22CE] hover:bg-[#6B21A8] text-white text-base md:text-lg font-bold uppercase tracking-[0.15em] px-12 py-4 md:py-5 rounded-md shadow-[0_10px_20px_rgba(126,34,206,0.2)] transition-all transform hover:-translate-y-1 w-full sm:w-auto mt-2">
            START TRIAL
          </button>
        </div>

        <div class="w-full md:w-[45%] flex items-center justify-center relative h-[280px] md:h-full">
          <img src="/spirulina-bottle.png" alt="Trial Pack" class="relative z-10 w-auto h-[80%] lg:h-[85%] object-contain drop-shadow-xl"/>
          
          <div class="absolute bottom-[15%] right-[5%] md:right-[15%] bg-[#7E22CE] text-white px-3 py-1.5 md:px-4 md:py-2 text-[10px] lg:text-xs font-black uppercase tracking-[0.2em] rounded shadow-xl rotate-6 z-30">
            BEGINNER FRIENDLY
          </div>
        </div>
      </div>
    </div>

    {/* ==========================================
        SLIDER CONTROLS (Dots strictly positioned above the target goal line)
        ========================================== */}
    <div class="absolute bottom-12 md:bottom-16 left-1/2 -translate-x-1/2 flex gap-3 z-30">
      <button class="slider-dot w-2.5 h-2.5 lg:w-3 lg:h-3 rounded-full bg-gray-800 transition-colors shadow-sm cursor-pointer" data-index="0" aria-label="Slide 1"></button>
      <button class="slider-dot w-2.5 h-2.5 lg:w-3 lg:h-3 rounded-full bg-gray-300 hover:bg-gray-500 transition-colors shadow-sm cursor-pointer" data-index="1" aria-label="Slide 2"></button>
      <button class="slider-dot w-2.5 h-2.5 lg:w-3 lg:h-3 rounded-full bg-gray-300 hover:bg-gray-500 transition-colors shadow-sm cursor-pointer" data-index="2" aria-label="Slide 3"></button>
      <button class="slider-dot w-2.5 h-2.5 lg:w-3 lg:h-3 rounded-full bg-gray-300 hover:bg-gray-500 transition-colors shadow-sm cursor-pointer" data-index="3" aria-label="Slide 4"></button>
    </div>

  </div>

  {/* ==========================================
      2. THE TARGET GOAL TRACK (Safely placed right below the slider)
      ========================================== */}
  <div class="relative w-full z-40 flex justify-center px-4 -mt-7 lg:-mt-8">
    <div class="bg-white/95 backdrop-blur-xl p-1.5 md:p-2 rounded-full shadow-[0_15px_40px_rgba(0,0,0,0.08)] border border-gray-100 flex items-center overflow-x-auto no-scrollbar max-w-full pointer-events-auto">

      <div class="hidden md:flex items-center gap-2 px-4 border-r border-gray-200">
        <span class="text-[9px] font-black text-gray-400 uppercase tracking-[0.2em]">Target Goal</span>
      </div>

      <div class="flex items-center gap-1 md:pl-2">
        <a href="#energy" class="flex-shrink-0 flex items-center gap-2 px-5 lg:px-6 py-2.5 lg:py-3 bg-[#111827] text-white rounded-full shadow-md transition-all group">
          <svg class="w-3.5 h-3.5 lg:w-4 lg:h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
          <span class="text-[11px] lg:text-xs font-bold tracking-wide">Energy & Focus</span>
        </a>
        <a href="#immunity" class="flex-shrink-0 flex items-center gap-2 px-5 lg:px-6 py-2.5 lg:py-3 text-gray-500 hover:text-[#111827] hover:bg-gray-100 rounded-full transition-all group">
           <svg class="w-3.5 h-3.5 lg:w-4 lg:h-4 group-hover:text-[#166534] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
          <span class="text-[11px] lg:text-xs font-bold tracking-wide">Immunity</span>
        </a>
        <a href="#skin" class="flex-shrink-0 flex items-center gap-2 px-5 lg:px-6 py-2.5 lg:py-3 text-gray-500 hover:text-[#111827] hover:bg-gray-100 rounded-full transition-all group">
          <svg class="w-3.5 h-3.5 lg:w-4 lg:h-4 group-hover:text-[#166534] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path></svg>
          <span class="text-[11px] lg:text-xs font-bold tracking-wide">Skin & Hair</span>
        </a>
        <a href="#gut" class="flex-shrink-0 flex items-center gap-2 px-5 lg:px-6 py-2.5 lg:py-3 text-gray-500 hover:text-[#111827] hover:bg-gray-100 rounded-full transition-all group">
          <svg class="w-3.5 h-3.5 lg:w-4 lg:h-4 group-hover:text-[#166534] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
          <span class="text-[11px] lg:text-xs font-bold tracking-wide">Gut Health</span>
        </a>
      </div>

    </div>
  </div>
</section>

<script>
  // ULTRA-CLEAN JS (Only handles transitions and clicks. ZERO height calculations!)
  document.addEventListener('DOMContentLoaded', () => {
    const slides = document.querySelectorAll('.slide');
    const dots = document.querySelectorAll('.slider-dot');
    let currentSlide = 0;
    const totalSlides = slides.length;
    let autoSlideInterval;

    function goToSlide(index) {
      slides.forEach((slide, i) => {
        if (i === index) {
          slide.style.transform = 'translateX(0)';
          slide.style.zIndex = '10';
          slide.style.opacity = '1';
        } else if (i < index) {
          slide.style.transform = 'translateX(-100%)';
          slide.style.zIndex = '0';
          setTimeout(() => { if(currentSlide !== i) slide.style.opacity = '0'; }, 500);
        } else {
          slide.style.transform = 'translateX(100%)';
          slide.style.zIndex = '0';
          setTimeout(() => { if(currentSlide !== i) slide.style.opacity = '0'; }, 500);
        }
      });

      dots.forEach((dot, i) => {
        if (i === index) {
          dot.classList.remove('bg-gray-300');
          dot.classList.add('bg-gray-800');
        } else {
          dot.classList.remove('bg-gray-800');
          dot.classList.add('bg-gray-300');
        }
      });
      currentSlide = index;
    }

    function nextSlide() {
      const next = (currentSlide + 1) % totalSlides;
      goToSlide(next);
    }

    const startAutoSlide = () => { autoSlideInterval = setInterval(nextSlide, 4500); };
    const stopAutoSlide = () => { clearInterval(autoSlideInterval); };

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        stopAutoSlide();
        goToSlide(index);
        startAutoSlide();
      });
    });

    goToSlide(0);
    startAutoSlide();
    
    const sliderContainer = document.getElementById('hero-slider');
    sliderContainer?.addEventListener('mouseenter', stopAutoSlide);
    sliderContainer?.addEventListener('mouseleave', startAutoSlide);
  });
</script>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>