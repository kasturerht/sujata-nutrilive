---
// src/components/StoreHeader.astro
---

<header id="main-header" class="fixed top-0 w-full z-[100] transition-all duration-300">
  
  {/* 1. DYNAMIC ANNOUNCEMENT BAR (Urgency Engine) */}
  <div class="w-full bg-[#111827] text-white overflow-hidden py-2 border-b border-white/5">
    <div class="flex whitespace-nowrap animate-[marquee_25s_linear_infinite] hover:pause">
      <span class="text-[10px] md:text-xs font-bold uppercase tracking-[0.2em] px-8 border-r border-white/10 flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
        FLASH SALE: BUY 2 GET 1 FREE ON SPIRULINA POWDER
      </span>
      <span class="text-[10px] md:text-xs font-bold uppercase tracking-[0.2em] px-8 border-r border-white/10">
        🚀 FREE EXPRESS DELIVERY ABOVE ₹999
      </span>
      <span class="text-[10px] md:text-xs font-bold uppercase tracking-[0.2em] px-8 border-r border-white/10">
        🌿 100% PURE COLD-PRESSED FORMULATIONS
      </span>
      {/* Repeat for seamless loop */}
      <span class="text-[10px] md:text-xs font-bold uppercase tracking-[0.2em] px-8 border-r border-white/10 flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
        FLASH SALE: BUY 2 GET 1 FREE ON SPIRULINA POWDER
      </span>
    </div>
  </div>

  {/* 2. THE UTILITY HEADER (Kapiva Style Details) */}
  <nav class="bg-white/95 backdrop-blur-md border-b border-gray-100 px-4 md:px-8 py-3">
    <div class="max-w-[95rem] mx-auto flex items-center justify-between gap-4 md:gap-8">
      
      {/* Logo */}
      <a href="/" class="flex-shrink-0">
        <h1 class="text-xl md:text-2xl font-black text-[#111827] tracking-tighter">
          SUJATA<span class="text-[#166534]">.</span>
        </h1>
      </a>

      {/* Pincode Tracker (Trust Element) */}
      <div class="hidden lg:flex items-center gap-3 px-4 py-2 bg-gray-50 rounded-xl border border-gray-200 cursor-pointer hover:bg-white transition-all group relative" id="pincode-trigger">
        <svg class="w-4 h-4 text-[#166534]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
        <div class="flex flex-col">
          <span class="text-[9px] uppercase font-bold text-gray-400">Deliver to</span>
          <span class="text-[11px] font-black text-[#111827]" id="display-pincode">Check Pincode</span>
        </div>
        
        {/* Pincode Mini-Popup (Hidden by default) */}
        <div id="pincode-popup" class="absolute top-[110%] left-0 w-64 bg-white shadow-2xl rounded-2xl p-5 border border-gray-100 opacity-0 pointer-events-none transition-all scale-95 z-50">
          <p class="text-xs font-bold text-[#111827] mb-3">Verify Pincode for Accuracy</p>
          <div class="flex gap-2">
            <input type="text" id="pincode-input" maxlength="6" placeholder="Enter Pincode" class="w-full bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-xs focus:ring-1 focus:ring-[#166534] outline-none" />
            <button id="verify-btn" class="bg-[#111827] text-white px-4 py-2 rounded-lg text-[10px] font-bold uppercase tracking-widest hover:bg-[#166534]">Verify</button>
          </div>
          <p id="pincode-status" class="text-[9px] mt-2 hidden"></p>
        </div>
      </div>

      {/* Main Search Bar (Intent Capture) */}
      <div class="flex-1 max-w-xl relative group">
        <input 
          type="text" 
          placeholder="Search for 'Hair Oil', 'Spirulina Capsules'..." 
          class="w-full bg-gray-50 border border-gray-200 rounded-2xl px-5 py-3 text-sm focus:bg-white focus:ring-2 focus:ring-[#166534]/10 focus:border-[#166534] outline-none transition-all pl-12"
        />
        <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 group-focus-within:text-[#166534] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
      </div>

      {/* Action Icons */}
      <div class="flex items-center gap-2 md:gap-5">
        <a href="/account" class="hidden sm:flex flex-col items-center gap-1 group">
          <svg class="w-5 h-5 text-gray-600 group-hover:text-[#166534] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
          <span class="text-[9px] font-bold uppercase text-gray-500 group-hover:text-[#166534]">Profile</span>
        </a>
        <button id="cart-drawer-trigger" class="relative bg-[#111827] text-white p-3 md:px-5 md:py-3 rounded-2xl flex items-center gap-3 hover:bg-[#166534] transition-all shadow-lg">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
          <span class="hidden md:block text-xs font-bold uppercase tracking-widest">Cart</span>
          <span id="header-cart-badge" class="absolute -top-1 -right-1 w-5 h-5 bg-[#166534] border-2 border-white text-[10px] font-black rounded-full flex items-center justify-center">0</span>
        </button>
      </div>

    </div>
  </nav>
</header>

<style is:global>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>

<script>
  // TASK 1 LOGIC ENGINE
  document.addEventListener('DOMContentLoaded', () => {
    
    // 1. Pincode Popup Toggle
    const trigger = document.getElementById('pincode-trigger');
    const popup = document.getElementById('pincode-popup');
    const input = document.getElementById('pincode-input') as HTMLInputElement;
    const verifyBtn = document.getElementById('verify-btn');
    const status = document.getElementById('pincode-status');
    const displayPincode = document.getElementById('display-pincode');

    trigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      popup?.classList.toggle('opacity-0');
      popup?.classList.toggle('pointer-events-none');
      popup?.classList.toggle('translate-y-2');
    });

    // 2. Logic Hook (Ready for API integration)
    verifyBtn?.addEventListener('click', () => {
      const pin = input.value;
      if(pin.length === 6) {
        status!.innerText = "🔍 Checking availability...";
        status!.classList.remove('hidden', 'text-red-500');
        status!.classList.add('text-gray-500');

        // SIMULATED BACKEND LOGIC (Apan nantar ithe API call taku)
        setTimeout(() => {
          status!.innerText = "✅ Deliverable to " + pin;
          status!.classList.replace('text-gray-500', 'text-[#166534]');
          displayPincode!.innerText = pin;
          
          // Save to memory
          localStorage.setItem('user_pincode', pin);
          
          setTimeout(() => {
             popup?.classList.add('opacity-0', 'pointer-events-none');
          }, 1500);
        }, 1000);

      } else {
        status!.innerText = "❌ Invalid Pincode";
        status!.classList.remove('hidden');
        status!.classList.add('text-red-500');
      }
    });

    // Close popup on click outside
    document.addEventListener('click', () => {
      popup?.classList.add('opacity-0', 'pointer-events-none');
    });
    popup?.addEventListener('click', (e) => e.stopPropagation());

  });
</script>