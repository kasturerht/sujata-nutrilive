    {/* -----------------------------------
        SLIDE 1: THE BIG DISCOUNT (Clinical Dark Theme)
        ----------------------------------- */}
    <div class="slide absolute inset-0 w-full h-full transition-transform duration-700 ease-[cubic-bezier(0.25,1,0.5,1)] translate-x-0" data-index="0">
      <div class="absolute inset-0 bg-gradient-to-r from-[#022c22] to-[#064e3b] z-0"></div>
      
      <div class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-16 relative z-10 w-full h-full pt-[100px] md:pt-[140px] pb-[80px] md:pb-[100px] flex flex-col md:flex-row items-center justify-between gap-6 md:gap-4">
        
        <div class="w-full md:w-[55%] flex flex-col items-center md:items-start text-center md:text-left z-20">
          <h2 class="text-base sm:text-lg md:text-2xl lg:text-3xl font-medium text-emerald-100 mb-1 md:mb-2 font-['Playfair_Display']">Peak Energy Made Affordable</h2>
          
          <div class="flex flex-col items-center md:items-start mb-4 md:mb-5 lg:mb-8">
            <span class="text-[#D97706] text-[clamp(2.5rem,5.5vw,5.5rem)] font-black leading-none tracking-tighter drop-shadow-sm">SAVE ₹500</span>
            <span class="text-xs sm:text-base md:text-xl font-medium text-emerald-200/80 mt-1 md:mt-2">on 30-Day Spirulina Powder Kit</span>
          </div>

          <div class="flex items-center gap-4 mb-6 md:mb-8 lg:mb-10">
            <span class="text-lg md:text-2xl text-emerald-300/50 font-bold line-through decoration-red-500/80 decoration-2">₹1,999</span>
            <span class="text-3xl md:text-5xl lg:text-6xl font-black text-white">₹1,499</span>
          </div>

          <a href="#product-ecosystem" class="bg-[#D97706] hover:bg-[#B45309] text-white text-center text-sm md:text-base lg:text-lg font-bold uppercase tracking-[0.15em] px-8 sm:px-12 py-3.5 md:py-4 rounded-md shadow-[0_10px_20px_rgba(217,119,6,0.3)] transition-all transform hover:-translate-y-1 w-full sm:w-auto">
            SHOP NOW
          </a>
        </div>

        <div class="w-full md:w-[45%] flex items-center justify-center relative h-[220px] sm:h-[260px] md:h-full group">
          <div class="absolute inset-0 bg-gradient-to-tr from-[#022c22] to-[#064e3b] z-0 rounded-[2.5rem] border border-emerald-500/10"></div>
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(52,211,153,0.15)_0%,transparent_70%)] rounded-[2.5rem]"></div>
