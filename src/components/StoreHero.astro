---
// src/components/StoreHero.astro
---
{/* The Track: 400vh gives smooth scrolling time for both mobile swipe and desktop scroll */}
<section id="scrolly-track" class="relative h-[400vh] w-full bg-[#022c22] font-['Inter'] selection:bg-emerald-900 selection:text-white">
  
  {/* The Sticky Canvas: 100svh prevents jumping on mobile browsers (Safari/Chrome) */}
  <div id="sticky-canvas" class="sticky top-0 h-[100svh] w-full overflow-hidden flex items-center justify-center transition-colors duration-700">
    
    {/* DYNAMIC BACKGROUND LAYER */}
    <div id="bg-ocean" class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,#064e3b_0%,#022c22_100%)] opacity-100 z-0 transition-opacity duration-300"></div>
    <div id="bg-clinical" class="absolute inset-0 bg-[#FAF9F6] opacity-0 z-0 transition-opacity duration-300"></div>
    <div id="bg-grid" class="absolute inset-0 bg-[linear-gradient(to_right,#052e1608_1px,transparent_1px),linear-gradient(to_bottom,#052e1608_1px,transparent_1px)] bg-[size:32px_32px] opacity-0 z-0 transition-opacity duration-700"></div>
    <div class="absolute inset-0 bg-[url('/noise.svg')] opacity-[0.03] mix-blend-overlay z-0"></div>

    {/* MOBILE FIX: Adjusted padding (pt-16 for mobile, pt-24 for desktop) to save space */}
    <div class="max-w-[90rem] mx-auto px-5 md:px-6 lg:px-12 w-full relative z-10 flex flex-col lg:flex-row items-center justify-center h-full pt-16 lg:pt-24 pb-6 lg:pb-10">
      
      {/* LEFT SIDE: Typography Container */}
      {/* MOBILE FIX: Gave exact 40% height to text on mobile to ensure it doesn't push the bottle out */}
      <div class="w-full lg:w-1/2 h-[45svh] lg:h-full relative flex flex-col justify-start lg:justify-center z-30">
        
        {/* NARRATIVE 1 */}
        <div id="text-step-1" class="absolute left-0 top-4 lg:top-1/2 lg:-translate-y-1/2 w-full pr-2 lg:pr-8 transition-all duration-300">
          <p class="text-emerald-400 font-bold tracking-[0.2em] uppercase text-[9px] md:text-xs mb-2 md:mb-4">Phase 01: The Source</p>
          {/* MOBILE FIX: text-[clamp(2.2rem...)] ensures it's small enough for 375px screens but huge on desktop */}
          <h1 class="text-[clamp(2.2rem,9vw,5rem)] font-['Playfair_Display'] font-black leading-[1.05] text-white tracking-tighter drop-shadow-md">
            Born in <br/> <span class="italic text-emerald-300">Pure Waters.</span>
          </h1>
          <p class="mt-3 md:mt-6 text-sm md:text-lg text-emerald-100/80 font-light max-w-md leading-relaxed">Deep in isolated, pristine aquatic farms, we cultivate the earth's oldest and most nutrient-dense living organism.</p>
        </div>

        {/* NARRATIVE 2 */}
        <div id="text-step-2" class="absolute left-0 top-4 lg:top-1/2 lg:-translate-y-1/2 w-full pr-2 lg:pr-8 opacity-0 translate-y-10 transition-all duration-300">
          <p class="text-teal-600 font-bold tracking-[0.2em] uppercase text-[9px] md:text-xs mb-2 md:mb-4">Phase 02: The Extraction</p>
          <h1 class="text-[clamp(2.2rem,9vw,5rem)] font-['Playfair_Display'] font-black leading-[1.05] text-[#111827] tracking-tighter">
            Refined by <br/> <span class="italic text-teal-600">Cold Science.</span>
          </h1>
          <p class="mt-3 md:mt-6 text-sm md:text-lg text-gray-600 font-light max-w-md leading-relaxed">Zero heat. Zero chemicals. Our advanced cold-press extraction preserves 100% of the active Phycocyanin and raw proteins.</p>
        </div>

        {/* NARRATIVE 3 */}
        <div id="text-step-3" class="absolute left-0 top-4 lg:top-1/2 lg:-translate-y-1/2 w-full pr-2 lg:pr-8 opacity-0 translate-y-10 transition-all duration-300">
          <p class="text-[#166534] font-bold tracking-[0.2em] uppercase text-[9px] md:text-xs mb-2 md:mb-4">Phase 03: The Form</p>
          <h1 class="text-[clamp(2.2rem,9vw,5rem)] font-['Playfair_Display'] font-black leading-[1.05] text-[#111827] tracking-tighter">
            Delivered for <br/> <span class="italic text-[#166534]">Your Focus.</span>
          </h1>
          <p class="mt-3 md:mt-6 text-sm md:text-lg text-gray-600 font-light max-w-md leading-relaxed hidden sm:block">Absolute clinical purity in every serving. Ready to supercharge your cells, ignite your energy, and elevate your mind.</p>
          <p class="mt-3 text-sm text-gray-600 font-light max-w-md leading-relaxed sm:hidden">Absolute clinical purity in every serving. Ignite your energy and elevate your mind.</p>
          
          <div class="mt-5 md:mt-8">
            <a href="#shop" class="group relative inline-flex items-center justify-center px-6 py-3.5 md:px-8 md:py-4 bg-[#111827] text-white rounded-full font-bold text-[11px] md:text-sm uppercase tracking-wider overflow-hidden transition-all hover:scale-105 shadow-xl hover:shadow-[0_20px_40px_rgba(0,0,0,0.2)]">
              <span class="relative z-10 flex items-center gap-2 md:gap-3">
                Experience Sujata
                <svg class="w-3.5 h-3.5 md:w-4 md:h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
              </span>
              <div class="absolute inset-0 bg-[#166534] transform scale-x-0 origin-left transition-transform duration-500 ease-out group-hover:scale-x-100 z-0"></div>
            </a>
          </div>
        </div>

      </div>

      {/* RIGHT SIDE: The Visual Journey */}
      {/* MOBILE FIX: Gave 55svh to visual on mobile so bottle has room to breathe */}
      <div class="w-full lg:w-1/2 h-[55svh] lg:h-full relative flex items-center justify-center mt-2 lg:mt-0 z-20">
        
        {/* Visual 1: Raw Energy Orb */}
        <div id="visual-orb" class="absolute w-[80vw] h-[80vw] lg:w-[35vw] lg:h-[35vw] rounded-full bg-gradient-to-tr from-emerald-500 to-teal-300 blur-[50px] md:blur-[80px] opacity-40 mix-blend-screen transition-transform duration-100 z-0"></div>
        
        {/* Visual 2: The Data Rings */}
        <div id="visual-rings" class="absolute inset-0 flex items-center justify-center opacity-0 scale-150 transition-transform duration-100 z-10">
          <div class="w-[85%] h-[85%] lg:w-[80%] lg:h-[80%] rounded-full border border-teal-500/30 border-dashed animate-[spin_20s_linear_infinite]"></div>
          <div class="absolute w-[65%] h-[65%] lg:w-[60%] lg:h-[60%] rounded-full border border-teal-400/50 border-dotted animate-[spin_15s_linear_infinite_reverse]"></div>
        </div>

        {/* Visual 3: THE PRODUCT BOTTLE */}
        <div id="visual-bottle-container" class="absolute inset-0 flex items-center justify-center scale-[0.85] transition-all duration-100 z-20">
          
          <div id="bottle-shadow" class="absolute bottom-[5%] lg:bottom-[15%] w-[45%] h-5 md:h-8 bg-black/15 blur-xl rounded-[100%] opacity-0 transition-opacity duration-300"></div>
          
          {/* MOBILE FIX: max-h-[45svh] ensures bottle doesn't overflow its container on tiny phones */}
          <img 
            src="/spirulina-bottle.png" 
            alt="Sujata Nutrilive Pure Spirulina" 
            id="the-bottle"
            class="relative z-10 w-auto h-auto max-h-[45svh] lg:max-h-[55vh] max-w-[70%] lg:max-w-[320px] object-contain drop-shadow-[0_15px_30px_rgba(0,0,0,0.4)] transition-all duration-300 animate-[float_6s_ease-in-out_infinite]"
          />

          {/* Premium Floating Badges - Closer to bottle on mobile */}
          <div id="badge-1" class="absolute top-[10%] lg:top-[20%] left-0 lg:-left-10 bg-white/95 backdrop-blur-md px-2.5 py-1.5 md:px-4 md:py-2 rounded-lg md:rounded-xl shadow-xl border border-gray-100 flex items-center gap-1.5 md:gap-2 opacity-0 translate-y-5 transition-all duration-500 z-30">
            <span class="w-1.5 h-1.5 md:w-2.5 md:h-2.5 rounded-full bg-emerald-500 animate-pulse"></span>
            <span class="text-[9px] md:text-xs font-bold text-gray-900 uppercase tracking-wider whitespace-nowrap">Lab Tested</span>
          </div>
          <div id="badge-2" class="absolute bottom-[15%] lg:bottom-[25%] right-0 lg:-right-5 bg-white/95 backdrop-blur-md px-2.5 py-1.5 md:px-4 md:py-2 rounded-lg md:rounded-xl shadow-xl border border-gray-100 flex items-center gap-1.5 md:gap-2 opacity-0 translate-y-5 transition-all duration-500 z-30">
            <span class="w-1.5 h-1.5 md:w-2.5 md:h-2.5 rounded-full bg-[#166534]"></span>
            <span class="text-[9px] md:text-xs font-bold text-gray-900 uppercase tracking-wider whitespace-nowrap">100% Pure</span>
          </div>

        </div>

      </div>
    </div>
    
    {/* THE "SCROLL TO DISCOVER" INDICATOR (Moved slightly up for mobile safe areas) */}
    <div id="scroll-indicator" class="absolute bottom-8 md:bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 transition-opacity duration-500 z-50">
      <span class="text-emerald-300/80 text-[8px] md:text-[10px] font-bold uppercase tracking-[0.2em] whitespace-nowrap">Scroll to Discover</span>
      <div class="w-3.5 h-6 md:w-5 md:h-8 border-2 border-emerald-300/50 rounded-full flex justify-center pt-1 md:pt-1.5">
        <div class="w-1 h-1.5 md:h-2 bg-emerald-400 rounded-full animate-[bounce_1.5s_infinite]"></div>
      </div>
    </div>

  </div>
</section>

<style is:global>
  @keyframes float { 0% { transform: translateY(0px); } 50% { transform: translateY(-10px); } 100% { transform: translateY(0px); } }
</style>

<script>
  // Script remains untouched! The magic is entirely in the CSS/Tailwind updates.
  document.addEventListener('DOMContentLoaded', () => {
    const track = document.getElementById('scrolly-track');
    const bgOcean = document.getElementById('bg-ocean');
    const bgClinical = document.getElementById('bg-clinical');
    const bgGrid = document.getElementById('bg-grid');
    const text1 = document.getElementById('text-step-1');
    const text2 = document.getElementById('text-step-2');
    const text3 = document.getElementById('text-step-3');
    const orb = document.getElementById('visual-orb');
    const rings = document.getElementById('visual-rings');
    const bottleContainer = document.getElementById('visual-bottle-container');
    const bottle = document.getElementById('the-bottle');
    const bottleShadow = document.getElementById('bottle-shadow');
    const badge1 = document.getElementById('badge-1');
    const badge2 = document.getElementById('badge-2');
    const scrollIndicator = document.getElementById('scroll-indicator');

    const easeOutCubic = x => 1 - Math.pow(1 - x, 3);

    function onScroll() {
      const rect = track.getBoundingClientRect();
      const trackTop = rect.top;
      const trackHeight = rect.height - window.innerHeight;
      let progress = -trackTop / trackHeight;
      progress = Math.max(0, Math.min(1, progress));

      if (progress > 0.02) scrollIndicator.style.opacity = '0';
      else scrollIndicator.style.opacity = '1';

      if (progress < 0.33) {
        const localProgress = progress / 0.33; 
        text1.style.opacity = 1 - Math.pow(localProgress, 3);
        text1.style.transform = `translateY(${localProgress * -20}px)`;
        text2.style.opacity = 0; text3.style.opacity = 0;

        bottleContainer.style.transform = `scale(0.85) translateY(${localProgress * 20}px)`;
        bottle.style.filter = `brightness(${0.8 + (localProgress * 0.2)}) drop-shadow(0 20px 40px rgba(0,0,0,0.5))`;
        bottleShadow.style.opacity = 0;

        orb.style.opacity = 0.5 - (localProgress * 0.3);
        orb.style.transform = `scale(${1 - (localProgress * 0.5)})`;
        rings.style.opacity = localProgress;
        rings.style.transform = `scale(${1.5 - (localProgress * 0.5)})`;
        
        bgOcean.style.opacity = 1; bgClinical.style.opacity = 0; bgGrid.style.opacity = 0;
      }
      else if (progress >= 0.33 && progress < 0.66) {
        const localProgress = (progress - 0.33) / 0.33;
        text1.style.opacity = 0;
        
        if (localProgress < 0.2) {
          text2.style.opacity = localProgress * 5; 
          text2.style.transform = `translateY(${(1 - localProgress*5) * 20}px)`;
        } else if (localProgress > 0.8) {
          const fadeOut = (1 - localProgress) * 5;
          text2.style.opacity = fadeOut;
          text2.style.transform = `translateY(${(1 - fadeOut) * -20}px)`;
        } else {
          text2.style.opacity = 1; text2.style.transform = `translateY(0px)`;
        }
        text3.style.opacity = 0;

        orb.style.opacity = 0;
        rings.style.opacity = Math.sin(localProgress * Math.PI); 
        rings.style.transform = `scale(${1 - (localProgress * 0.2)}) rotate(${localProgress * 90}deg)`;
        
        bottleContainer.style.transform = `scale(${0.85 + (localProgress * 0.1)}) translateY(0px)`;
        bottle.style.filter = `brightness(1) drop-shadow(0 20px 40px rgba(0,0,0,0.3))`;
        bottleShadow.style.opacity = localProgress * 0.5;
        
        bgOcean.style.opacity = 1 - localProgress; bgClinical.style.opacity = localProgress; bgGrid.style.opacity = localProgress * 0.5;
        badge1.style.opacity = 0; badge2.style.opacity = 0;
      }
      else if (progress >= 0.66) {
        const localProgress = (progress - 0.66) / 0.34;
        const smoothProgress = easeOutCubic(localProgress);
        
        text1.style.opacity = 0; text2.style.opacity = 0;
        text3.style.opacity = Math.min(1, localProgress * 3);
        text3.style.transform = `translateY(${Math.max(0, 20 - (localProgress * 60))}px)`;

        rings.style.opacity = 0;
        
        bottleContainer.style.transform = `scale(${0.95 + (smoothProgress * 0.05)}) translateY(0px)`;
        bottle.style.filter = `brightness(1) drop-shadow(0 30px 50px rgba(0,0,0,0.15))`;
        bottleShadow.style.opacity = 0.5 + (smoothProgress * 0.5); 
        
        if (localProgress > 0.5) {
          badge1.style.opacity = (localProgress - 0.5) * 2;
          badge1.style.transform = `translateY(${Math.max(0, 10 - ((localProgress - 0.5) * 40))}px)`;
          badge2.style.opacity = (localProgress - 0.5) * 2;
          badge2.style.transform = `translateY(${Math.max(0, 10 - ((localProgress - 0.5) * 40))}px)`;
        } else {
          badge1.style.opacity = 0; badge2.style.opacity = 0;
        }

        bgOcean.style.opacity = 0; bgClinical.style.opacity = 1; bgGrid.style.opacity = 1;
      }
    }

    window.addEventListener('scroll', () => { requestAnimationFrame(onScroll); }, { passive: true });
    onScroll(); 
  });
</script>