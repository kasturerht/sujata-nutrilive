    </div>

    {/* -----------------------------------
        SLIDE 2: THE BUNDLE OFFER (Clinical Mint Theme)
        ----------------------------------- */}
    <div class="slide absolute inset-0 w-full h-full transition-transform duration-700 ease-[cubic-bezier(0.25,1,0.5,1)] translate-x-full" data-index="1">
