---
// src/components/StoreHero.astro
---
{/* The Track: This section is 400vh tall to give us plenty of scrolling room */}
<section id="scrolly-track" class="relative h-[400vh] w-full bg-[#022c22] font-['Inter'] selection:bg-emerald-900 selection:text-white">
  
  {/* The Sticky Canvas: Locks to the screen while scrolling the track */}
  <div id="sticky-canvas" class="sticky top-0 h-[100svh] w-full overflow-hidden flex items-center justify-center transition-colors duration-700">
    
    {/* DYNAMIC BACKGROUND LAYER */}
    <div id="bg-ocean" class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,#064e3b_0%,#022c22_100%)] opacity-100 z-0 transition-opacity duration-300"></div>
    <div id="bg-clinical" class="absolute inset-0 bg-[#FAF9F6] opacity-0 z-0 transition-opacity duration-300"></div>
    
    {/* Clinical Grid (Hidden initially, shows in Phase 3) */}
    <div id="bg-grid" class="absolute inset-0 bg-[linear-gradient(to_right,#052e1608_1px,transparent_1px),linear-gradient(to_bottom,#052e1608_1px,transparent_1px)] bg-[size:32px_32px] opacity-0 z-0 transition-opacity duration-700"></div>
    
    <div class="absolute inset-0 bg-[url('/noise.svg')] opacity-[0.03] mix-blend-overlay z-0"></div>

    <div class="max-w-[90rem] mx-auto px-6 lg:px-12 w-full relative z-10 flex flex-col lg:flex-row items-center h-full">
      
      {/* LEFT SIDE: Dynamic Narrative Typography */}
      <div class="w-full lg:w-1/2 h-[40vh] lg:h-[60vh] relative flex flex-col justify-center">
        
        {/* NARRATIVE 1: The Origin (Visible immediately) */}
        <div id="text-step-1" class="absolute left-0 top-1/2 -translate-y-1/2 w-full pr-8 transition-all duration-300">
          <p class="text-emerald-400 font-bold tracking-[0.25em] uppercase text-xs mb-4">Phase 01: The Source</p>
          <h1 class="text-[clamp(3rem,6vw,5.5rem)] font-['Playfair_Display'] font-black leading-[0.95] text-white tracking-tighter drop-shadow-md">
            Born in <br/> <span class="italic text-emerald-300">Pure Waters.</span>
          </h1>
          <p class="mt-6 text-lg text-emerald-100/80 font-light max-w-md">Deep in isolated, pristine aquatic farms, we cultivate the earth's oldest and most nutrient-dense living organism.</p>
        </div>

        {/* NARRATIVE 2: The Process */}
        <div id="text-step-2" class="absolute left-0 top-1/2 -translate-y-1/2 w-full pr-8 opacity-0 translate-y-10 transition-all duration-300">
          <p class="text-teal-600 font-bold tracking-[0.25em] uppercase text-xs mb-4">Phase 02: The Extraction</p>
          <h1 class="text-[clamp(3rem,6vw,5.5rem)] font-['Playfair_Display'] font-black leading-[0.95] text-[#111827] tracking-tighter">
            Refined by <br/> <span class="italic text-teal-600">Cold Science.</span>
          </h1>
          <p class="mt-6 text-lg text-gray-600 font-light max-w-md">Zero heat. Zero chemicals. Our advanced cold-press extraction preserves 100% of the active Phycocyanin and raw proteins.</p>
        </div>

        {/* NARRATIVE 3: The Form */}
        <div id="text-step-3" class="absolute left-0 top-1/2 -translate-y-1/2 w-full pr-8 opacity-0 translate-y-10 transition-all duration-300">
          <p class="text-[#166534] font-bold tracking-[0.25em] uppercase text-xs mb-4">Phase 03: The Form</p>
          <h1 class="text-[clamp(3rem,6vw,5.5rem)] font-['Playfair_Display'] font-black leading-[0.95] text-[#111827] tracking-tighter">
            Delivered for <br/> <span class="italic text-[#166534]">Your Focus.</span>
          </h1>
          <p class="mt-6 text-lg text-gray-600 font-light max-w-md">Absolute clinical purity in every serving. Ready to supercharge your cells, ignite your energy, and elevate your mind.</p>
          
          <div class="mt-8">
            <a href="#shop" class="group relative inline-flex items-center justify-center px-8 py-4 bg-[#111827] text-white rounded-full font-bold text-sm uppercase tracking-wider overflow-hidden transition-all hover:scale-105 shadow-xl hover:shadow-[0_20px_40px_rgba(0,0,0,0.2)]">
              <span class="relative z-10 flex items-center gap-3">
                Experience Sujata
                <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
              </span>
              <div class="absolute inset-0 bg-[#166534] transform scale-x-0 origin-left transition-transform duration-500 ease-out group-hover:scale-x-100 z-0"></div>
            </a>
          </div>
        </div>

      </div>

      {/* RIGHT SIDE: The Visual Journey (Product visible from second 1) */}
      <div class="w-full lg:w-1/2 h-[50vh] lg:h-[80vh] relative flex items-center justify-center mt-10 lg:mt-0">
        
        {/* Visual 1: Raw Energy Orb (Underwater glow) */}
        <div id="visual-orb" class="absolute w-[60vw] h-[60vw] lg:w-[40vw] lg:h-[40vw] rounded-full bg-gradient-to-tr from-emerald-500 to-teal-300 blur-[80px] opacity-50 mix-blend-screen transition-transform duration-100 z-0"></div>
        
        {/* Visual 2: The Data Rings (Extraction phase) */}
        <div id="visual-rings" class="absolute inset-0 flex items-center justify-center opacity-0 scale-150 transition-transform duration-100 z-10">
          <div class="w-[80%] h-[80%] rounded-full border border-teal-500/40 border-dashed animate-[spin_20s_linear_infinite]"></div>
          <div class="absolute w-[60%] h-[60%] rounded-full border border-teal-400/60 border-dotted animate-[spin_15s_linear_infinite_reverse]"></div>
        </div>

        {/* Visual 3: THE PRODUCT BOTTLE (Always visible, but transforms) */}
        <div id="visual-bottle-container" class="absolute inset-0 flex items-center justify-center scale-[0.85] transition-all duration-100 mt-10 lg:mt-0 z-20">
          
          {/* Clinical Shadow (Hidden in phase 1, shows in phase 3) */}
          <div id="bottle-shadow" class="absolute bottom-[15%] w-[50%] h-8 bg-black/15 blur-xl rounded-[100%] opacity-0 transition-opacity duration-300"></div>
          
          {/* THE BOTTLE */}
          <img 
            src="/spirulina-bottle.png" 
            alt="Sujata Nutrilive Pure Spirulina" 
            id="the-bottle"
            class="relative z-10 w-[70%] max-w-[350px] object-contain drop-shadow-[0_20px_40px_rgba(0,0,0,0.5)] transition-all duration-300 animate-[float_6s_ease-in-out_infinite]"
          />

          {/* Premium Floating Badges (Appear only at the end) */}
          <div id="badge-1" class="absolute top-[20%] -left-10 bg-white/95 backdrop-blur-md px-4 py-2 rounded-xl shadow-xl border border-gray-100 flex items-center gap-2 opacity-0 translate-y-5 transition-all duration-500 z-30">
            <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse"></span>
            <span class="text-xs font-bold text-gray-900 uppercase tracking-wider">Lab Tested</span>
          </div>
          <div id="badge-2" class="absolute bottom-[25%] -right-5 bg-white/95 backdrop-blur-md px-4 py-2 rounded-xl shadow-xl border border-gray-100 flex items-center gap-2 opacity-0 translate-y-5 transition-all duration-500 z-30">
            <span class="w-2.5 h-2.5 rounded-full bg-[#166534]"></span>
            <span class="text-xs font-bold text-gray-900 uppercase tracking-wider">100% Pure</span>
          </div>

        </div>

      </div>
    </div>
    
    {/* THE "SCROLL TO DISCOVER" INDICATOR (Guides the user) */}
    <div id="scroll-indicator" class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 transition-opacity duration-500 z-50">
      <span class="text-emerald-300/80 text-[10px] font-bold uppercase tracking-[0.2em]">Scroll to Discover</span>
      <div class="w-5 h-8 border-2 border-emerald-300/50 rounded-full flex justify-center pt-1.5">
        <div class="w-1 h-2 bg-emerald-400 rounded-full animate-[bounce_1.5s_infinite]"></div>
      </div>
    </div>

  </div>
</section>

<style is:global>
  @keyframes float { 0% { transform: translateY(0px); } 50% { transform: translateY(-15px); } 100% { transform: translateY(0px); } }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const track = document.getElementById('scrolly-track');
    
    // Backgrounds
    const bgOcean = document.getElementById('bg-ocean');
    const bgClinical = document.getElementById('bg-clinical');
    const bgGrid = document.getElementById('bg-grid');
    
    // Texts
    const text1 = document.getElementById('text-step-1');
    const text2 = document.getElementById('text-step-2');
    const text3 = document.getElementById('text-step-3');
    
    // Visuals
    const orb = document.getElementById('visual-orb');
    const rings = document.getElementById('visual-rings');
    const bottleContainer = document.getElementById('visual-bottle-container');
    const bottle = document.getElementById('the-bottle');
    const bottleShadow = document.getElementById('bottle-shadow');
    const badge1 = document.getElementById('badge-1');
    const badge2 = document.getElementById('badge-2');
    const scrollIndicator = document.getElementById('scroll-indicator');

    const easeOutCubic = x => 1 - Math.pow(1 - x, 3);

    function onScroll() {
      const rect = track.getBoundingClientRect();
      const trackTop = rect.top;
      const trackHeight = rect.height - window.innerHeight;
      
      let progress = -trackTop / trackHeight;
      progress = Math.max(0, Math.min(1, progress));

      // Hide Scroll Indicator as soon as user starts scrolling
      if (progress > 0.02) {
        scrollIndicator.style.opacity = '0';
      } else {
        scrollIndicator.style.opacity = '1';
      }

      // PHASE 1: The Origin (0.0 to 0.33)
      if (progress < 0.33) {
        const localProgress = progress / 0.33; 
        
        text1.style.opacity = 1 - Math.pow(localProgress, 3);
        text1.style.transform = `translateY(${localProgress * -20}px)`;
        text2.style.opacity = 0;
        text3.style.opacity = 0;

        // Bottle is deep in the ocean (Slightly darker, floating)
        bottleContainer.style.transform = `scale(0.85) translateY(${localProgress * 20}px)`;
        bottle.style.filter = `brightness(${0.8 + (localProgress * 0.2)}) drop-shadow(0 20px 40px rgba(0,0,0,0.5))`;
        bottleShadow.style.opacity = 0;

        orb.style.opacity = 0.5 - (localProgress * 0.3);
        orb.style.transform = `scale(${1 - (localProgress * 0.5)})`;
        
        rings.style.opacity = localProgress;
        rings.style.transform = `scale(${1.5 - (localProgress * 0.5)})`;
        
        bgOcean.style.opacity = 1;
        bgClinical.style.opacity = 0;
        bgGrid.style.opacity = 0;
      }

      // PHASE 2: The Extraction (0.33 to 0.66)
      else if (progress >= 0.33 && progress < 0.66) {
        const localProgress = (progress - 0.33) / 0.33;
        
        text1.style.opacity = 0;
        
        if (localProgress < 0.2) {
          text2.style.opacity = localProgress * 5; 
          text2.style.transform = `translateY(${(1 - localProgress*5) * 20}px)`;
        } else if (localProgress > 0.8) {
          const fadeOut = (1 - localProgress) * 5;
          text2.style.opacity = fadeOut;
          text2.style.transform = `translateY(${(1 - fadeOut) * -20}px)`;
        } else {
          text2.style.opacity = 1;
          text2.style.transform = `translateY(0px)`;
        }
        
        text3.style.opacity = 0;

        // Transitioning out of water into clinical
        orb.style.opacity = 0;
        rings.style.opacity = Math.sin(localProgress * Math.PI); 
        rings.style.transform = `scale(${1 - (localProgress * 0.2)}) rotate(${localProgress * 90}deg)`;
        
        bottleContainer.style.transform = `scale(${0.85 + (localProgress * 0.1)}) translateY(0px)`;
        bottle.style.filter = `brightness(1) drop-shadow(0 20px 40px rgba(0,0,0,0.3))`;
        bottleShadow.style.opacity = localProgress * 0.5;
        
        bgOcean.style.opacity = 1 - localProgress;
        bgClinical.style.opacity = localProgress;
        bgGrid.style.opacity = localProgress * 0.5;
        
        badge1.style.opacity = 0;
        badge2.style.opacity = 0;
      }

      // PHASE 3: The Form (0.66 to 1.0)
      else if (progress >= 0.66) {
        const localProgress = (progress - 0.66) / 0.34;
        const smoothProgress = easeOutCubic(localProgress);
        
        text1.style.opacity = 0;
        text2.style.opacity = 0;
        
        text3.style.opacity = Math.min(1, localProgress * 3);
        text3.style.transform = `translateY(${Math.max(0, 20 - (localProgress * 60))}px)`;

        rings.style.opacity = 0;
        
        // Full Clinical Display
        bottleContainer.style.transform = `scale(${0.95 + (smoothProgress * 0.05)}) translateY(0px)`;
        bottle.style.filter = `brightness(1) drop-shadow(0 30px 50px rgba(0,0,0,0.15))`;
        bottleShadow.style.opacity = 0.5 + (smoothProgress * 0.5); 
        
        if (localProgress > 0.5) {
          badge1.style.opacity = (localProgress - 0.5) * 2;
          badge1.style.transform = `translateY(${Math.max(0, 10 - ((localProgress - 0.5) * 40))}px)`;
          badge2.style.opacity = (localProgress - 0.5) * 2;
          badge2.style.transform = `translateY(${Math.max(0, 10 - ((localProgress - 0.5) * 40))}px)`;
        } else {
          badge1.style.opacity = 0;
          badge2.style.opacity = 0;
        }

        bgOcean.style.opacity = 0;
        bgClinical.style.opacity = 1;
        bgGrid.style.opacity = 1;
      }
    }

    window.addEventListener('scroll', () => {
      requestAnimationFrame(onScroll);
    }, { passive: true });
    
    onScroll(); // Run once on load
  });
</script>