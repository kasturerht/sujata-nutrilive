---
// src/components/StoreHero.astro
---
<section id="hero-interactive" class="relative min-h-[90vh] flex items-center justify-center overflow-hidden bg-[#FAF9F6] pt-24 pb-12">
  
  <div class="parallax-element absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full flex justify-center pointer-events-none z-0 overflow-hidden" data-speed="2">
    <h2 class="text-[14vw] font-['Playfair_Display'] font-black text-[#166534]/[0.03] tracking-tighter whitespace-nowrap select-none">
      SPIRULINA
    </h2>
  </div>

  <div class="parallax-element absolute top-1/2 left-[70%] -translate-x-1/2 -translate-y-1/2 w-[1000px] h-[1000px] bg-[radial-gradient(circle,rgba(22,101,52,0.05)_0%,rgba(250,249,246,0)_70%)] pointer-events-none z-0 opacity-70" data-speed="-1"></div>

  <div class="max-w-[90rem] mx-auto px-6 lg:px-12 w-full relative z-10">
    <div class="flex flex-col lg:flex-row items-center justify-between">
      
      <div class="lg:w-1/2 z-20 flex flex-col items-start pt-10 lg:pt-0 relative">
        
        <div class="flex items-center gap-3 mb-6 animate-[fadeIn_1s_ease-out_forwards] opacity-0">
          <div class="flex text-[#F59E0B] gap-1">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <span class="text-sm font-bold text-[#111827]">5.0</span>
          </div>
          <span class="text-xs font-semibold tracking-widest uppercase text-[#4B5563]">10K+ Healthy Humans</span>
        </div>

        <h1 class="text-[4rem] md:text-[5.5rem] lg:text-[7.5rem] font-['Playfair_Display'] font-bold leading-[0.9] text-[#111827] tracking-tight mb-8 animate-[fadeInUp_1s_ease-out_0.2s_forwards] opacity-0 relative">
          Pure <br/> 
          <span class="text-[#166534] italic font-medium">Spirulina.</span>
        </h1>

        <p class="text-lg md:text-xl text-[#4B5563] font-light max-w-md leading-relaxed mb-12 animate-[fadeInUp_1s_ease-out_0.4s_forwards] opacity-0">
          Fuel your day with the most nutrient-dense superfood on the planet. 100% organic, raw, and unapologetically green.
        </p>

        <button class="group bg-[#111827] text-white px-12 py-4 rounded-full font-semibold hover:bg-[#166534] transition-all duration-500 text-lg shadow-2xl hover:shadow-[0_20px_40px_rgba(22,101,52,0.3)] flex items-center justify-center gap-4 hover:-translate-y-1 animate-[fadeInUp_1s_ease-out_0.6s_forwards] opacity-0 active:scale-95">
          Shop the Powder
          <span class="bg-white/20 rounded-full p-1.5 group-hover:bg-white group-hover:text-[#166534] transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
          </span>
        </button>
      </div>

      <div class="lg:w-1/2 absolute lg:relative right-[-10%] lg:right-0 bottom-[-10%] lg:bottom-0 z-0 lg:z-10 opacity-30 lg:opacity-100 flex justify-center lg:justify-end items-center mt-20 lg:mt-0">
        
        <div class="relative w-full max-w-[500px] lg:max-w-[600px] aspect-square flex items-center justify-center">
          
          <div class="parallax-element absolute top-10 right-10 w-24 h-24 bg-gradient-to-tr from-[#166534]/20 to-transparent rounded-full blur-2xl" data-speed="8"></div>
          <div class="parallax-element absolute bottom-20 left-10 w-32 h-32 bg-gradient-to-tr from-[#34D399]/15 to-transparent rounded-full blur-3xl" data-speed="-6"></div>
          <div class="parallax-element absolute top-1/2 -right-10 w-20 h-20 border border-[#166534]/20 rounded-full" data-speed="10"></div>
          <div class="parallax-element absolute top-[-10%] left-[20%] w-3 h-3 bg-green-500 rounded-full delay-100 blur-[1px]" data-speed="4"></div>

          <div class="relative animate-[float_6s_ease-in-out_infinite] z-20 w-[60%] lg:w-[70%]">
            <div class="absolute -bottom-10 left-1/2 -translate-x-1/2 w-[80%] h-8 bg-black/15 blur-xl rounded-[100%] z-0"></div>
            
            <img 
                src="/spirulina-bottle.png" 
                alt="Skadas Premium Organic Spirulina" 
                class="relative z-10 w-full h-auto object-contain drop-shadow-[0_30px_50px_rgba(0,0,0,0.2)]"
            />

            <div class="absolute top-[8%] left-[45%] group/hotspot z-30">
              <div class="relative flex items-center justify-center">
                <span class="absolute w-4 h-4 bg-[#166534]/30 rounded-full animate-ping"></span>
                <span class="relative w-2.5 h-2.5 bg-[#166534] rounded-full cursor-pointer border-2 border-white shadow-md"></span>
                <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-4 w-48 opacity-0 group-hover/hotspot:opacity-100 group-hover/hotspot:mb-6 transition-all duration-300 pointer-events-none">
                  <div class="bg-white/80 backdrop-blur-lg px-4 py-3 rounded-2xl shadow-xl border border-gray-100">
                    <p class="text-xs font-bold text-[#111827] mb-1">Aluminum Free</p>
                    <p class="text-[10px] text-[#6B7280] leading-tight">Zero leaching, food-grade safe storage.</p>
                  </div>
                  <div class="absolute bottom-[-4px] left-1/2 -translate-x-1/2 w-4 h-[1px] bg-[#166534]/30"></div>
                </div>
              </div>
            </div>

            <div class="absolute top-[35%] -left-[15%] group/hotspot z-30">
              <div class="relative flex items-center justify-center">
                <span class="absolute w-4 h-4 bg-[#166534]/30 rounded-full animate-ping"></span>
                <span class="relative w-2.5 h-2.5 bg-[#166534] rounded-full cursor-pointer border-2 border-white shadow-md"></span>
                <div class="absolute top-1/2 right-full -translate-y-1/2 mr-4 w-40 opacity-0 group-hover/hotspot:opacity-100 group-hover/hotspot:mr-6 transition-all duration-300 pointer-events-none">
                  <div class="bg-white/80 backdrop-blur-lg px-4 py-3 rounded-2xl shadow-xl border border-gray-100">
                    <p class="text-xs font-bold text-[#111827] mb-1">100% Raw</p>
                    <p class="text-[10px] text-[#6B7280] leading-tight">Cold-pressed. Max nutrient density.</p>
                  </div>
                  <div class="absolute top-1/2 -right-4 -translate-y-1/2 w-4 h-[1px] bg-[#166534]/30"></div>
                </div>
              </div>
            </div>

            <div class="absolute bottom-[35%] -right-[15%] group/hotspot z-30">
              <div class="relative flex items-center justify-center">
                <span class="absolute w-4 h-4 bg-[#166534]/30 rounded-full animate-ping"></span>
                <span class="relative w-2.5 h-2.5 bg-[#166534] rounded-full cursor-pointer border-2 border-white shadow-md"></span>
                <div class="absolute top-1/2 left-full -translate-y-1/2 ml-4 w-40 opacity-0 group-hover/hotspot:opacity-100 group-hover/hotspot:ml-6 transition-all duration-300 pointer-events-none">
                  <div class="bg-white/80 backdrop-blur-lg px-4 py-3 rounded-2xl shadow-xl border border-gray-100">
                    <p class="text-xs font-bold text-[#111827] mb-1">High Protein</p>
                    <p class="text-[10px] text-[#6B7280] leading-tight">Packed with 60% vegan protein.</p>
                  </div>
                  <div class="absolute top-1/2 -left-4 -translate-y-1/2 w-4 h-[1px] bg-[#166534]/30"></div>
                </div>
              </div>
            </div>
            
            <div class="absolute bottom-[10%] left-[30%] group/hotspot z-30">
              <div class="relative flex items-center justify-center">
                <span class="absolute w-4 h-4 bg-[#166534]/30 rounded-full animate-ping"></span>
                <span class="relative w-2.5 h-2.5 bg-[#166534] rounded-full cursor-pointer border-2 border-white shadow-md"></span>
                <div class="absolute top-full left-1/2 -translate-x-1/2 mt-4 w-48 opacity-0 group-hover/hotspot:opacity-100 group-hover/hotspot:mt-6 transition-all duration-300 pointer-events-none">
                  <div class="bg-white/80 backdrop-blur-lg px-4 py-3 rounded-2xl shadow-xl border border-gray-100">
                    <p class="text-xs font-bold text-[#111827] mb-1">Non-GMO • Vegan</p>
                    <p class="text-[10px] text-[#6B7280] leading-tight">Third-party tested. Zero artificials.</p>
                  </div>
                  <div class="absolute top-[-4px] left-1/2 -translate-x-1/2 w-4 h-[1px] bg-[#166534]/30"></div>
                </div>
              </div>
            </div>

          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<style is:global>
  @keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes float { 0% { transform: translateY(0px); } 50% { transform: translateY(-15px); } 100% { transform: translateY(0px); } }
</style>

<script>
  // Silicon Valley Extreme Parallax Script
  document.addEventListener('DOMContentLoaded', () => {
    const hero = document.getElementById('hero-interactive');
    const parallaxElements = document.querySelectorAll('.parallax-element');

    if (window.matchMedia("(min-width: 1024px)").matches) {
      hero.addEventListener('mousemove', (e) => {
        const x = (e.clientX / window.innerWidth - 0.5) * 2; // Value between -1 and 1
        const y = (e.clientY / window.innerHeight - 0.5) * 2; // Value between -1 and 1

        requestAnimationFrame(() => {
          parallaxElements.forEach((el) => {
            const speed = parseFloat(el.getAttribute('data-speed'));
            // MOVE WITH MOUSE (not opposite) for a more powerful feel.
            // Increased movement factor (25).
            const moveX = x * speed * 25; 
            const moveY = y * speed * 25;
            el.style.transform = `translate(${moveX}px, ${moveY}px)`;
          });
        });
      });

      // Reset on mouse leave
      hero.addEventListener('mouseleave', () => {
        requestAnimationFrame(() => {
          parallaxElements.forEach((el) => {
            el.style.transform = `translate(0px, 0px)`;
          });
        });
      });
    }
  });
</script>