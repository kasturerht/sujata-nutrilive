          <Image src="/spirulina-bottle.png" alt="Bottle 2" width={350} height={450} class="relative z-20 h-[90%] object-contain drop-shadow-2xl"/>
          <Image src="/spirulina-bottle.png" alt="Bottle 3" width={300} height={400} class="relative z-10 h-[75%] object-contain drop-shadow-xl rotate-6 -translate-x-4 opacity-90"/>
          
          <div class="absolute bottom-[10%] right-[5%] lg:right-[15%] bg-red-600 text-white px-3 py-1.5 md:px-4 md:py-2 text-xs font-black uppercase tracking-[0.2em] rounded shadow-xl -rotate-12 z-30 animate-pulse">
