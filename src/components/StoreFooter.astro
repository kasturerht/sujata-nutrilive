---
// src/components/StoreFooter.astro
---

<footer class="relative bg-[#050B08] pt-20 pb-10 font-['Inter'] selection:bg-emerald-500 selection:text-white border-t border-emerald-900/30 overflow-hidden z-10">
  
  {/* ==========================================
      0. AMBIENT LUXURY GLOWS (Background)
      ========================================== */}
  <div class="absolute inset-0 pointer-events-none z-0">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[1px] bg-gradient-to-r from-transparent via-[#166534] to-transparent opacity-50"></div>
    <div class="absolute top-[-20%] right-[-10%] w-[50vw] h-[50vw] bg-emerald-900/20 rounded-full blur-[150px]"></div>
    <div class="absolute bottom-[-10%] left-[-10%] w-[40vw] h-[40vw] bg-amber-900/10 rounded-full blur-[120px]"></div>
    {/* Subtle Noise Texture for Premium Feel */}
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>
  </div>

  <div class="max-w-[85rem] mx-auto px-5 md:px-8 lg:px-12 relative z-10">

    {/* ==========================================
        PART 1: THE VIP CLUB (Lead Generation Engine)
        ========================================== */}
    <div class="relative bg-gradient-to-br from-[#0A1A12] to-[#050B08] border border-emerald-900/50 rounded-[2.5rem] p-8 md:p-12 lg:p-16 mb-20 shadow-[0_30px_60px_rgba(0,0,0,0.5)] overflow-hidden flex flex-col lg:flex-row items-center justify-between gap-10">
      
      {/* Decorative inner glow */}
      <div class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(ellipse_at_top_left,rgba(22,101,52,0.15)_0%,transparent_60%)] pointer-events-none"></div>

      <div class="w-full lg:w-1/2 flex flex-col relative z-10 text-center lg:text-left">
        <span class="inline-flex items-center justify-center lg:justify-start gap-2 text-amber-400 text-[10px] md:text-xs font-black uppercase tracking-[0.3em] mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse"></span>
          Join The Inner Circle
        </span>
        <h3 class="text-3xl md:text-4xl lg:text-5xl font-['Playfair_Display'] font-black text-white tracking-tight mb-4 leading-tight">
          Unlock <span class="text-emerald-400 italic">10% Off</span> <br class="hidden md:block"/> Your First Routine.
        </h3>
        <p class="text-gray-400 text-sm leading-relaxed max-w-md mx-auto lg:mx-0">
          Get exclusive access to flash sales, early product drops, and expert nutritional protocols. No spam, ever.
        </p>
      </div>

      <div class="w-full lg:w-1/2 relative z-10">
        {/* Sleek Apple-style Input Form */}
        <form class="relative flex items-center w-full max-w-lg mx-auto lg:ml-auto lg:mr-0 bg-black/40 border border-white/10 rounded-full p-1.5 focus-within:border-emerald-500/50 focus-within:bg-black/60 transition-all duration-500 shadow-inner">
          <div class="pl-5 pr-2 flex items-center text-gray-500">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
          </div>
          <input 
            type="email" 
            placeholder="Enter your email address..." 
            class="w-full bg-transparent border-none text-white text-sm focus:outline-none focus:ring-0 placeholder-gray-500 px-3"
            required
          />
          <button type="submit" class="shrink-0 bg-emerald-600 hover:bg-emerald-500 text-white font-bold text-xs uppercase tracking-widest px-6 py-3.5 rounded-full transition-colors duration-300 shadow-[0_0_20px_rgba(5,150,105,0.3)]">
            Subscribe
          </button>
        </form>
        <p class="text-[10px] text-gray-500 text-center lg:text-right mt-4 tracking-wide uppercase">By subscribing, you agree to our terms.</p>
      </div>
    </div>

    {/* ==========================================
        PART 2: THE DIRECTORY (Brand & Links)
        ========================================== */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-8 mb-20">
      
      {/* Column 1: Brand Info (Span 4) */}
      <div class="lg:col-span-4 flex flex-col">
        <h2 class="text-3xl font-['Playfair_Display'] font-black text-white tracking-widest mb-6">
          SUJATA<span class="text-emerald-500">.</span>
        </h2>
        <p class="text-gray-400 text-sm leading-relaxed mb-8 max-w-sm">
          India's most trusted name in cellular nutrition. We blend 50 years of heritage with cold-pressed scientific precision to deliver real, lab-tested results.
        </p>
        
        {/* Contact Info */}
        <div class="flex flex-col gap-4">
          <a href="mailto:support@sujatanutrilive.com" class="flex items-center gap-3 text-gray-400 hover:text-white transition-colors group w-fit">
            <div class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center border border-white/5 group-hover:border-emerald-500/50 group-hover:bg-emerald-500/10 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </div>
            <span class="text-sm font-medium tracking-wide">support@sujatanutrilive.com</span>
          </a>
          <a href="tel:+919876543210" class="flex items-center gap-3 text-gray-400 hover:text-white transition-colors group w-fit">
            <div class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center border border-white/5 group-hover:border-emerald-500/50 group-hover:bg-emerald-500/10 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            </div>
            <span class="text-sm font-medium tracking-wide">+91 98765 43210 <span class="text-gray-600 text-xs ml-1">(10AM - 6PM)</span></span>
          </a>
        </div>
      </div>

      {/* Column 2: Quick Links (Span 2) */}
      <div class="lg:col-span-2 lg:col-start-6 flex flex-col">
        <h4 class="text-white font-bold text-sm uppercase tracking-widest mb-6">Shop</h4>
        <ul class="flex flex-col gap-4">
          <li><a href="#" class="text-gray-400 text-sm hover:text-emerald-400 hover:translate-x-1 transition-all inline-block">Spirulina Powder</a></li>
          <li><a href="#" class="text-gray-400 text-sm hover:text-emerald-400 hover:translate-x-1 transition-all inline-block">Spirulina Capsules</a></li>
          <li><a href="#" class="text-gray-400 text-sm hover:text-emerald-400 hover:translate-x-1 transition-all inline-block">Value Combos <span class="ml-1 bg-amber-500/20 text-amber-400 text-[8px] px-1.5 py-0.5 rounded uppercase font-black">Sale</span></a></li>
          <li><a href="#" class="text-gray-400 text-sm hover:text-emerald-400 hover:translate-x-1 transition-all inline-block">7-Day Trial Packs</a></li>
        </ul>
      </div>

      {/* Column 3: Legal & Compliance - MANDATORY FOR ADS (Span 2) */}
      <div class="lg:col-span-2 flex flex-col">
        <h4 class="text-white font-bold text-sm uppercase tracking-widest mb-6">Policies</h4>
        <ul class="flex flex-col gap-4">
          <li><a href="#" class="text-gray-400 text-sm hover:text-white hover:translate-x-1 transition-all inline-block">Privacy Policy</a></li>
          <li><a href="#" class="text-gray-400 text-sm hover:text-white hover:translate-x-1 transition-all inline-block">Terms of Service</a></li>
          <li><a href="#" class="text-gray-400 text-sm hover:text-white hover:translate-x-1 transition-all inline-block">Refund Policy</a></li>
          <li><a href="#" class="text-gray-400 text-sm hover:text-white hover:translate-x-1 transition-all inline-block">Shipping Policy</a></li>
        </ul>
      </div>

      {/* Column 4: Socials (Span 2) */}
      <div class="lg:col-span-2 flex flex-col">
        <h4 class="text-white font-bold text-sm uppercase tracking-widest mb-6">Connect</h4>
        <div class="flex items-center gap-3">
          <a href="#" class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-gray-400 hover:bg-[#E1306C] hover:text-white hover:border-[#E1306C] transition-all transform hover:-translate-y-1 shadow-lg">
            {/* Instagram Icon */}
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm3.98-10.822a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="#" class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-gray-400 hover:bg-[#25D366] hover:text-white hover:border-[#25D366] transition-all transform hover:-translate-y-1 shadow-lg">
            {/* WhatsApp Icon */}
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          </a>
        </div>
      </div>

    </div>

    {/* ==========================================
        PART 3: THE ANCHOR (Copyright & VISUAL Payments)
        ========================================== */}
    <div class="pt-8 border-t border-white/10 flex flex-col md:flex-row items-center justify-between gap-6">
      
      {/* Copyright */}
      <div class="text-gray-500 text-xs font-medium text-center md:text-left">
        © 2026 Sujata Nutrilive. All rights reserved. <br class="md:hidden"/> <span class="hidden md:inline">|</span> Crafted with precision in India.
      </div>

      {/* Safe Payment Badges (The "Zero-Reading" Visual Trust Engine) */}
      {/* I have used live Wikimedia CDN links so the original logos render immediately in your browser */}
      <div class="flex items-center gap-2 md:gap-3">
        
        {/* UPI */}
        <div class="w-10 h-6 md:w-12 md:h-7 bg-white rounded-[4px] flex items-center justify-center p-1 shadow-sm">
           <img src="https://upload.wikimedia.org/wikipedia/commons/e/e1/UPI-Logo-vector.svg" alt="UPI" class="w-full h-full object-contain" />
        </div>
        
        {/* Visa */}
        <div class="w-10 h-6 md:w-12 md:h-7 bg-white rounded-[4px] flex items-center justify-center p-1 shadow-sm">
           <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/5/5c/Visa_Inc._logo_%282021%E2%80%93present%29.svg/960px-Visa_Inc._logo_%282021%E2%80%93present%29.svg.png?_=20240313022811" alt="Visa" class="w-full h-full object-contain" />
        </div>
        
        {/* Mastercard */}
        <div class="w-10 h-6 md:w-12 md:h-7 bg-white rounded-[4px] flex items-center justify-center p-1 shadow-sm">
           <img src="https://upload.wikimedia.org/wikipedia/commons/2/2a/Mastercard-logo.svg" alt="Mastercard" class="w-full h-full object-contain" />
        </div>
        
        {/* RuPay */}
        <div class="w-10 h-6 md:w-12 md:h-7 bg-white rounded-[4px] flex items-center justify-center p-1 shadow-sm">
           <img src="https://upload.wikimedia.org/wikipedia/commons/d/d1/RuPay.svg" alt="RuPay" class="w-full h-full object-contain" />
        </div>

      </div>

    </div>

  </div>
</footer>