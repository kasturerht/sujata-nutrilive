      </div>

    </div>

  </div>
</section>

{/* =========================================
    THE INTERACTIVE & REVEAL ENGINE
========================================= */}
<script>
  document.addEventListener('DOMContentLoaded', () => {
    
    // 1. Interactive Protocol Tabs Logic
    const tabs = document.querySelectorAll('.trust-tab-btn');
    const contents = document.querySelectorAll('.trust-tab-content');
    const activeLine = document.getElementById('active-tab-line');

    tabs.forEach(tab => {
      // You can change 'click' to 'mouseenter' if you want it to change just by hovering!
      tab.addEventListener('click', () => {
        // Remove active states from all
        tabs.forEach(t => {
          t.classList.remove('active', 'text-white');
          t.classList.add('text-gray-500');
        });
        contents.forEach(c => {
          c.classList.remove('opacity-100', 'translate-y-0', 'z-20');
          c.classList.add('opacity-0', 'translate-y-8', 'pointer-events-none', 'z-10');
        });

        // Add active state to clicked
        tab.classList.add('active', 'text-white');
        tab.classList.remove('text-gray-500');
        
        const targetId = tab.getAttribute('data-target');
        const targetContent = document.getElementById(targetId);
        
        targetContent.classList.remove('opacity-0', 'translate-y-8', 'pointer-events-none', 'z-10');
        targetContent.classList.add('opacity-100', 'translate-y-0', 'z-20');

        // Move the glowing line indicator
        const index = parseInt(tab.getAttribute('data-index'));
        activeLine.style.transform = `translateY(${index * 100}%)`;
      });
    });

    // 2. Cinematic Scroll Reveal Observer
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          // observer.unobserve(entry.target); // Uncomment if you only want it to reveal once
        }
      });
    }, { threshold: 0.2, rootMargin: "0px 0px -100px 0px" });

    document.querySelectorAll('.reveal-up').forEach((el) => {
      observer.observe(el);
    });
  });
</script>

<style>
  /* Cinematic Fade In Up */
  .reveal-up {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1), transform 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal-up.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>