---
---
<section id="contact" class="py-24 md:py-32 relative overflow-hidden z-10 bg-[#000000] border-t border-white/5">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-7xl h-full bg-gradient-to-b from-cyan-950/5 via-blue-950/5 to-transparent blur-[150px] pointer-events-none z-0"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-20 items-stretch">
      
      <div class="lg:col-span-5 lg:sticky lg:top-32 flex flex-col justify-center">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[#050505] border border-cyan-500/20 text-[10px] text-cyan-400 font-mono tracking-widest uppercase mb-8 shadow-inner w-max">
          <span class="w-1.5 h-1.5 bg-cyan-400 shadow-[0_0_8px_#22d3ee] animate-pulse rounded-full"></span> 
          System Active // Awaiting Query
        </div>
        
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tighter text-white mb-6 leading-[1.05]">
          Ready to rebuild your <br/> 
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 via-blue-500 to-purple-500">conversion engine?</span>
        </h2>
        
        <p class="text-slate-400 text-lg mb-10 leading-relaxed font-light">
          We partner exclusively with forward-thinking brands ready to transition to modern headless architecture. Submit your details below for a technical mapping session.
        </p>
        
        <div class="space-y-6 pt-6 border-t border-white/5">
          <div class="flex items-start gap-4 text-slate-300">
            <div class="w-8 h-8 rounded-lg bg-[#0a0a0a] border border-white/10 flex items-center justify-center text-cyan-500 text-xs mt-1 shrink-0 font-mono shadow-[0_0_15px_rgba(34,211,238,0.1)]">01</div>
            <div>
                <h4 class="font-bold text-white tracking-tight mb-1">Architecture Diagnostics</h4>
                <p class="text-sm text-slate-500 font-light">Analysis of Core Web Vitals and SEO gaps.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 text-slate-300">
            <div class="w-8 h-8 rounded-lg bg-[#0a0a0a] border border-white/10 flex items-center justify-center text-cyan-500 text-xs mt-1 shrink-0 font-mono shadow-[0_0_15px_rgba(34,211,238,0.1)]">02</div>
            <div>
                <h4 class="font-bold text-white tracking-tight mb-1">Telemetry Audit</h4>
                <p class="text-sm text-slate-500 font-light">Identifying tracking gaps and Server-Side opportunities.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="lg:col-span-7 h-full">
        <form id="contactForm" action="https://formspree.io/f/maqdzroa" method="POST" class="space-y-8 flex flex-col h-full justify-between">
          
          <div class="space-y-8 flex-grow">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2 relative group/input">
                    <label class="block text-[10px] font-mono uppercase tracking-widest text-slate-300 pl-1">Founder / Leader Name</label>
                    <input type="text" name="name" placeholder="John Doe" required 
                      class="w-full bg-[#050505] border border-white/10 rounded-xl px-5 py-4 text-sm text-white placeholder:text-slate-500 focus:outline-none focus:border-cyan-400 focus:ring-1 focus:ring-cyan-400/50 transition-all shadow-inner focus:shadow-[0_0_20px_rgba(34,211,238,0.2)]" />
                </div>
                <div class="space-y-2 relative group/input">
                    <label class="block text-[10px] font-mono uppercase tracking-widest text-slate-300 pl-1">Work Email</label>
                    <input type="email" name="email" placeholder="john@company.com" required 
                      class="w-full bg-[#050505] border border-white/10 rounded-xl px-5 py-4 text-sm text-white placeholder:text-slate-500 focus:outline-none focus:border-cyan-400 focus:ring-1 focus:ring-cyan-400/50 transition-all shadow-inner focus:shadow-[0_0_20px_rgba(34,211,238,0.2)]" />
                </div>
            </div>

            <div class="space-y-2 relative group/input">
              <label class="block text-[10px] font-mono uppercase tracking-widest text-slate-300 pl-1">Current Domain URL</label>
              <input type="url" name="website" placeholder="https://example.com" required 
                class="w-full bg-[#050505] border border-white/10 rounded-xl px-5 py-4 text-sm text-white placeholder:text-slate-500 focus:outline-none focus:border-cyan-400 focus:ring-1 focus:ring-cyan-400/50 transition-all shadow-inner focus:shadow-[0_0_20px_rgba(34,211,238,0.2)]" />
            </div>

            <div class="space-y-4">
              <label class="block text-[10px] font-mono uppercase tracking-widest text-slate-300 pl-1 mb-3">Primary Infrastructure Bottleneck</label>
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                
                <label class="cursor-pointer relative group h-full">
                  <input type="radio" name="bottleneck" value="Speed & Core Web Vitals" class="peer sr-only" required>
                  
                  <div class="w-full h-full p-6 rounded-2xl border border-white/5 bg-[#030712] transition-all duration-300 group-hover:border-cyan-500/50 group-hover:bg-cyan-950/20 group-hover:shadow-[0_0_30px_rgba(34,211,238,0.1)] peer-checked:border-cyan-500/50 peer-checked:bg-cyan-950/20 peer-checked:shadow-[0_0_30px_rgba(34,211,238,0.15)] flex flex-col justify-between">
                    
                    <div class="flex items-start justify-between mb-4 gap-4">
                      <span class="text-white font-bold tracking-tight text-base transition-colors group-hover:text-cyan-400 peer-checked:text-cyan-400">Speed / Core Web Vitals</span>
                      
                      <div class="w-6 h-6 rounded-full border-2 border-slate-700 bg-slate-900 flex items-center justify-center transition-all duration-300 group-hover:border-cyan-600 peer-checked:border-cyan-400 peer-checked:bg-cyan-500 peer-checked:shadow-[0_0_15px_rgba(34,211,238,0.5)] shrink-0">
                         <svg class="w-3.5 h-3.5 text-white scale-0 opacity-0 transition-all duration-300 ease-out peer-checked:scale-100 peer-checked:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
                      </div>
                    </div>
                    
                    <p class="text-xs text-slate-500 leading-relaxed font-light transition-colors group-hover:text-slate-300 peer-checked:text-slate-300">Consistently failing Core Web Vitals and slow page load times.</p>
                  </div>
                </label>

                <label class="cursor-pointer relative group h-full">
                  <input type="radio" name="bottleneck" value="Tracking Accuracy" class="peer sr-only" required>
                  
                  <div class="w-full h-full p-6 rounded-2xl border border-white/5 bg-[#030712] transition-all duration-300 group-hover:border-blue-500/50 group-hover:bg-blue-950/20 group-hover:shadow-[0_0_30px_rgba(59,130,246,0.1)] peer-checked:border-blue-500/50 peer-checked:bg-blue-950/20 peer-checked:shadow-[0_0_30px_rgba(59,130,246,0.15)] flex flex-col justify-between">
                    
                    <div class="flex items-start justify-between mb-4 gap-4">
                      <span class="text-white font-bold tracking-tight text-base transition-colors group-hover:text-blue-400 peer-checked:text-blue-400">Inaccurate Data / Attribution</span>
                      
                      <div class="w-6 h-6 rounded-full border-2 border-slate-700 bg-slate-900 flex items-center justify-center transition-all duration-300 group-hover:border-blue-600 peer-checked:border-blue-400 peer-checked:bg-blue-500 peer-checked:shadow-[0_0_15px_rgba(59,130,246,0.5)] shrink-0">
                         <svg class="w-3.5 h-3.5 text-white scale-0 opacity-0 transition-all duration-300 ease-out peer-checked:scale-100 peer-checked:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
                      </div>
                    </div>
                    
                    <p class="text-xs text-slate-500 leading-relaxed font-light transition-colors group-hover:text-slate-300 peer-checked:text-slate-300">iOS data restrictions, ad-blockers, and broken Meta/Google pixels.</p>
                  </div>
                </label>

                <label class="cursor-pointer relative group h-full">
                  <input type="radio" name="bottleneck" value="Technical SEO" class="peer sr-only" required>
                  
                  <div class="w-full h-full p-6 rounded-2xl border border-white/5 bg-[#030712] transition-all duration-300 group-hover:border-emerald-500/50 group-hover:bg-emerald-950/20 group-hover:shadow-[0_0_30px_rgba(16,185,129,0.1)] peer-checked:border-emerald-500/50 peer-checked:bg-emerald-950/20 peer-checked:shadow-[0_0_30px_rgba(16,185,129,0.15)] flex flex-col justify-between">
                    
                    <div class="flex items-start justify-between mb-4 gap-4">
                      <span class="text-white font-bold tracking-tight text-base transition-colors group-hover:text-emerald-400 peer-checked:text-emerald-400">Technical SEO Architecture</span>
                      
                      <div class="w-6 h-6 rounded-full border-2 border-slate-700 bg-slate-900 flex items-center justify-center transition-all duration-300 group-hover:border-emerald-600 peer-checked:border-emerald-400 peer-checked:bg-emerald-500 peer-checked:shadow-[0_0_15px_rgba(16,185,129,0.5)] shrink-0">
                         <svg class="w-3.5 h-3.5 text-white scale-0 opacity-0 transition-all duration-300 ease-out peer-checked:scale-100 peer-checked:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
                      </div>
                    </div>
                    
                    <p class="text-xs text-slate-500 leading-relaxed font-light transition-colors group-hover:text-slate-300 peer-checked:text-slate-300">Problems crawling, indexing, or structural SEO flaws limiting organic reach.</p>
                  </div>
                </label>

                <label class="cursor-pointer relative group h-full">
                  <input type="radio" name="bottleneck" value="Full Headless Migration" class="peer sr-only" required>
                  
                  <div class="w-full h-full p-6 rounded-2xl border border-white/5 bg-[#030712] transition-all duration-300 group-hover:border-purple-500/50 group-hover:bg-purple-950/20 group-hover:shadow-[0_0_30px_rgba(168,85,247,0.1)] peer-checked:border-purple-500/50 peer-checked:bg-purple-950/20 peer-checked:shadow-[0_0_30px_rgba(168,85,247,0.15)] flex flex-col justify-between">
                    
                    <div class="flex items-start justify-between mb-4 gap-4">
                      <span class="text-white font-bold tracking-tight text-base transition-colors group-hover:text-purple-400 peer-checked:text-purple-400">Full Headless Migration</span>
                      
                      <div class="w-6 h-6 rounded-full border-2 border-slate-700 bg-slate-900 flex items-center justify-center transition-all duration-300 group-hover:border-purple-600 peer-checked:border-purple-400 peer-checked:bg-purple-500 peer-checked:shadow-[0_0_15px_rgba(168,85,247,0.5)] shrink-0">
                         <svg class="w-3.5 h-3.5 text-white scale-0 opacity-0 transition-all duration-300 ease-out peer-checked:scale-100 peer-checked:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
                      </div>
                    </div>
                    
                    <p class="text-xs text-slate-500 leading-relaxed font-light transition-colors group-hover:text-slate-300 peer-checked:text-slate-300">Looking to transition from monolithic CMS (WordPress) to modern Astro/Sanity.</p>
                  </div>
                </label>

              </div>
            </div>
          </div>
          
          <input type="text" name="_gotcha" style="display:none" />
          <input type="hidden" name="_next" value="#" />

          <div class="pt-8 border-t border-white/5 mt-auto">
              <button type="submit" class="w-full bg-white hover:bg-slate-200 text-slate-950 font-black text-lg py-4 rounded-xl transition-all shadow-[0_0_30px_rgba(255,255,255,0.15)] hover:shadow-[0_0_40px_rgba(255,255,255,0.2)] transform hover:-translate-y-1 flex items-center justify-center gap-2 group/btn relative overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/50 to-transparent -translate-x-[150%] hover:animate-[shine_1s_ease-in-out_1] pointer-events-none z-0"></div>
                <span class="relative z-10">Submit Premium Application</span>
                <svg class="w-5 h-5 text-slate-950 group-hover/btn:translate-x-1.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
              </button>
              <div class="flex items-center justify-center gap-2 mt-5 opacity-60">
                  <svg class="w-3 h-3 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                  <p class="text-center text-[10px] font-mono tracking-widest uppercase text-slate-500 mt-0.5">Encrypted End-to-End Transmission.</p>
              </div>
          </div>
        </form>
      </div>
      
    </div>
  </div>

  <script is:inline>
  document.addEventListener('astro:page-load', () => {
    const form = document.getElementById('contactForm');
    
    if(form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault(); 
        
        const bottleneckSelected = document.querySelector('input[name="bottleneck"]:checked');
        if(!bottleneckSelected) {
            alert('Please select your primary infrastructure bottleneck from the options above.');
            return;
        }

        const data = new FormData(form);
        const actionUrl = form.getAttribute('action');
        const submitBtn = form.querySelector('button[type="submit"]');

        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = '<span class="animate-pulse flex items-center gap-2"><svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 4V2m0 20v-2m8-8h2M2 12h2m16.24 6.24L20 20m-16.24-6.24L4 4m16.24-12.48L20 4M3.76 16.24L4 20"></path></svg>Authenticating Signal...</span>';
        submitBtn.disabled = true;

        try {
          const response = await fetch(actionUrl, {
            method: 'POST',
            body: data,
            headers: {
              'Accept': 'application/json' 
            }
          });

          if (response.ok) {
            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({ 
                'event': 'application_submitted',
                'form_name': 'Skadas Elite Pipeline Application'
            });

            setTimeout(() => {
                window.location.href = '/thank-you';
            }, 600); 
            
          } else {
            alert('Signal interruption. Please try again or email us directly.');
            submitBtn.innerHTML = originalText;
            submitBtn.disabled = false;
          }
        } catch (error) {
          console.error('Submission error:', error);
          alert('Network anomaly detected. Please check your connection.');
          submitBtn.innerHTML = originalText;
          submitBtn.disabled = false;
        }
      });
    }
  });
</script>
</section>