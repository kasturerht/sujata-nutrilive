---
// src/components/StoreBundles.astro
import { Image } from 'astro:assets';
---

<section id="bundles-section" class="relative bg-[#F3F4F6] py-20 lg:py-32 font-['Inter'] overflow-hidden border-t border-gray-200">
  
  <div class="max-w-[85rem] mx-auto px-6 lg:px-12 relative z-10">
    
    {/* Section Header */}
    <div class="text-center max-w-3xl mx-auto mb-16 md:mb-24">
      <span class="text-[#166534] text-[10px] md:text-xs font-bold tracking-[0.3em] uppercase mb-4 block">
        Bestselling Combos
      </span>
      <h2 class="text-3xl md:text-5xl font-['Playfair_Display'] font-black text-gray-900 leading-tight">
        Save Extra With Our <span class="italic text-[#166534]">Value Bundles.</span>
      </h2>
      <p class="text-gray-600 text-sm md:text-base mt-4">
        Save up to 17% with our specially curated wellness kits. Free Shipping & Cash on Delivery (COD) included on all bundles.
      </p>
    </div>

    {/* Bundles Grid */}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-10">
      
      {/* BUNDLE 1: Starter Combo */}
      <div class="group relative bg-white border border-gray-200/80 rounded-[2.5rem] p-6 lg:p-8 hover:border-emerald-500/30 hover:shadow-[0_30px_60px_rgba(22,101,52,0.06)] transition-all duration-500 flex flex-col justify-between h-full">
        
        {/* Hot badge */}
        <div class="absolute -top-3.5 left-8 bg-[#166534] text-white text-[9px] font-black uppercase tracking-widest px-4 py-1.5 rounded-full border border-emerald-400/30 shadow-md">
          Most Popular Combo
        </div>

        <div>
          {/* Images preview */}
          <div class="h-44 bg-[#F9FAFB] rounded-2xl flex items-center justify-center p-4 gap-2 relative overflow-hidden mb-6">
            <Image src="/spirulina-bottle.png" alt="Capsules" width={100} height={120} class="h-32 object-contain drop-shadow-md transform group-hover:-translate-y-1 transition-transform duration-500" />
            <span class="text-2xl font-black text-[#166534] z-10">+</span>
            <Image src="/spirulina-powder.png" alt="Powder" width={100} height={120} class="h-32 object-contain drop-shadow-md transform group-hover:translate-y-1 transition-transform duration-500" />
          </div>

          {/* Details */}
          <div class="flex items-center gap-1.5 mb-3">
            <div class="flex text-[#D97706] text-xs">★★★★★</div>
            <span class="text-[10px] font-bold text-gray-400 tracking-wider">4.9 (420+ reviews)</span>
          </div>

          <h3 class="text-xl lg:text-2xl font-['Playfair_Display'] font-black text-gray-900 mb-2">Sujata Starter Combo</h3>
          <p class="text-gray-500 text-xs mb-6">1x Premium Capsules (120 Caps) + 1x Pure Powder (100g). Perfect kit to experience both formats.</p>

          <div class="border-t border-gray-100 pt-4 mb-6">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs text-gray-400 line-through">₹1,800</span>
              <span class="text-[9px] font-black text-[#166534] bg-[#f0fdf4] px-2 py-0.5 rounded-sm uppercase tracking-widest">SAVE ₹301</span>
            </div>
            <div class="flex items-baseline gap-2">
              <span class="text-3xl font-black text-gray-900">₹1,499</span>
              <span class="text-[10px] font-semibold text-gray-500">/ Complete Kit</span>
            </div>
            <div class="text-[10px] text-emerald-600 font-bold mt-2 flex items-center gap-1">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
              Paisa-Vasool: Only ₹25/day per serving
            </div>
          </div>
        </div>

        <button 
          class="add-to-cart-btn w-full bg-[#111827] hover:bg-[#166534] text-white py-4 rounded-xl font-bold text-xs uppercase tracking-wider transition-all duration-300"
          data-variant-ids="gid://shopify/ProductVariant/59276906103118,gid://shopify/ProductVariant/59247880438094"
        >
          Add to Routine
        </button>

      </div>

      {/* BUNDLE 2: Double Capsules Pack */}
      <div class="group relative bg-white border border-gray-200/80 rounded-[2.5rem] p-6 lg:p-8 hover:border-emerald-500/30 hover:shadow-[0_30px_60px_rgba(22,101,52,0.06)] transition-all duration-500 flex flex-col justify-between h-full">
        
        {/* Hot badge */}
        <div class="absolute -top-3.5 left-8 bg-[#D97706] text-white text-[9px] font-black uppercase tracking-widest px-4 py-1.5 rounded-full border border-amber-400/30 shadow-md">
          Recommended Routine
        </div>

        <div>
          {/* Images preview */}
          <div class="h-44 bg-[#F9FAFB] rounded-2xl flex items-center justify-center p-4 gap-4 relative overflow-hidden mb-6">
            <Image src="/spirulina-bottle.png" alt="Capsules 1" width={90} height={120} class="h-32 object-contain drop-shadow-md transform -rotate-6 translate-x-2 group-hover:translate-x-1 transition-transform duration-500" />
            <Image src="/spirulina-bottle.png" alt="Capsules 2" width={90} height={120} class="h-32 object-contain drop-shadow-md transform rotate-6 -translate-x-2 group-hover:-translate-x-1 transition-transform duration-500" />
          </div>

          {/* Details */}
          <div class="flex items-center gap-1.5 mb-3">
            <div class="flex text-[#D97706] text-xs">★★★★★</div>
            <span class="text-[10px] font-bold text-gray-400 tracking-wider">5.0 (280+ reviews)</span>
          </div>

          <h3 class="text-xl lg:text-2xl font-['Playfair_Display'] font-black text-gray-900 mb-2">Double Capsules Pack</h3>
          <p class="text-gray-500 text-xs mb-6">2x Premium Capsules (240 Caps total). Formulated for 60 days of sustained immunity & gut strength.</p>

          <div class="border-t border-gray-100 pt-4 mb-6">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs text-gray-400 line-through">₹2,400</span>
              <span class="text-[9px] font-black text-[#166534] bg-[#f0fdf4] px-2 py-0.5 rounded-sm uppercase tracking-widest">SAVE ₹401</span>
            </div>
            <div class="flex items-baseline gap-2">
              <span class="text-3xl font-black text-gray-900">₹1,999</span>
              <span class="text-[10px] font-semibold text-gray-500">/ 60 Days Supply</span>
            </div>
            <div class="text-[10px] text-emerald-600 font-bold mt-2 flex items-center gap-1">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
              Daily Investment: Just ₹33/day
            </div>
          </div>
        </div>

        <button 
          class="add-to-cart-btn w-full bg-[#111827] hover:bg-[#166534] text-white py-4 rounded-xl font-bold text-xs uppercase tracking-wider transition-all duration-300"
          data-variant-ids="gid://shopify/ProductVariant/59247880438094,gid://shopify/ProductVariant/59247880438094"
        >
          Add to Routine
        </button>

      </div>

      {/* BUNDLE 3: Double Powder Pack */}
      <div class="group relative bg-white border border-gray-200/80 rounded-[2.5rem] p-6 lg:p-8 hover:border-emerald-500/30 hover:shadow-[0_30px_60px_rgba(22,101,52,0.06)] transition-all duration-500 flex flex-col justify-between h-full">
        
        {/* Hot badge */}
        <div class="absolute -top-3.5 left-8 bg-purple-900 text-white text-[9px] font-black uppercase tracking-widest px-4 py-1.5 rounded-full border border-purple-400/30 shadow-md">
          Family Saver
        </div>

        <div>
          {/* Images preview */}
          <div class="h-44 bg-[#F9FAFB] rounded-2xl flex items-center justify-center p-4 gap-4 relative overflow-hidden mb-6">
            <Image src="/spirulina-powder.png" alt="Powder 1" width={90} height={120} class="h-32 object-contain drop-shadow-md transform -rotate-6 translate-x-2 group-hover:translate-x-1 transition-transform duration-500" />
            <Image src="/spirulina-powder.png" alt="Powder 2" width={90} height={120} class="h-32 object-contain drop-shadow-md transform rotate-6 -translate-x-2 group-hover:-translate-x-1 transition-transform duration-500" />
          </div>

          {/* Details */}
          <div class="flex items-center gap-1.5 mb-3">
            <div class="flex text-[#D97706] text-xs">★★★★★</div>
            <span class="text-[10px] font-bold text-gray-400 tracking-wider">4.8 (190+ reviews)</span>
          </div>

          <h3 class="text-xl lg:text-2xl font-['Playfair_Display'] font-black text-gray-900 mb-2">Double Powder Pack</h3>
          <p class="text-gray-500 text-xs mb-6">2x Premium Powder (200g total). Best choice for cooking, smoothies, and family consumption.</p>

          <div class="border-t border-gray-100 pt-4 mb-6">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs text-gray-400 line-through">₹1,200</span>
              <span class="text-[9px] font-black text-[#166534] bg-[#f0fdf4] px-2 py-0.5 rounded-sm uppercase tracking-widest">SAVE ₹201</span>
            </div>
            <div class="flex items-baseline gap-2">
              <span class="text-3xl font-black text-gray-900">₹999</span>
              <span class="text-[10px] font-semibold text-gray-500">/ 2 Packs</span>
            </div>
            <div class="text-[10px] text-emerald-600 font-bold mt-2 flex items-center gap-1">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
              Super Value: Only ₹16/day per serving
            </div>
          </div>
        </div>

        <button 
          class="add-to-cart-btn w-full bg-[#111827] hover:bg-[#166534] text-white py-4 rounded-xl font-bold text-xs uppercase tracking-wider transition-all duration-300"
          data-variant-ids="gid://shopify/ProductVariant/59276906103118,gid://shopify/ProductVariant/59276906103118"
        >
          Add to Routine
        </button>

      </div>

    </div>

  </div>
</section>
