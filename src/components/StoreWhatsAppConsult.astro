---
// src/components/StoreWhatsAppConsult.astro
---

<section id="whatsapp-consultation" class="relative bg-emerald-950 py-16 md:py-24 font-['Inter'] overflow-hidden text-white border-t border-emerald-900">
  
  {/* Ambient light glow */}
  <div class="absolute inset-0 z-0 pointer-events-none opacity-20">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[80vw] h-[400px] bg-[radial-gradient(circle_at_center,rgba(52,211,153,0.35)_0%,transparent_60%)] blur-[60px]"></div>
  </div>

  <div class="max-w-[70rem] mx-auto px-6 relative z-10">
    
    {/* Inner Box with Glassmorphism */}
    <div class="bg-white/[0.03] border border-white/10 rounded-[3rem] p-8 md:p-14 lg:p-16 flex flex-col lg:flex-row items-center justify-between gap-10 shadow-2xl backdrop-blur-md">
      
      {/* Left Column: Text Content */}
      <div class="flex-1 text-center lg:text-left">
        <span class="inline-flex items-center gap-2 bg-[#166534] border border-emerald-400/30 text-emerald-300 text-[10px] font-black uppercase tracking-widest px-4 py-1.5 rounded-full mb-6">
          <span class="w-2 h-2 rounded-full bg-emerald-400 animate-ping"></span>
          Free Nutrition Consultation
        </span>
        
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-['Playfair_Display'] font-black leading-tight mb-4 text-white">
          Confused about dosage?<br/>
          <span class="italic text-emerald-300">WhatsApp our Nutritionist.</span>
        </h2>
        
        <p class="text-emerald-100/70 text-sm md:text-base max-w-lg mb-8 mx-auto lg:mx-0">
          Apni lifestyle ke hisab se sahi protocol janiye. Get a personalized diet chart and spirulina dosage guide from our expert clinical nutritionist directly on WhatsApp. 
          <span class="block mt-2 font-bold text-emerald-400">100% Free • No Automated Bots • Real Doctors.</span>
        </p>

        {/* Highlight points with icons */}
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-left max-w-xl mx-auto lg:mx-0">
          <div class="flex items-center gap-3">
            <span class="text-emerald-400 font-bold text-lg">💬</span>
            <span class="text-xs font-semibold text-emerald-100">Live Chat within 5 Mins</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-emerald-400 font-bold text-lg">📋</span>
            <span class="text-xs font-semibold text-emerald-100">Free Customized Diet Chart</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-emerald-400 font-bold text-lg">💊</span>
            <span class="text-xs font-semibold text-emerald-100">Safe Dose Verification</span>
          </div>
        </div>
      </div>

      {/* Right Column: CTA Button */}
      <div class="w-full lg:w-auto shrink-0 flex flex-col items-center gap-3">
        <a 
          href="https://wa.me/919999999999?text=Hello%20Sujata%20Nutrilive,%20I%20want%20a%20free%20diet%20consultation%20and%20product%20dosage%20guide." 
          target="_blank" 
          rel="noopener noreferrer"
          class="w-full sm:w-auto bg-[#25D366] hover:bg-[#20ba5a] text-emerald-950 px-8 py-5 rounded-2xl font-extrabold text-sm uppercase tracking-wider shadow-[0_15px_30px_rgba(37,211,102,0.2)] hover:shadow-[0_20px_40px_rgba(37,211,102,0.35)] transition-all duration-300 flex items-center justify-center gap-3 text-center"
        >
          {/* WhatsApp SVG Icon */}
          <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24">
            <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.5-5.739-1.446L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.725 1.45 5.535 0 10.026-4.488 10.029-10.02.002-2.684-1.038-5.207-2.93-7.101C16.559 1.588 14.054.55 11.4.553 5.865.553 1.376 5.04 1.373 10.573c-.001 1.702.464 3.367 1.348 4.838l-.99 3.613 3.7-.971zm12.39-5.127c-.302-.15-1.786-.88-2.062-.98-.277-.1-.478-.15-.679.15-.201.3-.778.98-.954 1.18-.176.2-.352.225-.654.075-.302-.15-1.276-.47-2.43-1.498-.897-.8-1.502-1.787-1.678-2.087-.176-.3-.019-.462.13-.611.135-.134.302-.35.453-.525.15-.175.2-.3.302-.5.101-.2.05-.375-.025-.525-.075-.15-.679-1.635-.93-2.245-.244-.587-.49-.508-.679-.518-.176-.008-.377-.01-.578-.01-.201 0-.527.075-.803.375-.276.3-1.054 1.03-1.054 2.51 0 1.48 1.08 2.91 1.23 3.11.15.2 2.124 3.245 5.144 4.545.718.31 1.277.495 1.713.635.722.23 1.378.197 1.897.12.579-.085 1.786-.73 2.037-1.43.251-.7.251-1.3.176-1.43-.075-.13-.277-.205-.578-.355z"/>
          </svg>
          Chat on WhatsApp
        </a>
        
        <span class="text-[10px] text-emerald-300/60 font-semibold tracking-wider uppercase">
          ⚡ Sathi Nutritionist Available Now
        </span>
      </div>

    </div>
  </div>
</section>
