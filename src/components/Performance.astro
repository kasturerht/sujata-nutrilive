---
---
<section id="performance" class="py-24 relative z-10 bg-[#000000] border-y border-white/5 overflow-hidden">
  
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] bg-cyan-900/10 blur-[150px] rounded-full pointer-events-none z-0"></div>

  <div class="max-w-6xl mx-auto px-6 lg:px-8 relative z-10">
    
    <div class="flex flex-col md:flex-row gap-12 items-end mb-16">
        <div class="w-full md:w-1/2">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-900/80 border border-slate-700/50 text-xs text-slate-300 font-mono mb-6 backdrop-blur-sm">
                <span class="w-1.5 h-1.5 rounded-full bg-cyan-500 animate-pulse"></span>
                Live Telemetry
            </div>
            <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tighter text-white leading-tight">
                We don't guess. <br/>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">We measure & scale.</span>
            </h2>
        </div>
        <div class="w-full md:w-1/2 pb-2">
            <p class="text-slate-400 text-lg font-light leading-relaxed">
                Hope is not a strategy. We implement ruthless analytics, advanced tag management, and flawless technical SEO to ensure every dollar you spend delivers measurable pipeline growth.
            </p>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 telemetry-cards">
        
        <div class="telemetry-card rounded-3xl bg-[#0a0a0a] p-8 md:p-10 relative overflow-hidden flex flex-col justify-between group h-[320px]">
            <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 to-transparent opacity-50"></div>
            <div class="relative z-10">
                <p class="text-xs text-slate-500 font-mono uppercase tracking-widest mb-2">Organic Growth</p>
                <div class="flex items-baseline gap-2">
                    <p class="text-6xl font-black text-white tracking-tighter counter-value" data-target="340">0</p>
                    <span class="text-3xl font-medium text-emerald-400">%</span>
                </div>
            </div>
            <div class="relative z-10 mt-auto">
                <svg class="w-full h-24 overflow-visible" viewBox="0 0 200 60" preserveAspectRatio="none">
                    <defs>
                        <linearGradient id="grad1" x1="0%" y1="0%" x2="0%" y2="100%">
                            <stop offset="0%" stop-color="#10b981" stop-opacity="0.2" />
                            <stop offset="100%" stop-color="#10b981" stop-opacity="0" />
                        </linearGradient>
                    </defs>
                    <path class="spark-fill opacity-0 transition-opacity duration-1000" d="M0,60 L0,50 C40,40 60,55 100,30 C140,5 160,20 200,5 L200,60 Z" fill="url(#grad1)" />
                    <path class="spark-line" d="M0,50 C40,40 60,55 100,30 C140,5 160,20 200,5" fill="none" stroke="#10b981" stroke-width="2.5" stroke-linecap="round" stroke-dasharray="300" stroke-dashoffset="300" />
                    <circle cx="200" cy="5" r="4" fill="#10b981" class="spark-dot opacity-0" />
                </svg>
                <p class="text-sm text-slate-400 mt-4 font-light">Sustained traffic increases across enterprise portfolios within 6 months.</p>
            </div>
        </div>

        <div class="telemetry-card rounded-3xl bg-[#0a0a0a] p-8 md:p-10 relative overflow-hidden flex flex-col justify-between group h-[320px]">
            <div class="absolute inset-0 bg-gradient-to-br from-cyan-500/5 to-transparent opacity-50"></div>
            <div class="relative z-10">
                <p class="text-xs text-slate-500 font-mono uppercase tracking-widest mb-2">Page Load Speeds</p>
                <div class="flex items-baseline gap-2">
                    <span class="text-3xl font-medium text-cyan-400 opacity-0 fade-in-element">&lt;</span>
                    <p class="text-6xl font-black text-white tracking-tighter opacity-0 fade-in-element delay-100">0.8<span class="text-3xl font-medium text-cyan-400">s</span></p>
                </div>
            </div>
            <div class="relative z-10 mt-auto flex items-end justify-between">
                <p class="text-sm text-slate-400 font-light pr-4">We engineer front-ends that consistently hit 99+ on Google Core Web Vitals.</p>
                
                <div class="relative w-16 h-16 shrink-0 flex items-center justify-center">
                    <svg class="w-full h-full transform -rotate-90" viewBox="0 0 36 36">
                        <path class="text-slate-800" stroke-width="3" stroke="currentColor" fill="none" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                        <path class="text-cyan-400 ring-progress" stroke-width="3" stroke-dasharray="0, 100" stroke="currentColor" fill="none" stroke-linecap="round" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                    </svg>
                    <div class="absolute inset-0 flex items-center justify-center text-[10px] font-mono text-cyan-400 font-bold opacity-0 fade-in-element delay-500">99+</div>
                </div>
            </div>
        </div>

        <div class="telemetry-card rounded-3xl bg-[#0a0a0a] p-8 md:p-10 relative overflow-hidden flex flex-col justify-between group h-[320px]">
            <div class="absolute inset-0 bg-gradient-to-br from-blue-500/5 to-transparent opacity-50"></div>
            <div class="relative z-10">
                <p class="text-xs text-slate-500 font-mono uppercase tracking-widest mb-2">Conversion Lift</p>
                <div class="flex items-baseline gap-1">
                    <p class="text-6xl font-black text-white tracking-tighter counter-value" data-target="5">0</p>
                    <span class="text-4xl font-black text-blue-500">x</span>
                </div>
            </div>
            <div class="relative z-10 mt-auto">
                <div class="flex items-end gap-2 h-16 mb-4">
                    <div class="w-1/4 bg-slate-800 rounded-t-sm h-[20%] transition-all duration-1000"></div>
                    <div class="w-1/4 bg-slate-700 rounded-t-sm h-[40%] transition-all duration-1000 delay-100"></div>
                    <div class="w-1/4 bg-blue-900/40 rounded-t-sm h-[60%] transition-all duration-1000 delay-200"></div>
                    <div class="w-1/4 bg-blue-500 rounded-t-sm h-[0%] bar-final transition-all duration-1000 delay-300 relative shadow-[0_0_15px_rgba(59,130,246,0.3)]">
                        <div class="absolute -top-5 left-1/2 -translate-x-1/2 text-[9px] text-blue-400 font-mono opacity-0 bar-label transition-opacity delay-1000">MAX</div>
                    </div>
                </div>
                <p class="text-sm text-slate-400 font-light">Through precision GA4 tracking and data-driven UX optimization.</p>
            </div>
        </div>

    </div>
  </div>
</section>

<style>
  /* =========================================
     MOUSE SPOTLIGHT EFFECT (Consistent Aesthetic)
     ========================================= */
  .telemetry-cards:hover > .telemetry-card::after {
    opacity: 1;
  }

  .telemetry-card {
    background-color: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    position: relative;
  }

  .telemetry-card::before,
  .telemetry-card::after {
    border-radius: inherit;
    content: "";
    height: 100%;
    left: 0px;
    opacity: 0;
    position: absolute;
    top: 0px;
    transition: opacity 500ms;
    width: 100%;
  }

  .telemetry-card::before {
    background: radial-gradient(
      600px circle at var(--mouse-x) var(--mouse-y), 
      rgba(255, 255, 255, 0.1),
      transparent 40%
    );
    z-index: 3;
    pointer-events: none;
  }

  .telemetry-card::after {  
    background: radial-gradient(
      600px circle at var(--mouse-x) var(--mouse-y), 
      rgba(255, 255, 255, 0.02),
      transparent 40%
    );
    z-index: 1;
    pointer-events: none;
  }

  .telemetry-card > * {
    z-index: 2;
    position: relative;
  }

  /* =========================================
     SCROLL TRIGGERED SVG ANIMATIONS (Clean & Premium)
     ========================================= */
  
  /* Fade-in Elements */
  .fade-in-element { transition: opacity 0.8s ease-out; }
  .is-visible .fade-in-element { opacity: 1; }

  /* Sparkline Animation */
  .is-visible .spark-line { animation: drawLine 1.5s ease-out forwards; }
  .is-visible .spark-fill { opacity: 1; transition-delay: 1s; }
  .is-visible .spark-dot  { opacity: 1; transition: opacity 0.5s ease-in 1.5s; }

  @keyframes drawLine {
    to { stroke-dashoffset: 0; }
  }

  /* Ring Animation */
  .is-visible .ring-progress { animation: drawRing 1.5s cubic-bezier(0.4, 0, 0.2, 1) forwards; }

  @keyframes drawRing {
    from { stroke-dasharray: 0, 100; }
    to { stroke-dasharray: 99, 100; }
  }

  /* Bar Chart Animation */
  .is-visible .bar-final { height: 100% !important; }
  .is-visible .bar-label { opacity: 1; }
</style>

<script is:inline>
  function initTelemetry() {
    // 1. Mouse Spotlight Engine
    const handleOnMouseMove = e => {
        const { currentTarget: target } = e;
        const rect = target.getBoundingClientRect(),
            x = e.clientX - rect.left,
            y = e.clientY - rect.top;

        target.style.setProperty("--mouse-x", `${x}px`);
        target.style.setProperty("--mouse-y", `${y}px`);
    }

    for(const card of document.querySelectorAll('.telemetry-card')) {
        card.onmousemove = e => handleOnMouseMove(e);
    }

    // 2. Intersection Observer (Triggers animation only when scrolled into view)
    const observerOptions = {
        threshold: 0.3 // Trigger when 30% of the section is visible
    };

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                // Add class to trigger CSS animations
                entry.target.classList.add('is-visible');
                
                // Fast JS Counter Logic
                const counters = entry.target.querySelectorAll('.counter-value');
                counters.forEach(counter => {
                    const target = +counter.getAttribute('data-target');
                    const duration = 1500; 
                    const step = target / (duration / 16); 
                    let current = 0;

                    const updateCounter = () => {
                        current += step;
                        if (current < target) {
                            counter.innerText = Math.ceil(current);
                            requestAnimationFrame(updateCounter);
                        } else {
                            counter.innerText = target; // Ensure exact final value
                        }
                    };
                    updateCounter();
                });

                // Unobserve after running once
                observer.unobserve(entry.target);
            }
        });
    }, observerOptions);

    const section = document.getElementById('performance');
    if (section) observer.observe(section);
  }

  document.addEventListener('astro:page-load', initTelemetry);
  initTelemetry();
</script>