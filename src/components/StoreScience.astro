---
// src/components/StoreScience.astro
---

<section id="lux-scanner-section" class="relative bg-[#030303] w-full h-[400vh] font-['Inter'] selection:bg-emerald-900 selection:text-white">
  
  <div class="sticky top-0 h-[100svh] w-full overflow-hidden flex items-center justify-center bg-[#020202]">
    
    {/* 1. THE RICH MINIMALIST VOID */}
    <div class="absolute inset-0 z-0 opacity-40">
      <div class="absolute top-[-10%] left-[-10%] w-[50vw] h-[50vw] bg-emerald-900/20 rounded-full blur-[120px] mix-blend-screen animate-[pulse_8s_ease-in-out_infinite]"></div>
      <div class="absolute bottom-[-10%] right-[-10%] w-[60vw] h-[60vw] bg-teal-900/10 rounded-full blur-[150px] mix-blend-screen animate-[pulse_12s_ease-in-out_infinite_reverse]"></div>
    </div>

    {/* 2. FLOATING BOKEH PARTICLES */}
    <div id="bokeh-container" class="absolute inset-0 z-0 pointer-events-none transition-all duration-1000">
      <div class="absolute top-[20%] left-[15%] w-32 h-32 bg-emerald-500/10 rounded-full blur-[40px]"></div>
      <div class="absolute bottom-[30%] right-[15%] w-48 h-48 bg-teal-500/10 rounded-full blur-[50px]"></div>
      <div class="absolute top-[60%] right-[25%] w-24 h-24 bg-emerald-300/5 rounded-full blur-[30px]"></div>
    </div>

    {/* 3. THE DYNAMIC BACKGROUND PRODUCTS */}
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none z-0">
      <img id="bg-bottle" src="/spirulina-bottle.png" alt="Sujata Capsules" class="absolute h-[60vh] md:h-[75vh] object-contain will-change-transform" style="opacity: 0.2; filter: grayscale(80%) blur(4px); clip-path: inset(0% 0% 0% 0%);" />
      <img id="bg-powder" src="/spirulina-powder.png" alt="Sujata Powder" class="absolute h-[60vh] md:h-[75vh] object-contain will-change-transform" style="opacity: 0.2; filter: grayscale(80%) blur(4px); clip-path: inset(0% 0% 100% 0%);" />
    </div>

    {/* 4. STAGGERED TYPOGRAPHY */}
    <div class="absolute inset-0 z-30 pointer-events-none flex flex-col justify-center px-6 md:px-24">
      <div id="text-1" class="absolute left-4 md:left-24 top-1/2 -translate-y-1/2 opacity-0 transition-all duration-[800ms] ease-out w-[90%] sm:w-3/4 md:w-1/3 text-left">
        <p class="text-emerald-400 text-[9px] md:text-xs tracking-[0.3em] md:tracking-[0.4em] uppercase font-bold mb-3 md:mb-4 drop-shadow-lg">Phase 01 / Absorption</p>
        <h2 class="text-[clamp(2rem,5vw,3.75rem)] text-white font-['Playfair_Display'] font-black leading-[1.1] drop-shadow-2xl">
          60% Bio-Active<br/><span class="italic text-gray-400 font-light">Protein.</span>
        </h2>
      </div>
      <div id="text-2" class="absolute right-4 md:right-24 top-1/2 -translate-y-1/2 opacity-0 transition-all duration-[800ms] ease-out w-[90%] sm:w-3/4 md:w-1/3 text-right">
        <p class="text-emerald-400 text-[9px] md:text-xs tracking-[0.3em] md:tracking-[0.4em] uppercase font-bold mb-3 md:mb-4 drop-shadow-lg">Phase 02 / Preservation</p>
        <h2 class="text-[clamp(2rem,5vw,3.75rem)] text-white font-['Playfair_Display'] font-black leading-[1.1] drop-shadow-2xl">
          Cold Pressed.<br/><span class="italic text-gray-400 font-light">Live Enzymes.</span>
        </h2>
      </div>
      <div id="text-3" class="absolute left-4 md:left-24 top-1/2 -translate-y-1/2 opacity-0 transition-all duration-[800ms] ease-out w-[90%] sm:w-3/4 md:w-1/3 text-left">
        <p class="text-emerald-400 text-[9px] md:text-xs tracking-[0.3em] md:tracking-[0.4em] uppercase font-bold mb-3 md:mb-4 drop-shadow-lg">Phase 03 / Standard</p>
        <h2 class="text-[clamp(2rem,5vw,3.75rem)] text-white font-['Playfair_Display'] font-black leading-[1.1] drop-shadow-2xl">
          Triple Lab<br/><span class="italic text-gray-400 font-light">Tested.</span>
        </h2>
      </div>
    </div>

    {/* 5. THE CLIMAX LIGHT SWEEP */}
    <div id="climax-sweep" class="absolute inset-0 z-10 pointer-events-none opacity-0 transition-opacity duration-1000 flex items-center justify-center">
      <div class="absolute w-[200%] h-[20%] bg-gradient-to-b from-transparent via-white/5 to-transparent -rotate-45 animate-[sweep_3s_ease-in-out_infinite]"></div>
    </div>

    {/* 6. THE MAGIC X-RAY LENS */}
    <div id="scanner-lens" class="absolute z-20 w-[95%] md:w-[min(700px,90vw)] h-[180px] sm:h-[220px] md:h-[280px] border-t border-b border-white/20 bg-black/30 backdrop-blur-[16px] overflow-hidden shadow-[0_0_80px_rgba(0,0,0,0.5)] flex items-center justify-center will-change-transform -translate-y-[150vh]">
      <div id="lens-inner" class="absolute w-screen h-[100svh] flex items-center justify-center will-change-transform translate-y-[150vh]">
        <img id="fg-bottle" src="/spirulina-bottle.png" class="absolute h-[60vh] md:h-[75vh] object-contain drop-shadow-[0_0_50px_rgba(16,185,129,0.2)] scale-[1.02]" style="clip-path: inset(0% 0% 0% 0%);" />
        <img id="fg-powder" src="/spirulina-powder.png" class="absolute h-[60vh] md:h-[75vh] object-contain drop-shadow-[0_0_50px_rgba(16,185,129,0.2)] scale-[1.02]" style="clip-path: inset(0% 0% 100% 0%);" />
      </div>
      <div class="absolute top-0 w-full h-[1px] bg-gradient-to-r from-transparent via-emerald-300/60 to-transparent shadow-[0_0_20px_rgba(52,211,153,1)]"></div>
      <div class="absolute bottom-0 w-full h-[1px] bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
    </div>

  </div>
</section>

<style is:global>
  @keyframes sweep {
    0% { transform: translateY(-150vh) rotate(-45deg); }
    100% { transform: translateY(150vh) rotate(-45deg); }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.getElementById('lux-scanner-section');
    const lens = document.getElementById('scanner-lens');
    const lensInner = document.getElementById('lens-inner');
    const bgBottle = document.getElementById('bg-bottle');
    const bgPowder = document.getElementById('bg-powder');
    const fgBottle = document.getElementById('fg-bottle');
    const fgPowder = document.getElementById('fg-powder');
    const bokehContainer = document.getElementById('bokeh-container');
    const climaxSweep = document.getElementById('climax-sweep');
    const texts = [
      document.getElementById('text-1'), 
      document.getElementById('text-2'), 
      document.getElementById('text-3')
    ];

    // 🌟 NEW: UNIVERSAL LERP VARIABLES
    let targetProgress = 0;
    let currentProgress = 0;
    let windowHeight = window.innerHeight;

    window.addEventListener('resize', () => { windowHeight = window.innerHeight; });

    // Scroll event ONLY sets the target progress now. No animations happen here!
    window.addEventListener('scroll', () => {
      const rect = section.getBoundingClientRect();
      if (rect.top <= 0 && rect.bottom >= windowHeight) {
        targetProgress = Math.abs(rect.top) / (rect.height - windowHeight);
      } else if (rect.bottom < windowHeight) {
        targetProgress = 1;
      } else if (rect.top > 0) {
        targetProgress = 0;
      }
    }, { passive: true });

    // 🌟 THE UNIFIED ENGINE (Everything runs in perfect sync here)
    const render = () => {
      // Smooth out the progress itself (The Butter Effect)
      currentProgress += (targetProgress - currentProgress) * 0.08;

      // 1. Move the Lens smoothly
      const travelDistance = windowHeight + 600; 
      const currentY = -(windowHeight / 2) - 300 + (currentProgress * travelDistance);
      lens.style.transform = `translateY(${currentY}px)`;
      lensInner.style.transform = `translateY(${-currentY}px)`;

      // 2. The Perfectly Synced Image Wipe
      let wipeP = 0;
      if (currentProgress > 0.35 && currentProgress < 0.60) {
        wipeP = (currentProgress - 0.35) / 0.25; 
      } else if (currentProgress >= 0.60) {
        wipeP = 1;
      }

      // .toFixed(2) removes sub-pixel jitter making the cut razor sharp
      const powderInset = (100 - (wipeP * 100)).toFixed(2);
      const bottleInset = (wipeP * 100).toFixed(2);

      bgPowder.style.clipPath = `inset(0% 0% ${powderInset}% 0%)`;
      fgPowder.style.clipPath = `inset(0% 0% ${powderInset}% 0%)`;
      bgBottle.style.clipPath = `inset(${bottleInset}% 0% 0% 0%)`;
      fgBottle.style.clipPath = `inset(${bottleInset}% 0% 0% 0%)`;

      // 3. Climax Logic
      if (currentProgress > 0.85) {
        const revealProgress = (currentProgress - 0.85) / 0.15; 
        bgPowder.style.opacity = 0.2 + (0.8 * revealProgress); 
        bgPowder.style.filter = `grayscale(${80 - (80 * revealProgress)}%) blur(${4 - (4 * revealProgress)}px)`;
        bgPowder.style.transform = `scale(${1 + (0.05 * revealProgress)})`; 

        bokehContainer.style.filter = `blur(${0 + (10 * revealProgress)}px)`;
        bokehContainer.style.opacity = 0.3 + (0.7 * revealProgress);
        climaxSweep.style.opacity = revealProgress;
      } else {
        bgPowder.style.opacity = 0.2;
        bgPowder.style.filter = `grayscale(80%) blur(4px)`;
        bgPowder.style.transform = `scale(1)`;
        
        bgBottle.style.opacity = 0.2;
        bgBottle.style.filter = `grayscale(80%) blur(4px)`;
        bgBottle.style.transform = `scale(1)`;
        
        bokehContainer.style.filter = `blur(0px)`;
        bokehContainer.style.opacity = 0.3;
        climaxSweep.style.opacity = 0;
      }

      // 4. Staggered Text Logic
      texts.forEach((text, index) => {
        const start = (index * 0.33);
        const end = start + 0.33;
        
        if (currentProgress > start && currentProgress < end) {
          const localP = (currentProgress - start) / 0.33;
          if(localP > 0.2 && localP < 0.8) {
            text.style.opacity = '1';
            text.style.transform = `translateY(0) translateX(0)`;
          } else {
            text.style.opacity = '0';
            const offset = index % 2 === 0 ? '-20px' : '20px';
            text.style.transform = localP <= 0.2 ? `translateY(30px) translateX(${offset})` : `translateY(-30px) translateX(${offset})`;
          }
        } else {
          text.style.opacity = '0';
        }
      });

      // Keep looping
      requestAnimationFrame(render);
    };
    
    // Start Engine
    render();
  });
</script>