---
// src/components/StoreHeader.astro
---

<header id="main-header" class="fixed top-0 w-full z-[100] transition-all duration-300">
  
  {/* 1. ANNOUNCEMENT BAR (Darker Tone) */}
  <div class="w-full bg-[#022C22] text-white overflow-hidden py-2 border-b border-white/5">
    <div class="flex whitespace-nowrap animate-[marquee_25s_linear_infinite] hover:pause">
      <span class="text-[9px] md:text-[10px] font-bold uppercase tracking-[0.25em] px-8 border-r border-white/10 flex items-center gap-2 opacity-90">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
        FLASH SALE: BUY 2 GET 1 FREE ON SPIRULINA POWDER
      </span>
      <span class="text-[9px] md:text-[10px] font-bold uppercase tracking-[0.25em] px-8 border-r border-white/10 opacity-90">
        🚀 FREE EXPRESS DELIVERY ABOVE ₹999
      </span>
      <span class="text-[9px] md:text-[10px] font-bold uppercase tracking-[0.25em] px-8 border-r border-white/10 opacity-90">
        🌿 100% PURE COLD-PRESSED FORMULATIONS
      </span>
      {/* Loop duplicate */}
      <span class="text-[9px] md:text-[10px] font-bold uppercase tracking-[0.25em] px-8 border-r border-white/10 flex items-center gap-2 opacity-90">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
        FLASH SALE: BUY 2 GET 1 FREE ON SPIRULINA POWDER
      </span>
    </div>
  </div>

  {/* 2. THE LUXURY UTILITY HEADER (Deep Emerald Background) */}
  <nav class="bg-[#064E3B] border-b border-[#043d2e] px-4 md:px-8 py-3 lg:py-4 shadow-xl">
    <div class="max-w-[95rem] mx-auto flex items-center justify-between gap-6 md:gap-8">
      
      {/* Logo - White Text */}
      <a href="/" class="flex-shrink-0">
        <h1 class="text-2xl md:text-3xl font-black text-white tracking-tighter font-['Playfair_Display']">
          SUJATA<span class="text-emerald-400">.</span>
        </h1>
      </a>

      {/* Pincode Tracker - Glassmorphism on Dark */}
      <div class="hidden lg:flex items-center gap-2.5 cursor-pointer group relative" id="pincode-trigger">
        <div class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center group-hover:bg-white/20 transition-colors border border-white/10">
          <svg class="w-4 h-4 text-emerald-100 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
        </div>
        <div class="flex flex-col">
          <span class="text-[9px] uppercase font-bold text-emerald-200/70 tracking-wider">Deliver to</span>
          <span class="text-[11px] font-bold text-white transition-colors" id="display-pincode">Check Pincode</span>
        </div>
        
        {/* Sleek Popup (Kept light for usability) */}
        <div id="pincode-popup" class="absolute top-[120%] left-0 w-64 bg-white shadow-[0_20px_40px_rgba(0,0,0,0.2)] rounded-2xl p-5 border border-gray-100 opacity-0 pointer-events-none transition-all duration-300 scale-95 origin-top-left z-50">
          <p class="text-xs font-bold text-[#111827] mb-3">Verify Pincode</p>
          <div class="flex gap-2">
            <input type="text" id="pincode-input" maxlength="6" placeholder="e.g. 411001" class="w-full bg-gray-50 border border-gray-200 rounded-xl px-3 py-2 text-xs focus:ring-2 focus:ring-[#166534] focus:bg-white outline-none transition-all text-black" />
            <button id="verify-btn" class="bg-[#111827] text-white px-4 py-2 rounded-xl text-[10px] font-bold uppercase tracking-widest hover:bg-[#166534] transition-colors shadow-md">Set</button>
          </div>
          <p id="pincode-status" class="text-[9px] mt-2 hidden"></p>
        </div>
      </div>

      {/* Main Search Bar - Dark Glass Pill */}
      <div class="hidden md:block flex-1 max-w-xl relative group">
        <input 
          type="text" 
          placeholder="Search for 'Spirulina Powders', 'Hair Oil'..." 
          class="w-full bg-black/20 hover:bg-black/30 border border-white/10 text-white placeholder-emerald-100/50 rounded-full px-5 py-2.5 md:py-3 text-xs md:text-sm focus:bg-black/40 focus:ring-2 focus:ring-emerald-400/30 focus:border-emerald-400/50 outline-none transition-all pl-12 shadow-inner"
        />
        <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-emerald-100/60 group-focus-within:text-emerald-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
      </div>

      {/* Action Icons - White lines on Dark */}
      <div class="flex items-center gap-3 md:gap-5">
        <a href="/account" class="hidden sm:flex flex-col items-center gap-1 group">
          <div class="w-9 h-9 rounded-full hover:bg-white/10 flex items-center justify-center transition-colors">
            <svg class="w-4 h-4 text-emerald-50 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
          </div>
        </a>
        
        <button id="cart-drawer-trigger" class="relative group bg-emerald-800/50 border border-white/20 p-2.5 md:px-5 md:py-2.5 rounded-full flex items-center gap-2.5 hover:bg-white hover:border-white transition-all shadow-lg hover:shadow-xl">
          <svg class="w-4 h-4 text-white group-hover:text-[#064E3B] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
          <span class="hidden md:block text-[10px] font-bold uppercase tracking-widest text-white group-hover:text-[#064E3B] transition-colors">Cart</span>
          <span id="header-cart-badge" style="display: none;" class="absolute -top-1 -right-1 md:top-auto md:right-auto md:relative w-4 h-4 md:w-5 md:h-5 bg-amber-500 text-white text-[9px] md:text-[10px] font-black rounded-full flex items-center justify-center shadow-[0_0_10px_rgba(245,158,11,0.4)]">0</span>
        </button>
      </div>

    </div>
  </nav>
</header>

<style is:global>
  @keyframes marquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
</style>

<script>
  function initPincode() {
    console.log("📍 Pincode Engine Loading...");
    const trigger = document.getElementById('pincode-trigger');
    const popup = document.getElementById('pincode-popup');
    const input = document.getElementById('pincode-input') as HTMLInputElement | null;
    const verifyBtn = document.getElementById('verify-btn');
    const status = document.getElementById('pincode-status');
    const display = document.getElementById('display-pincode');

    if (!trigger || !popup || !input || !verifyBtn || !status || !display) {
      console.warn("⚠️ Pincode elements missing in DOM.");
      return;
    }

    // Load saved pincode if exists
    const savedPincode = localStorage.getItem('sujata_pincode');
    if (savedPincode) {
      display.innerText = `Deliver to ${savedPincode}`;
      input.value = savedPincode;
    }

    const togglePopup = (show: boolean) => {
      if (show) {
        popup.classList.remove('opacity-0', 'pointer-events-none', 'scale-95');
        popup.classList.add('opacity-100', 'pointer-events-auto', 'scale-100');
        input.focus();
      } else {
        popup.classList.remove('opacity-100', 'pointer-events-auto', 'scale-100');
        popup.classList.add('opacity-0', 'pointer-events-none', 'scale-95');
      }
    };

    trigger.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('#pincode-popup')) {
        return;
      }
      const isVisible = popup.classList.contains('opacity-100');
      togglePopup(!isVisible);
    });

    // Close when clicking outside trigger/popup
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (!trigger.contains(target)) {
        togglePopup(false);
      }
    });

    // Close on Escape key press
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        togglePopup(false);
      }
    });

    const verifyPincode = () => {
      const value = input.value.trim();
      const isValid = /^\d{6}$/.test(value);

      status.classList.remove('hidden', 'text-red-500', 'text-emerald-600');

      if (!isValid) {
        status.innerText = 'Please enter a valid 6-digit pincode.';
        status.classList.add('text-red-500');
      } else {
        status.innerText = 'Serviceable! Express delivery available. 🚚';
        status.classList.add('text-emerald-600');
        localStorage.setItem('sujata_pincode', value);
        display.innerText = `Deliver to ${value}`;
        
        // Auto-close after successful validation
        setTimeout(() => {
          togglePopup(false);
          status.classList.add('hidden');
        }, 1500);
      }
    };

    verifyBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      verifyPincode();
    });

    input.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        e.stopPropagation();
        verifyPincode();
      }
    });
  }

  // Initialize pincode logic
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPincode);
  } else {
    initPincode();
  }

  // Handle page transitions in Astro
  document.addEventListener('astro:page-load', initPincode);
</script>