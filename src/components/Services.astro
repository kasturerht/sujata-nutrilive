---
---
<section id="expertise" class="py-24 relative z-10 bg-[#000000] border-y border-white/5 overflow-hidden">
  
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-blue-900/10 blur-[150px] rounded-full pointer-events-none z-0"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">
    
    <div class="mb-16 md:mb-24 flex flex-col md:flex-row md:items-end justify-between gap-8">
        <div class="max-w-2xl">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-900/80 border border-slate-700/50 text-xs text-slate-300 font-mono mb-6 backdrop-blur-sm">
                <span class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse"></span>
                The Arsenal
            </div>
            <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tighter text-white leading-tight">
                We don't just build websites. <br class="hidden lg:block" />
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500 drop-shadow-[0_0_15px_rgba(34,211,238,0.2)]">We engineer infrastructure.</span>
            </h2>
        </div>
        <div class="pb-2">
            <a href="#contact" class="group relative inline-flex items-center gap-2 px-6 py-3 bg-white text-slate-950 text-sm font-bold rounded-full overflow-hidden transition-transform hover:scale-105">
                <span class="relative z-10">Map Your Architecture</span>
                <svg class="w-4 h-4 relative z-10 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </a>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 expertise-cards">
        
        <div class="expertise-card group rounded-[2rem] bg-[#0a0a0a] border border-white/5 p-8 relative overflow-hidden flex flex-col h-auto md:h-[400px]">
            <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            
            <div class="relative h-32 mb-8 rounded-xl border border-white/5 bg-[#030712] overflow-hidden flex items-center justify-center">
                <div class="absolute inset-0 opacity-[0.2] bg-[linear-gradient(to_right,#10b981_1px,transparent_1px),linear-gradient(to_bottom,#10b981_1px,transparent_1px)] bg-[size:10px_10px]"></div>
                <div class="relative w-full px-6">
                    <div class="flex items-end gap-1.5 h-12">
                        <div class="w-1/5 bg-emerald-500/20 rounded-t-sm h-[30%] group-hover:h-[40%] transition-all duration-500"></div>
                        <div class="w-1/5 bg-emerald-500/40 rounded-t-sm h-[50%] group-hover:h-[65%] transition-all duration-500 delay-75"></div>
                        <div class="w-1/5 bg-emerald-500/60 rounded-t-sm h-[40%] group-hover:h-[80%] transition-all duration-500 delay-100"></div>
                        <div class="w-1/5 bg-emerald-500/80 rounded-t-sm h-[70%] group-hover:h-[90%] transition-all duration-500 delay-150"></div>
                        <div class="w-1/5 bg-emerald-400 rounded-t-sm h-[60%] group-hover:h-[100%] transition-all duration-500 delay-200 shadow-[0_0_15px_rgba(16,185,129,0.5)]"></div>
                    </div>
                </div>
            </div>

            <div class="mt-auto relative z-10">
                <p class="text-emerald-400/80 font-mono text-[10px] tracking-widest uppercase mb-2">SYS.01 // Content Architecture</p>
                <h3 class="text-2xl font-bold text-white mb-3 tracking-tight">Headless CMS Migration Experts</h3>
                <p class="text-slate-400 text-sm leading-relaxed font-light">We flawlessly migrate legacy monolithic setups (WordPress/Shopify) to a headless Sanity CMS backend. Structured data, real-time collaboration, and absolute freedom from bloated plugins.</p>
            </div>
        </div>

        <div class="expertise-card group rounded-[2rem] bg-[#0a0a0a] border border-white/5 p-8 relative overflow-hidden flex flex-col h-[350px] md:h-[400px] lg:col-span-2">
            <div class="absolute inset-0 bg-gradient-to-br from-cyan-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            
            <div class="absolute -right-16 md:right-0 top-0 bottom-0 w-[120%] md:w-1/2 flex items-center justify-end md:justify-center opacity-20 md:opacity-30 group-hover:opacity-60 md:group-hover:opacity-100 transition-opacity duration-700 pointer-events-none">
                <div class="relative w-48 h-48 md:w-56 md:h-56 border border-cyan-500/30 rounded-full animate-[spin_10s_linear_infinite] flex items-center justify-center">
                    <div class="absolute w-2 h-2 bg-cyan-400 rounded-full top-0 -translate-y-1/2 shadow-[0_0_10px_#22d3ee]"></div>
                    <div class="absolute w-2 h-2 bg-cyan-400 rounded-full bottom-0 translate-y-1/2 shadow-[0_0_10px_#22d3ee]"></div>
                </div>
                <div class="absolute w-32 h-32 md:w-36 md:h-36 border border-blue-500/30 rounded-full animate-[spin_7s_linear_infinite_reverse] flex items-center justify-center right-10 md:right-auto">
                    <div class="absolute w-1.5 h-1.5 bg-blue-400 rounded-full left-0 -translate-x-1/2"></div>
                    <div class="absolute w-1.5 h-1.5 bg-blue-400 rounded-full right-0 translate-x-1/2"></div>
                </div>
                <div class="absolute text-cyan-500 font-mono text-[8px] md:text-[10px] tracking-widest bg-slate-950/80 px-2 rounded right-20 md:right-auto backdrop-blur-sm">EDGE NODE</div>
            </div>

            <div class="mt-auto relative z-10 max-w-sm pointer-events-none">
                <p class="text-cyan-400/80 font-mono text-[10px] tracking-widest uppercase mb-2">SYS.02 // Front-End Delivery</p>
                <h3 class="text-2xl font-bold text-white mb-3 tracking-tight">Enterprise Astro Development</h3>
                <p class="text-slate-400 text-sm leading-relaxed font-light">We engineer highly optimized, decoupled front-ends using the Astro framework. Static pre-rendering delivered globally via Edge networks for sub-second load times and perfect Core Web Vitals.</p>
            </div>
        </div>

        <div class="expertise-card group rounded-[2rem] bg-[#0a0a0a] border border-white/5 p-8 relative overflow-hidden flex flex-col md:flex-row items-center gap-8 h-auto lg:col-span-3">
            <div class="absolute inset-0 bg-gradient-to-r from-blue-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            
            <div class="w-full md:w-1/2 relative z-10 order-2 md:order-1">
                <p class="text-blue-400/80 font-mono text-[10px] tracking-widest uppercase mb-2">SYS.03 // Telemetry Network</p>
                <h3 class="text-2xl font-bold text-white mb-3 tracking-tight">Server-Side Tracking Consultants</h3>
                <p class="text-slate-400 text-sm leading-relaxed font-light">We architect pristine data pipelines using advanced GA4 and GTM Server-Side tagging. Bypass iOS restrictions, secure user privacy, and feed advertising algorithms with 100% accurate conversion signals.</p>
            </div>

            <div class="w-full md:w-1/2 h-64 rounded-xl border border-white/5 bg-[#030712] overflow-hidden relative order-1 md:order-2 perspective-container">
                <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-32 h-32 bg-blue-500/20 blur-[60px] rounded-full pointer-events-none"></div>
                
                <div class="isometric-stack absolute top-1/2 left-1/2">
                    <div class="iso-layer layer-1 absolute bg-slate-900/80 border border-slate-700/50 backdrop-blur-md rounded-lg overflow-hidden flex items-center justify-center shadow-[0_0_30px_rgba(0,0,0,0.5)]">
                         <div class="absolute inset-0 opacity-[0.1] bg-[linear-gradient(to_right,#fff_1px,transparent_1px),linear-gradient(to_bottom,#fff_1px,transparent_1px)] bg-[size:8px_8px]"></div>
                    </div>
                    <div class="iso-layer layer-2 absolute bg-slate-800/40 border border-white/10 backdrop-blur-xl rounded-lg p-4 flex flex-col gap-3 shadow-[0_10px_30px_rgba(0,0,0,0.3)]">
                        <div class="w-1/3 h-2 bg-slate-600/50 rounded-full"></div>
                        <div class="w-3/4 h-2 bg-slate-700/50 rounded-full"></div>
                        <div class="w-1/2 h-2 bg-slate-700/50 rounded-full"></div>
                    </div>
                    <div class="iso-layer layer-3 absolute top-[60%] right-[10%]">
                        <div class="w-24 h-8 bg-gradient-to-r from-blue-600 to-blue-400 rounded-md shadow-[0_10px_25px_rgba(59,130,246,0.4),inset_0_1px_1px_rgba(255,255,255,0.3)] flex items-center justify-center relative overflow-hidden border border-blue-400/50">
                            <div class="absolute inset-0 bg-gradient-to-tr from-transparent via-white/20 to-transparent -translate-x-1/3"></div>
                            <div class="w-12 h-1.5 bg-white/80 rounded-full"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
  </div>
</section>

<style>
  /* =========================================
     MOUSE SPOTLIGHT ENGINE
     ========================================= */
  .expertise-cards:hover > .expertise-card::after {
    opacity: 1;
  }

  .expertise-card {
    background-color: rgba(255, 255, 255, 0.02);
    position: relative;
  }

  .expertise-card::before,
  .expertise-card::after {
    border-radius: inherit;
    content: "";
    height: 100%;
    left: 0px;
    opacity: 0;
    position: absolute;
    top: 0px;
    transition: opacity 500ms;
    width: 100%;
  }

  .expertise-card::before {
    background: radial-gradient(
      800px circle at var(--mouse-x) var(--mouse-y), 
      rgba(255, 255, 255, 0.1),
      transparent 40%
    );
    z-index: 3;
    pointer-events: none;
  }

  .expertise-card::after {  
    background: radial-gradient(
      600px circle at var(--mouse-x) var(--mouse-y), 
      rgba(255, 255, 255, 0.02),
      transparent 40%
    );
    z-index: 1;
    pointer-events: none;
  }



/* Add this to your <style> section in Services.astro */

  /* Give depth to the container */
  .perspective-container {
    perspective: 1000px;
  }

  /* Tilt the whole stack */
  .isometric-stack {
    width: 200px; /* Base width of the UI mockup */
    height: 140px; /* Base height */
    transform: translate(-50%, -50%) rotateX(55deg) rotateZ(-40deg);
    transform-style: preserve-3d;
  }

  /* Common styles for layers */
  .iso-layer {
    position: absolute;
    inset: 0;
    transition: transform 0.3s ease-out; /* Subtle shift on hover if needed, but keeps it mostly static */
  }

  /* Positioning the layers in 3D space */
  /* Layer 1 sits at the bottom */
  .layer-1 {
    transform: translateZ(0px);
  }
  
  /* Layer 2 floats above */
  .layer-2 {
    transform: translateZ(30px) scale(0.95); /* Slightly smaller for depth */
  }

  /* Layer 3 (Button) floats highest */
  .layer-3 {
    width: auto; height: auto; inset: auto; /* Reset inset for the button container */
    transform: translateZ(60px);
  }

  /* Subtle hover effect: The layers expand slightly apart */
  .expertise-card:hover .layer-2 {
    transform: translateZ(40px) scale(0.95);
  }
  .expertise-card:hover .layer-3 {
    transform: translateZ(80px);
  }


</style>

<script is:inline>
  function initServicesSpotlight() {
    const handleOnMouseMove = e => {
        const { currentTarget: target } = e;
        const rect = target.getBoundingClientRect(),
            x = e.clientX - rect.left,
            y = e.clientY - rect.top;

        target.style.setProperty("--mouse-x", `${x}px`);
        target.style.setProperty("--mouse-y", `${y}px`);
    }

    for(const card of document.querySelectorAll('.expertise-card')) {
        card.onmousemove = e => handleOnMouseMove(e);
    }
  }

  document.addEventListener('astro:page-load', initServicesSpotlight);
  initServicesSpotlight();
</script>