---
import StoreLayout from '../layouts/StoreLayout.astro';
import StoreHeader from '../components/StoreHeader.astro';
import StoreHero from '../components/StoreHero.astro';
import StoreProducts from '../components/StoreProducts.astro';
import StoreScience from '../components/StoreScience.astro';
import StoreTrust from '../components/StoreTrust.astro';
import StoreProtocol from '../components/StoreProtocol.astro';
import CartDrawer from '../components/CartDrawer.astro';
import ExitPopup from '../components/ExitPopup.astro';

// १. तुझे Shopify डिटेल्स
const shopifyDomain = 'skadas-headless-demo.myshopify.com'; 
const storefrontToken = '32f678c5f8d1345e945ed48713d9cf2f'; 

// २. संपूर्ण GraphQL Query
const query = `
  {
    products(first: 6) {
      edges {
        node {
          id
          handle
          title
          description
          availableForSale
          priceRange {
            minVariantPrice {
              amount
              currencyCode
            }
          }
          variants(first: 1) {
            edges {
              node {
                id
              }
            }
          }
          images(first: 2) {
            edges {
              node {
                url
                altText
              }
            }
          }
        }
      }
    }
  }
`;

// ३. Server-side Fetch
const response = await fetch(`https://${shopifyDomain}/api/2024-01/graphql.json`, {
  method: 'POST',
  headers: {
    'Content-Type': 'application/json',
    'X-Shopify-Storefront-Access-Token': storefrontToken,
  },
  body: JSON.stringify({ query }),
});

const json = await response.json();
const products = json.data?.products?.edges || [];
---

<StoreLayout title="Sujata Nutrilive | Absolute Peak">
  
  <StoreHeader />
  
  {/* 1. The Hook */}
  <StoreHero />
  
  {/* 2. The Product (Bento Box) */}
  <StoreProducts products={products} />
  
  {/* 🌟 3. The Micro-Science Anatomy (Idea 1) will go here soon! */}
  <StoreScience />

  <StoreProtocol />

  <StoreTrust />

  {/* Background Services */}
  <CartDrawer />
  <ExitPopup />

</StoreLayout>